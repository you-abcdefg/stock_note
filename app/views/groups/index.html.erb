<%# ***** groups/index のビュー ***** %>
<div class="container mt-4">
<%# ***** 「<div>」：汎用コンテナ要素 ***** %>
<%# ***** 「class ="【クラス名】"」：要素へスタイルを適用するクラス属性 ***** %>
  <h1>グループ（ジャンル）一覧</h1>
  <%# ***** 「<h1>【内容】</h1>」：見出し要素 ***** %>

  <div class="mb-3">
  <%# ***** 「<div>」：汎用コンテナ要素 ***** %>
  <%# ***** 「class ="【クラス名】"」：要素へスタイルを適用するクラス属性 ***** %>
    <%= link_to '新規グループ作成', new_group_path, class: 'btn btn-primary' %>
    <%# ***** 「link_to '新規グループ作成', new_group_path, class: 'btn btn-primary'」：画面へ値を出力する式 ***** %>
  </div>
  <%# ***** 「<div>【内容】</div>」：要素をまとめるための汎用コンテナ ***** %>

  <div class="row">
  <%# ***** 「<div>」：汎用コンテナ要素 ***** %>
  <%# ***** 一覧ループセクション ***** %>
  <%# ***** 「class ="【クラス名】"」：要素へスタイルを適用するクラス属性 ***** %>
    <% @groups.each do |group| %>
    <%# ***** 「@groups.each do |group|」：Ruby式を実行する処理 ***** %>
    <%# ***** 「each do |group|」: コレクションを順番に処理し、|group| で現在要素を受け取る反復構文 ***** %>
    <%# ***** 「@groups」：処理対象となるコレクション ***** %>
    <%# ***** 「|group|」：各反復で取り出した要素を受け取るブロック引数 ***** %>
    <%# ***** 「each」：コレクションを順に処理するループ ***** %>
      <div class="col-md-6 mb-4">
      <%# ***** 「<div>」：汎用コンテナ要素 ***** %>
      <%# ***** 「class ="【クラス名】"」：要素へスタイルを適用するクラス属性 ***** %>
        <div class="card h-100">
        <%# ***** 「<div>」：汎用コンテナ要素 ***** %>
        <%# ***** 「class ="【クラス名】"」：要素へスタイルを適用するクラス属性 ***** %>
          <div class="card-body">
          <%# ***** 「<div>」：汎用コンテナ要素 ***** %>
          <%# ***** 「class ="【クラス名】"」：要素へスタイルを適用するクラス属性 ***** %>
            <h5 class="card-title">
            <%# ***** 「<h5>」：見出し要素 ***** %>
            <%# ***** 「class ="【クラス名】"」：要素へスタイルを適用するクラス属性 ***** %>
              <%= link_to group.name, group_path(group) %>
              <%# ***** 「link_to group.name, group_path(group)」：画面へ値を出力する式 ***** %>
            </h5>
            <%# ***** 「<h5>【内容】</h5>」：見出し要素 ***** %>
            <p class="card-text text-muted">
            <%# ***** 「<p>」：段落要素 ***** %>
            <%# ***** 「class ="【クラス名】"」：要素へスタイルを適用するクラス属性 ***** %>
              <%= truncate(group.description, length: 100) %>
              <%# ***** 「truncate(group.description, length: 100)」：画面へ値を出力する式 ***** %>
            </p>
            <%# ***** 「<p>【内容】</p>」：段落要素 ***** %>
            <div class="d-flex justify-content-between align-items-center">
            <%# ***** 「<div>」：汎用コンテナ要素 ***** %>
            <%# ***** 「class ="【クラス名】"」：要素へスタイルを適用するクラス属性 ***** %>
              <div>
              <%# ***** 「<div>」：汎用コンテナ要素 ***** %>
                <small class="text-muted">
                <%# ***** 「<small>」：補足テキスト要素 ***** %>
                <%# ***** 「class ="【クラス名】"」：要素へスタイルを適用するクラス属性 ***** %>
                  投稿数: <%= group.posts.count %>件 |
                  メンバー: <%= group.users.count %>人
                </small>
                <%# ***** 「<small>【内容】</small>」：補足テキスト要素 ***** %>
                <%# ***** 条件分岐セクション ***** %>
                <% if user_signed_in? && current_user.group_memberships.exists?(group: group) %>
                <%# ***** 「if 【条件式】」：【条件式】が true の場合、以下の処理を実行する ***** %>
                <%# ***** 「user_signed_in?」：Deviseで定義されたログイン状態判定ヘルパー関数 ***** %>
                <%# ***** 「if 【条件式】」：【条件式】が true の場合、以下の処理を実行する ***** %>
                <%# ***** 「user_signed_in?」：Deviseのログイン状態を判定するヘルパーメソッド（true / false を返す） ***** %>
                  <span class="badge badge-success">所属中</span>
                  <%# ***** 「<span>【内容】</span>」：インライン要素 ***** %>
                  <%# ***** 「class ="【クラス名】"」：要素へスタイルを適用するクラス属性 ***** %>
                <% end %>
                <%# ***** 「end」：ブロック処理を終了するキーワード ***** %>
              </div>
              <%# ***** 「<div>【内容】</div>」：要素をまとめるための汎用コンテナ ***** %>
              <div>
              <%# ***** 「<div>」：汎用コンテナ要素 ***** %>
                <%= link_to '詳細', group_path(group), class: 'btn btn-sm btn-info' %>
                <%# ***** 「link_to '詳細', group_path(group), class: 'btn btn-sm btn-info'」：画面へ値を出力する式 ***** %>
                <% if current_user&.admin? %>
                <%# ***** 「if 【条件式】」：【条件式】が true の場合、以下の処理を実行する ***** %>
                  <%= link_to '編集', edit_group_path(group), class: 'btn btn-sm btn-warning' %>
                  <%# ***** 「link_to '編集', edit_group_path(group), class: 'btn btn-sm btn-warning'」：画面へ値を出力する式 ***** %>
                  <%= link_to '削除', group_path(group), method: :delete, data: { confirm: '本当に削除しますか？' }, class: 'btn btn-sm btn-danger' %>
                  <%# ***** 「link_to '削除', group_path(group), method: :delete, data: { confirm: '本当に削除しますか？' }, class: 'btn btn-sm btn-danger'」：画面へ値を出力する式 ***** %>
                <% end %>
                <%# ***** 「end」：ブロック処理を終了するキーワード ***** %>
              </div>
              <%# ***** 「<div>【内容】</div>」：要素をまとめるための汎用コンテナ ***** %>
            </div>
            <%# ***** 「<div>【内容】</div>」：要素をまとめるための汎用コンテナ ***** %>
          </div>
          <%# ***** 「<div>【内容】</div>」：要素をまとめるための汎用コンテナ ***** %>
        </div>
        <%# ***** 「<div>【内容】</div>」：要素をまとめるための汎用コンテナ ***** %>
      </div>
      <%# ***** 「<div>【内容】</div>」：要素をまとめるための汎用コンテナ ***** %>
    <% end %>
    <%# ***** 「end」：ブロック処理を終了するキーワード ***** %>
  </div>
  <%# ***** 「<div>【内容】</div>」：要素をまとめるための汎用コンテナ ***** %>

  <%= paginate @groups %>
  <%# ***** 「paginate @groups」：画面へ値を出力する式 ***** %>
</div>
<%# ***** 「<div>【内容】</div>」：要素をまとめるための汎用コンテナ ***** %>
