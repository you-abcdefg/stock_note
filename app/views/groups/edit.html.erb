<%# ***** groups/edit のビュー ***** %>
<div class="container mt-4">
<%# ***** div：汎用コンテナ要素 ***** %>
  <h1>グループ編集</h1>

<%# ***** 入力フォームセクション ***** %>
  <%= form_with(model: @group, local: true) do |f| %>
  <%# ***** エラーメッセージ表示セクション ***** %>
  <%# ***** 条件分岐セクション ***** %>
    <% if @group.errors.any? %>
    <%# ***** if：条件を判定する分岐 ***** %>
      <div class="alert alert-danger">
      <%# ***** div：汎用コンテナ要素 ***** %>
        <h4><%= pluralize(@group.errors.count, "error") %> prohibited this group from being saved:</h4>
        <%# ***** h4：見出し要素 ***** %>
        <ul>
<%# ***** 一覧ループセクション ***** %>
          <% @group.errors.full_messages.each do |message| %>
          <%# ***** each：コレクションを順に処理するループ ***** %>
            <li><%= message %></li>
            <%# ***** li：リスト項目要素 ***** %>
          <% end %>
        </ul>
        <%# ***** </ul>：ulタグ（順序なしリスト要素）の終了 ***** %>
      </div>
      <%# ***** </div>：divタグ（汎用コンテナ要素）の終了 ***** %>
    <% end %>

    <div class="form-group">
    <%# ***** div：汎用コンテナ要素 ***** %>
      <%= f.label :name, 'グループ名' %>
    <%# ***** フォーム入力欄セクション ***** %>
      <%= f.text_field :name, class: 'form-control' %>
    </div>
    <%# ***** </div>：divタグ（汎用コンテナ要素）の終了 ***** %>

    <div class="form-group">
    <%# ***** div：汎用コンテナ要素 ***** %>
      <%= f.label :description, '説明' %>
      <%= f.text_area :description, class: 'form-control', rows: 5 %>
    </div>
    <%# ***** </div>：divタグ（汎用コンテナ要素）の終了 ***** %>

    <div class="actions mt-4">
    <%# ***** 送信ボタンセクション ***** %>
      <%= f.submit '更新', class: 'btn btn-primary' %>
      <%= link_to 'キャンセル', group_path(@group), class: 'btn btn-secondary' %>
    </div>
    <%# ***** </div>：divタグ（汎用コンテナ要素）の終了 ***** %>
  <% end %>
</div>
<%# ***** </div>：divタグ（汎用コンテナ要素）の終了 ***** %>
