<%# ***** groups/show のビュー ***** %>
<div class="container mt-4">
<%# ***** div：汎用コンテナ要素 ***** %>
  <div class="row">
  <%# ***** div：汎用コンテナ要素 ***** %>
    <div class="col-md-8">
    <%# ***** div：汎用コンテナ要素 ***** %>
      <h1><%= @group.name %></h1>
      <%# ***** h1：見出し要素 ***** %>
      <p class="lead"><%= @group.description %></p>
      <%# ***** p：段落要素 ***** %>

      <div class="mb-3">
      <%# ***** div：汎用コンテナ要素 ***** %>
        <span class="badge badge-info">投稿数: <%= @group.posts.count %>件</span>
        <%# ***** span：インライン要素 ***** %>
        <span class="badge badge-success">メンバー: <%= @group.users.count %>人</span>
        <%# ***** span：インライン要素 ***** %>
      </div>
      <%# ***** </div>：divタグ（汎用コンテナ要素）の終了 ***** %>

      <div class="mb-4">
    <%# ***** 条件分岐セクション ***** %>
        <% if user_signed_in? %>
        <%# ***** if：条件を判定する分岐 ***** %>
          <% if current_user.group_memberships.exists?(group: @group) %>
          <%# ***** if：条件を判定する分岐 ***** %>
            <%= link_to 'グループから退出', leave_group_path(@group), method: :delete, class: 'btn btn-secondary' %>
          <% else %>
          <%# ***** else：上記条件に当てはまらない場合の分岐 ***** %>
            <%= link_to 'グループに参加', join_group_path(@group), method: :post, class: 'btn btn-primary' %>
          <% end %>
        <% end %>
        <% if current_user&.admin? %>
        <%# ***** if：条件を判定する分岐 ***** %>
          <%= link_to '編集', edit_group_path(@group), class: 'btn btn-warning' %>
          <%= link_to '削除', group_path(@group), method: :delete, data: { confirm: '本当に削除しますか？' }, class: 'btn btn-danger' %>
        <% end %>
      </div>
      <%# ***** </div>：divタグ（汎用コンテナ要素）の終了 ***** %>

      <h3 class="mt-4">このグループの投稿</h3>
      <%# ***** h3：見出し要素 ***** %>
      <% if @group.posts.published.any? %>
      <%# ***** 一覧ループセクション ***** %>
        <% @group.posts.published.order(created_at: :desc).each do |post| %>
        <%# ***** each：コレクションを順に処理するループ ***** %>
          <div class="card mb-3">
          <%# ***** div：汎用コンテナ要素 ***** %>
            <div class="card-body">
            <%# ***** div：汎用コンテナ要素 ***** %>
              <h5 class="card-title">
              <%# ***** h5：見出し要素 ***** %>
                <%= link_to post.title, post_path(post) %>
              </h5>
              <%# ***** </h5>：h5タグ（見出し要素）の終了 ***** %>
              <p class="card-text"><%= truncate(post.body, length: 150) %></p>
              <%# ***** p：段落要素 ***** %>
              <div class="d-flex justify-content-between">
              <%# ***** div：汎用コンテナ要素 ***** %>
                <small class="text-muted">
                <%# ***** small：補足テキスト要素 ***** %>
                  投稿者: <%= link_to post.user.name, user_path(post.user) %>
                </small>
                <%# ***** </small>：smallタグ（補足テキスト要素）の終了 ***** %>
                <small class="text-muted">
                <%# ***** small：補足テキスト要素 ***** %>
                  <%= post.created_at.strftime('%Y年%m月%d日') %>
                </small>
                <%# ***** </small>：smallタグ（補足テキスト要素）の終了 ***** %>
              </div>
              <%# ***** </div>：divタグ（汎用コンテナ要素）の終了 ***** %>
            </div>
            <%# ***** </div>：divタグ（汎用コンテナ要素）の終了 ***** %>
          </div>
          <%# ***** </div>：divタグ（汎用コンテナ要素）の終了 ***** %>
        <% end %>
      <% else %>
      <%# ***** else：上記条件に当てはまらない場合の分岐 ***** %>
        <p class="text-muted">まだ投稿がありません。</p>
        <%# ***** p：段落要素 ***** %>
      <% end %>
    </div>
    <%# ***** </div>：divタグ（汎用コンテナ要素）の終了 ***** %>

    <div class="col-md-4">
    <%# ***** div：汎用コンテナ要素 ***** %>
      <div class="card">
      <%# ***** div：汎用コンテナ要素 ***** %>
        <div class="card-header">
        <%# ***** div：汎用コンテナ要素 ***** %>
          <h5>メンバー一覧</h5>
          <%# ***** h5：見出し要素 ***** %>
        </div>
        <%# ***** </div>：divタグ（汎用コンテナ要素）の終了 ***** %>
        <div class="card-body">
        <%# ***** div：汎用コンテナ要素 ***** %>
          <% if @group.users.any? %>
          <%# ***** if：条件を判定する分岐 ***** %>
            <ul class="list-unstyled">
            <%# ***** ul：順序なしリスト要素 ***** %>
              <% @group.users.each do |user| %>
              <%# ***** each：コレクションを順に処理するループ ***** %>
                <li class="mb-2">
                <%# ***** li：リスト項目要素 ***** %>
                  <%= link_to user.name, user_path(user) %>
                </li>
                <%# ***** </li>：liタグ（リスト項目要素）の終了 ***** %>
              <% end %>
            </ul>
            <%# ***** </ul>：ulタグ（順序なしリスト要素）の終了 ***** %>
          <% else %>
          <%# ***** else：上記条件に当てはまらない場合の分岐 ***** %>
            <p class="text-muted">メンバーはまだいません。</p>
            <%# ***** p：段落要素 ***** %>
          <% end %>
        </div>
        <%# ***** </div>：divタグ（汎用コンテナ要素）の終了 ***** %>
      </div>
      <%# ***** </div>：divタグ（汎用コンテナ要素）の終了 ***** %>
    </div>
    <%# ***** </div>：divタグ（汎用コンテナ要素）の終了 ***** %>
  </div>
  <%# ***** </div>：divタグ（汎用コンテナ要素）の終了 ***** %>

  <div class="mt-4">
  <%# ***** div：汎用コンテナ要素 ***** %>
    <%= link_to '戻る', groups_path, class: 'btn btn-secondary' %>
  </div>
  <%# ***** </div>：divタグ（汎用コンテナ要素）の終了 ***** %>
</div>
<%# ***** </div>：divタグ（汎用コンテナ要素）の終了 ***** %>
