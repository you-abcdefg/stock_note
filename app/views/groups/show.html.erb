<%# ***** groups/show のビュー ***** %>
<div class="container mt-4">
<%# ***** 「<div>」：汎用コンテナ要素 ***** %>
<%# ***** 「class ="【クラス名】"」：要素へスタイルを適用するクラス属性 ***** %>
  <div class="row">
  <%# ***** 「<div>」：汎用コンテナ要素 ***** %>
  <%# ***** 「class ="【クラス名】"」：要素へスタイルを適用するクラス属性 ***** %>
    <div class="col-md-8">
    <%# ***** 「<div>」：汎用コンテナ要素 ***** %>
    <%# ***** 「class ="【クラス名】"」：要素へスタイルを適用するクラス属性 ***** %>
      <h1><%= @group.name %></h1>
      <%# ***** 「<h1>【内容】</h1>」：見出し要素 ***** %>
      <p class="lead"><%= @group.description %></p>
      <%# ***** 「<p>【内容】</p>」：段落要素 ***** %>
      <%# ***** 「class ="【クラス名】"」：要素へスタイルを適用するクラス属性 ***** %>

      <div class="mb-3">
      <%# ***** 「<div>」：汎用コンテナ要素 ***** %>
      <%# ***** 「class ="【クラス名】"」：要素へスタイルを適用するクラス属性 ***** %>
        <span class="badge badge-info">投稿数: <%= @group.posts.count %>件</span>
        <%# ***** 「<span>【内容】</span>」：インライン要素 ***** %>
        <%# ***** 「class ="【クラス名】"」：要素へスタイルを適用するクラス属性 ***** %>
        <span class="badge badge-success">メンバー: <%= @group.users.count %>人</span>
        <%# ***** 「<span>【内容】</span>」：インライン要素 ***** %>
        <%# ***** 「class ="【クラス名】"」：要素へスタイルを適用するクラス属性 ***** %>
      </div>
      <%# ***** 「<div>【内容】</div>」：要素をまとめるための汎用コンテナ ***** %>

      <div class="mb-4">
      <%# ***** 「<div>」：汎用コンテナ要素 ***** %>
      <%# ***** 条件分岐セクション ***** %>
      <%# ***** 「class ="【クラス名】"」：要素へスタイルを適用するクラス属性 ***** %>
        <%# ***** ログインしている場合の処理 ***** %>
        <% if user_signed_in? %>
        <%# ***** 「if 【条件式】」：【条件式】が true の場合、以下の処理を実行する ***** %>
        <%# ***** 「user_signed_in?」：Deviseで定義されたログイン状態判定ヘルパー関数 ***** %>
        <%# ***** 「if 【条件式】」：【条件式】が true の場合、以下の処理を実行する ***** %>
        <%# ***** 「user_signed_in?」：Deviseのログイン状態を判定するヘルパーメソッド（true / false を返す） ***** %>
          <% if current_user.group_memberships.exists?(group: @group) %>
          <%# ***** 「if 【条件式】」：【条件式】が true の場合、以下の処理を実行する ***** %>
            <%= link_to 'グループから退出', leave_group_path(@group), method: :delete, class: 'btn btn-secondary' %>
            <%# ***** 「link_to 'グループから退出', leave_group_path(@group), method: :delete, class: 'btn btn-secondary'」：画面へ値を出力する式 ***** %>
          <% else %>
          <%# ***** 「else」：上記条件に当てはまらない場合の分岐 ***** %>
            <%= link_to 'グループに参加', join_group_path(@group), method: :post, class: 'btn btn-primary' %>
            <%# ***** 「link_to 'グループに参加', join_group_path(@group), method: :post, class: 'btn btn-primary'」：画面へ値を出力する式 ***** %>
          <% end %>
          <%# ***** 「end」：ブロック処理を終了するキーワード ***** %>
        <% end %>
        <%# ***** 「end」：ブロック処理を終了するキーワード ***** %>
        <% if current_user&.admin? %>
        <%# ***** 「if 【条件式】」：【条件式】が true の場合、以下の処理を実行する ***** %>
          <%= link_to '編集', edit_group_path(@group), class: 'btn btn-warning' %>
          <%# ***** 「link_to '編集', edit_group_path(@group), class: 'btn btn-warning'」：画面へ値を出力する式 ***** %>
          <%= link_to '削除', group_path(@group), method: :delete, data: { confirm: '本当に削除しますか？' }, class: 'btn btn-danger' %>
          <%# ***** 「link_to '削除', group_path(@group), method: :delete, data: { confirm: '本当に削除しますか？' }, class: 'btn btn-danger'」：画面へ値を出力する式 ***** %>
        <% end %>
        <%# ***** 「end」：ブロック処理を終了するキーワード ***** %>
      </div>
      <%# ***** 「<div>【内容】</div>」：要素をまとめるための汎用コンテナ ***** %>

      <h3 class="mt-4">このグループの投稿</h3>
      <%# ***** 「<h3>【内容】</h3>」：見出し要素 ***** %>
      <%# ***** 「class ="【クラス名】"」：要素へスタイルを適用するクラス属性 ***** %>
      <% if @group.posts.published.any? %>
      <%# ***** 「if 【条件式】」：【条件式】が true の場合、以下の処理を実行する ***** %>
      <%# ***** 一覧ループセクション ***** %>
        <% @group.posts.published.order(created_at: :desc).each do |post| %>
        <%# ***** 「@group.posts.published.order(created_at: :desc).each do |post|」：Ruby式を実行する処理 ***** %>
        <%# ***** 「each do |post|」: コレクションを順番に処理し、|post| で現在要素を受け取る反復構文 ***** %>
        <%# ***** 「@group.posts.published.order(created_at: :desc)」：処理対象となるコレクション ***** %>
        <%# ***** 「|post|」：各反復で取り出した要素を受け取るブロック引数 ***** %>
        <%# ***** 「each」：コレクションを順に処理するループ ***** %>
          <div class="card mb-3">
          <%# ***** 「<div>」：汎用コンテナ要素 ***** %>
          <%# ***** 「class ="【クラス名】"」：要素へスタイルを適用するクラス属性 ***** %>
            <div class="card-body">
            <%# ***** 「<div>」：汎用コンテナ要素 ***** %>
            <%# ***** 「class ="【クラス名】"」：要素へスタイルを適用するクラス属性 ***** %>
              <h5 class="card-title">
              <%# ***** 「<h5>」：見出し要素 ***** %>
              <%# ***** 「class ="【クラス名】"」：要素へスタイルを適用するクラス属性 ***** %>
                <%= link_to post.title, post_path(post) %>
                <%# ***** 「link_to post.title, post_path(post)」：画面へ値を出力する式 ***** %>
              </h5>
              <%# ***** 「<h5>【内容】</h5>」：見出し要素 ***** %>
              <p class="card-text"><%= truncate(post.body, length: 150) %></p>
              <%# ***** 「<p>【内容】</p>」：段落要素 ***** %>
              <%# ***** 「class ="【クラス名】"」：要素へスタイルを適用するクラス属性 ***** %>
              <div class="d-flex justify-content-between">
              <%# ***** 「<div>」：汎用コンテナ要素 ***** %>
              <%# ***** 「class ="【クラス名】"」：要素へスタイルを適用するクラス属性 ***** %>
                <small class="text-muted">
                <%# ***** 「<small>」：補足テキスト要素 ***** %>
                <%# ***** 「class ="【クラス名】"」：要素へスタイルを適用するクラス属性 ***** %>
                  投稿者: <%= link_to post.user.name, user_path(post.user) %>
                </small>
                <%# ***** 「<small>【内容】</small>」：補足テキスト要素 ***** %>
                <small class="text-muted">
                <%# ***** 「<small>」：補足テキスト要素 ***** %>
                <%# ***** 「class ="【クラス名】"」：要素へスタイルを適用するクラス属性 ***** %>
                  <%= post.created_at.strftime('%Y年%m月%d日') %>
                  <%# ***** 「post.created_at.strftime('%Y年%m月%d日')」：画面へ値を出力する式 ***** %>
                </small>
                <%# ***** 「<small>【内容】</small>」：補足テキスト要素 ***** %>
              </div>
              <%# ***** 「<div>【内容】</div>」：要素をまとめるための汎用コンテナ ***** %>
            </div>
            <%# ***** 「<div>【内容】</div>」：要素をまとめるための汎用コンテナ ***** %>
          </div>
          <%# ***** 「<div>【内容】</div>」：要素をまとめるための汎用コンテナ ***** %>
        <% end %>
        <%# ***** 「end」：ブロック処理を終了するキーワード ***** %>
      <% else %>
      <%# ***** 「else」：上記条件に当てはまらない場合の分岐 ***** %>
        <p class="text-muted">まだ投稿がありません。</p>
        <%# ***** 「<p>【内容】</p>」：段落要素 ***** %>
        <%# ***** 「class ="【クラス名】"」：要素へスタイルを適用するクラス属性 ***** %>
      <% end %>
      <%# ***** 「end」：ブロック処理を終了するキーワード ***** %>
    </div>
    <%# ***** 「<div>【内容】</div>」：要素をまとめるための汎用コンテナ ***** %>

    <div class="col-md-4">
    <%# ***** 「<div>」：汎用コンテナ要素 ***** %>
    <%# ***** 「class ="【クラス名】"」：要素へスタイルを適用するクラス属性 ***** %>
      <div class="card">
      <%# ***** 「<div>」：汎用コンテナ要素 ***** %>
      <%# ***** 「class ="【クラス名】"」：要素へスタイルを適用するクラス属性 ***** %>
        <div class="card-header">
        <%# ***** 「<div>」：汎用コンテナ要素 ***** %>
        <%# ***** 「class ="【クラス名】"」：要素へスタイルを適用するクラス属性 ***** %>
          <h5>メンバー一覧</h5>
          <%# ***** 「<h5>【内容】</h5>」：見出し要素 ***** %>
        </div>
        <%# ***** 「<div>【内容】</div>」：要素をまとめるための汎用コンテナ ***** %>
        <div class="card-body">
        <%# ***** 「<div>」：汎用コンテナ要素 ***** %>
        <%# ***** 「class ="【クラス名】"」：要素へスタイルを適用するクラス属性 ***** %>
          <% if @group.users.any? %>
          <%# ***** 「if 【条件式】」：【条件式】が true の場合、以下の処理を実行する ***** %>
            <ul class="list-unstyled">
            <%# ***** 「<ul>」：順序なしリスト要素 ***** %>
            <%# ***** 「class ="【クラス名】"」：要素へスタイルを適用するクラス属性 ***** %>
              <% @group.users.each do |user| %>
              <%# ***** 「@group.users.each do |user|」：Ruby式を実行する処理 ***** %>
              <%# ***** 「each do |user|」: コレクションを順番に処理し、|user| で現在要素を受け取る反復構文 ***** %>
              <%# ***** 「@group.users」：処理対象となるコレクション ***** %>
              <%# ***** 「|user|」：各反復で取り出した要素を受け取るブロック引数 ***** %>
              <%# ***** 「each」：コレクションを順に処理するループ ***** %>
                <li class="mb-2">
                <%# ***** 「<li>」：リスト項目要素 ***** %>
                <%# ***** 「class ="【クラス名】"」：要素へスタイルを適用するクラス属性 ***** %>
                  <%= link_to user.name, user_path(user) %>
                  <%# ***** 「link_to user.name, user_path(user)」：画面へ値を出力する式 ***** %>
                </li>
                <%# ***** 「<li>【内容】</li>」：リスト項目要素 ***** %>
              <% end %>
              <%# ***** 「end」：ブロック処理を終了するキーワード ***** %>
            </ul>
            <%# ***** 「<ul>【内容】</ul>」：順序なしリスト要素 ***** %>
          <% else %>
          <%# ***** 「else」：上記条件に当てはまらない場合の分岐 ***** %>
            <p class="text-muted">メンバーはまだいません。</p>
            <%# ***** 「<p>【内容】</p>」：段落要素 ***** %>
            <%# ***** 「class ="【クラス名】"」：要素へスタイルを適用するクラス属性 ***** %>
          <% end %>
          <%# ***** 「end」：ブロック処理を終了するキーワード ***** %>
        </div>
        <%# ***** 「<div>【内容】</div>」：要素をまとめるための汎用コンテナ ***** %>
      </div>
      <%# ***** 「<div>【内容】</div>」：要素をまとめるための汎用コンテナ ***** %>
    </div>
    <%# ***** 「<div>【内容】</div>」：要素をまとめるための汎用コンテナ ***** %>
  </div>
  <%# ***** 「<div>【内容】</div>」：要素をまとめるための汎用コンテナ ***** %>

  <div class="mt-4">
  <%# ***** 「<div>」：汎用コンテナ要素 ***** %>
  <%# ***** 「class ="【クラス名】"」：要素へスタイルを適用するクラス属性 ***** %>
    <%= link_to '戻る', groups_path, class: 'btn btn-secondary' %>
    <%# ***** 「link_to '戻る', groups_path, class: 'btn btn-secondary'」：画面へ値を出力する式 ***** %>
  </div>
  <%# ***** 「<div>【内容】</div>」：要素をまとめるための汎用コンテナ ***** %>
</div>
<%# ***** 「<div>【内容】</div>」：要素をまとめるための汎用コンテナ ***** %>
