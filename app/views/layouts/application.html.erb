<%# ***** layouts/application.html.erb - アプリ全体のレイアウト ***** %>
<%# ***** 【このファイルの役割】 ***** %>
<%# ***** すべてのページで共通のヘッダー・フッター・ナビゲーションを定義 ***** %>
<%# ***** Bootstrap 4 と Font Awesome を使用したレスポンシブデザイン ***** %>

<!DOCTYPE html>
<%# ***** 「!DOCTYPE html」：HTML5文書型宣言 ***** %>
<html>
<%# ***** 「<html>」：HTMLドキュメント全体 ***** %>
  <head>
  <%# ***** 「<head>」：ヘッダー情報セクション ***** %>
    <title>Stock Note</title>
    <%# ***** 「<title>【内容】</title>」：文書タイトル要素 ***** %>
    <%# ***** スマホ対応のためのviewport設定 ***** %>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <%# ***** 「<meta>」：メタ情報要素 ***** %>
    <%# ***** セキュリティ設定（CSRF対策） ***** %>
    <%# ***** 「name ="【名前】"」：フォーム送信時のパラメータ名を指定する属性 ***** %>
    <%# ***** 「content ="【内容】"」：メタ情報の内容を指定する属性 ***** %>
    <%= csrf_meta_tags %>
    <%# ***** 「csrf_meta_tags」：画面へ値を出力する式 ***** %>
    <%= csp_meta_tag %>
    <%# ***** 「csp_meta_tag」：画面へ値を出力する式 ***** %>
    <%# ***** スタイルシート読み込み ***** %>
    <%= stylesheet_link_tag 'application', media: 'all', 'data-turbolinks-track': 'reload' %>
    <%# ***** 「stylesheet_link_tag 'application', media: 'all', 'data-turbolinks-track': 'reload'」：画面へ値を出力する式 ***** %>
    <%# ***** JavaScript読み込み ***** %>
    <%= javascript_pack_tag 'application', 'data-turbolinks-track': 'reload' %>
    <%# ***** 「javascript_pack_tag 'application', 'data-turbolinks-track': 'reload'」：画面へ値を出力する式 ***** %>
    <%# ***** Font Awesome（アイコン）とBootstrap（CSSフレームワーク）をCDNから読み込み ***** %>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
    <%# ***** 「<link>」：link要素 ***** %>
    <%# ***** 「rel ="【関係】"」：リンク先との関係を示す属性 ***** %>
    <%# ***** 「href ="【URL】"」：リンク先URLを指定する属性 ***** %>
    <link rel="stylesheet" href="https://stackpath.bootstrapcdn.com/bootstrap/4.5.2/css/bootstrap.min.css">
    <%# ***** 「<link>」：外部リソース参照要素 ***** %>
    <%# ***** 「rel ="【関係】"」：リンク先との関係を示す属性 ***** %>
    <%# ***** 「href ="【URL】"」：リンク先URLを指定する属性 ***** %>
  </head>
  <%# ***** 「</head>」：headタグ（ヘッダー情報セクション）の終了 ***** %>

  <body>
  <%# ***** 「<body>」：文書本文要素 ***** %>
  <%# ***** ヘッダー：ナビゲーションバー ***** %>
