      <div class="container mt-4">
      <%# ***** 「<div>」：汎用コンテナ要素 ***** %>
      <%# ***** 成功メッセージ表示（notice） ***** %>
      <%# ***** 「class ="【クラス名】"」：要素へスタイルを適用するクラス属性 ***** %>
        <% if notice %>
        <%# ***** 「if notice」：Ruby式を実行する処理 ***** %>
        <%# ***** 「if (notice)」: noticeを判定する条件分岐 ***** %>
        <%# ***** 「if」：条件を判定する分岐 ***** %>
          <div class="alert alert-success alert-dismissible fade show" role="alert">
          <%# ***** 「<div>」：汎用コンテナ要素 ***** %>
