          <%# ***** 「role ="【ロール】"」：要素の役割を示す属性 ***** %>
            <%= notice %>
            <%# ***** 「notice」：画面へ値を出力する式 ***** %>
            <button type="button" class="close" data-dismiss="alert" aria-label="Close">
            <%# ***** 「<button>」：ボタン要素 ***** %>
            <%# ***** 「type ="【種別】"」：要素や入力値の種類を指定する属性 ***** %>
            <%# ***** 「class ="【クラス名】"」：要素へスタイルを適用するクラス属性 ***** %>
            <%# ***** 「data-dismiss ="【値】"」：JavaScript連携に使うカスタムデータ属性 ***** %>
            <%# ***** 「aria-label ="【ラベル】"」：支援技術向けの要素ラベルを指定する属性 ***** %>
              <span aria-hidden="true">&times;</span>
              <%# ***** 「<span>【内容】</span>」：インライン要素 ***** %>
            </button>
            <%# ***** 「</button>」：buttonタグ（ボタン要素）の終了 ***** %>
          </div>
          <%# ***** 「</div>」：divタグ（汎用コンテナ要素）の終了 ***** %>
        <% end %>
        <%# ***** 「end」：Ruby式を実行する処理 ***** %>
        <%# ***** エラーメッセージ表示（alert） ***** %>
        <% if alert %>
        <%# ***** 「if alert」：Ruby式を実行する処理 ***** %>
        <%# ***** 「if (alert)」: alertを判定する条件分岐 ***** %>
        <%# ***** 「if」：条件を判定する分岐 ***** %>
          <div class="alert alert-danger alert-dismissible fade show" role="alert">
          <%# ***** 「<div>」：汎用コンテナ要素 ***** %>
          <%# ***** 「class ="【クラス名】"」：要素へスタイルを適用するクラス属性 ***** %>
          <%# ***** 「role ="【ロール】"」：要素の役割を示す属性 ***** %>
            <%= alert %>
            <%# ***** 「alert」：画面へ値を出力する式 ***** %>
            <button type="button" class="close" data-dismiss="alert" aria-label="Close">
            <%# ***** 「<button>」：ボタン要素 ***** %>
            <%# ***** 「type ="【種別】"」：要素や入力値の種類を指定する属性 ***** %>
            <%# ***** 「class ="【クラス名】"」：要素へスタイルを適用するクラス属性 ***** %>
            <%# ***** 「data-dismiss ="【値】"」：JavaScript連携に使うカスタムデータ属性 ***** %>
            <%# ***** 「aria-label ="【ラベル】"」：支援技術向けの要素ラベルを指定する属性 ***** %>
              <span aria-hidden="true">&times;</span>
              <%# ***** 「<span>【内容】</span>」：インライン要素 ***** %>
            </button>
            <%# ***** 「</button>」：buttonタグ（ボタン要素）の終了 ***** %>
          </div>
          <%# ***** 「</div>」：divタグ（汎用コンテナ要素）の終了 ***** %>
        <% end %>
        <%# ***** 「end」：ブロック処理を終了するキーワード ***** %>
      </div>
      <%# ***** 「</div>」：divタグ（汎用コンテナ要素）の終了 ***** %>
      <%# ***** 各ページのコンテンツがここに表示される ***** %>
      <%= yield %>
      <%# ***** 「yield」：画面へ値を出力する式 ***** %>
    </main>

    <%# ***** 「</main>」：mainタグ（メイン要素）の終了 ***** %>
    <%# ***** フッター ***** %>
    <footer class="border-top mt-5 pt-5">
    <%# ***** 「<footer>」：フッター要素 ***** %>
    <%# ***** 「class ="【クラス名】"」：要素へスタイルを適用するクラス属性 ***** %>
      <div class="container mb-5">
      <%# ***** 「<div>」：汎用コンテナ要素 ***** %>
      <%# ***** 「class ="【クラス名】"」：要素へスタイルを適用するクラス属性 ***** %>
        <div class="row">
        <%# ***** 「<div>」：汎用コンテナ要素 ***** %>
        <%# ***** 「class ="【クラス名】"」：要素へスタイルを適用するクラス属性 ***** %>
          <div class="mx-auto">
          <%# ***** 「<div>」：汎用コンテナ要素 ***** %>
          <%# ***** 「class ="【クラス名】"」：要素へスタイルを適用するクラス属性 ***** %>
            <p class="text-center">© 2026 Stock Note All rights reserved.</p>
            <%# ***** 「<p>【内容】</p>」：段落要素 ***** %>
          </div>
          <%# ***** 「</div>」：divタグ（汎用コンテナ要素）の終了 ***** %>
        </div>
        <%# ***** 「</div>」：divタグ（汎用コンテナ要素）の終了 ***** %>
      </div>
      <%# ***** 「</div>」：divタグ（汎用コンテナ要素）の終了 ***** %>
      <%# ***** 「</div>」：divタグ（汎用コンテナ要素）の終了 ***** %>
    </footer>

    <%# ***** 「</footer>」：footerタグ（フッター要素）の終了 ***** %>
    <%# ***** jQuery と Bootstrap の JavaScript を CDN から読み込み ***** %>
    <script src="https://code.jquery.com/jquery-3.5.1.slim.min.js"></script>
    <%# ***** 「<script>【内容】</script>」：スクリプト要素 ***** %>
    <%# ***** スクリプトセクション ***** %>
    <script src="https://cdn.jsdelivr.net/npm/popper.js@1.16.1/dist/umd/popper.min.js"></script>
    <%# ***** 「<script>【内容】</script>」：スクリプト要素 ***** %>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@4.5.2/dist/js/bootstrap.min.js"></script>
    <%# ***** 「<script>【内容】</script>」：スクリプト要素 ***** %>

    <%# ***** ナビゲーションメニューのクリックで自動折りたたみ ***** %>
    <script>
    <%# ***** 「<script>」：スクリプト要素 ***** %>
      // Bootstrapのネイティブcollapse機能を活用
      document.addEventListener('DOMContentLoaded', function() {
        // メニューリンククリック時に自動で閉じる処理のみ実装
        // ハンバーガーボタンの開閉はBootstrapのdata-toggle="collapse"に任せる
        document.querySelectorAll('.navbar-nav .nav-link').forEach(link => {
          link.addEventListener('click', function() {
            const navbarCollapse = document.querySelector('.navbar-collapse');
            // Bootstrapのcollapseメソッドを使用してメニューを閉じる
            if (navbarCollapse.classList.contains('show')) {
              $(navbarCollapse).collapse('hide');
            }
          });
        });
      });
    </script>
    <%# ***** 「</script>」：scriptタグ（スクリプト要素）の終了 ***** %>
  </body>
  <%# ***** 「</body>」：bodyタグ（本文セクション）の終了 ***** %>
