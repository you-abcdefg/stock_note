    <%# ***** 「<header>」：ヘッダー要素 ***** %>
      <nav class="navbar navbar-expand-lg navbar-dark bg-dark">
      <%# ***** 「<nav>」：ナビゲーション要素 ***** %>
      <%# ***** 「class ="【クラス名】"」：要素へスタイルを適用するクラス属性 ***** %>
        <div class="container">
        <%# ***** 「<div>」：汎用コンテナ要素 ***** %>
        <%# ***** サイトロゴ（リンクなし） ***** %>
        <%# ***** 「class ="【クラス名】"」：要素へスタイルを適用するクラス属性 ***** %>
