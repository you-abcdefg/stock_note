          <%# ***** 「<span>【内容】</span>」：インライン要素 ***** %>
          <%# ***** スマホ用ハンバーガーメニューボタン ***** %>
          <button class="navbar-toggler" type="button" data-toggle="collapse" data-target="#navbarNav" aria-controls="navbarNav" aria-expanded="false" aria-label="Toggle navigation">
          <%# ***** 「<button>」：ボタン要素 ***** %>
          <%# ***** 「class ="【クラス名】"」：要素へスタイルを適用するクラス属性 ***** %>
          <%# ***** 「type ="【種別】"」：要素や入力値の種類を指定する属性 ***** %>
          <%# ***** 「data-toggle ="【動作種別】"」：JavaScript動作用のデータ属性 ***** %>
          <%# ***** 「data-target ="【対象セレクタ】"」：JavaScript動作対象を指定するデータ属性 ***** %>
          <%# ***** 「aria-controls ="【制御対象ID】"」：制御対象要素を指定する属性 ***** %>
          <%# ***** 「aria-expanded ="【展開状態】"」：展開状態を示す属性 ***** %>
          <%# ***** 「aria-label ="【ラベル】"」：支援技術向けの要素ラベルを指定する属性 ***** %>
            <span class="navbar-toggler-icon"></span>
            <%# ***** 「<span>【内容】</span>」：インライン要素 ***** %>
          </button>

          <%# ***** 「</button>」：buttonタグ（ボタン要素）の終了 ***** %>
          <%# ***** ナビゲーションメニュー ***** %>
