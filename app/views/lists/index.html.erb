<%# ***** lists/index のビュー ***** %>
<div class="container mt-4">
<%# ***** 「<div>」：汎用コンテナ要素 ***** %>
<%# ***** 「class ="【クラス名】"」：要素へスタイルを適用するクラス属性 ***** %>
  <div class="d-flex justify-content-between align-items-center mb-3">
  <%# ***** 「<div>」：汎用コンテナ要素 ***** %>
  <%# ***** 「class ="【クラス名】"」：要素へスタイルを適用するクラス属性 ***** %>
    <h2 class="mb-0">リスト一覧</h2>
    <%# ***** 「<h2>【内容】</h2>」：見出し要素 ***** %>
    <%# ***** 条件分岐セクション ***** %>
    <%# ***** 「class ="【クラス名】"」：要素へスタイルを適用するクラス属性 ***** %>
    <% if user_signed_in? %>
    <%# ***** 「if user_signed_in?」：Ruby式を実行する処理 ***** %>
    <%# ***** 「if (user_signed_in?)」: user_signed_in?を判定する条件分岐 ***** %>
    <%# ***** 「user_signed_in?」：Deviseで定義されたログイン状態判定ヘルパー関数 ***** %>
    <%# ***** 「if」：条件を判定する分岐 ***** %>
    <%# ***** 「user_signed_in?」：Deviseのログイン状態を判定するヘルパーメソッド（true / false を返す） ***** %>
      <%= link_to 'リスト作成', new_list_path, class: 'btn btn-primary btn-sm' %>
      <%# ***** 「link_to 'リスト作成', new_list_path, class: 'btn btn-primary btn-sm'」：画面へ値を出力する式 ***** %>
    <% end %>
    <%# ***** 「end」：ブロック処理を終了するキーワード ***** %>
  </div>
  <%# ***** 「</div>」：divタグ（汎用コンテナ要素）の終了 ***** %>

  <% if @lists.any? %>
  <%# ***** 「if @lists.any?」：Ruby式を実行する処理 ***** %>
  <%# ***** 「if (@lists.any?)」: @lists.any?を判定する条件分岐 ***** %>
  <%# ***** 「if」：条件を判定する分岐 ***** %>
    <div class="row">
    <%# ***** 「<div>」：汎用コンテナ要素 ***** %>
    <%# ***** 一覧ループセクション ***** %>
    <%# ***** 「class ="【クラス名】"」：要素へスタイルを適用するクラス属性 ***** %>
      <% @lists.each do |list| %>
      <%# ***** 「@lists.each do |list|」：Ruby式を実行する処理 ***** %>
      <%# ***** 「each do |list|」: コレクションを順番に処理し、|list| で現在要素を受け取る反復構文 ***** %>
      <%# ***** 「@lists」：処理対象となるコレクション ***** %>
      <%# ***** 「|list|」：各反復で取り出した要素を受け取るブロック引数 ***** %>
      <%# ***** 「each」：コレクションを順に処理するループ ***** %>
        <div class="col-md-6 mb-3">
        <%# ***** 「<div>」：汎用コンテナ要素 ***** %>
        <%# ***** 「class ="【クラス名】"」：要素へスタイルを適用するクラス属性 ***** %>
          <div class="card h-100">
          <%# ***** 「<div>」：汎用コンテナ要素 ***** %>
          <%# ***** 「class ="【クラス名】"」：要素へスタイルを適用するクラス属性 ***** %>
            <div class="card-body">
            <%# ***** 「<div>」：汎用コンテナ要素 ***** %>
            <%# ***** 「class ="【クラス名】"」：要素へスタイルを適用するクラス属性 ***** %>
              <h5 class="card-title">
              <%# ***** 「<h5>」：見出し要素 ***** %>
              <%# ***** 「class ="【クラス名】"」：要素へスタイルを適用するクラス属性 ***** %>
                <%= link_to list.title, list_path(list) %>
                <%# ***** 「link_to list.title, list_path(list)」：画面へ値を出力する式 ***** %>
              </h5>
              <%# ***** 「</h5>」：h5タグ（見出し要素）の終了 ***** %>
              <p class="mb-2 text-muted"><%= truncate(list.description, length: 100) %></p>
              <%# ***** 「<p>【内容】</p>」：段落要素 ***** %>
              <%# ***** 「class ="【クラス名】"」：要素へスタイルを適用するクラス属性 ***** %>
              <div>
              <%# ***** 「<div>」：汎用コンテナ要素 ***** %>
                <span class="badge <%= list.public_list? ? 'badge-success' : 'badge-secondary' %>">
                <%# ***** 「<span>【内容】</span>」：インライン要素 ***** %>
                  <%= list.public_list? ? '全体公開' : '非公開' %>
                  <%# ***** 「list.public_list? ? '全体公開' : '非公開'」：画面へ値を出力する式 ***** %>
                </span>
                <%# ***** 「</span>」：spanタグ（インライン要素）の終了 ***** %>
                <span class="ml-2 text-muted small">作成者: <%= list.user.name.presence || list.user.email %></span>
                <%# ***** 「<span>【内容】</span>」：インライン要素 ***** %>
                <%# ***** 「class ="【クラス名】"」：要素へスタイルを適用するクラス属性 ***** %>
              </div>
              <%# ***** 「</div>」：divタグ（汎用コンテナ要素）の終了 ***** %>
            </div>
            <%# ***** 「</div>」：divタグ（汎用コンテナ要素）の終了 ***** %>
          </div>
          <%# ***** 「</div>」：divタグ（汎用コンテナ要素）の終了 ***** %>
        </div>
        <%# ***** 「</div>」：divタグ（汎用コンテナ要素）の終了 ***** %>
      <% end %>
      <%# ***** 「end」：ブロック処理を終了するキーワード ***** %>
    </div>
    <%# ***** 「</div>」：divタグ（汎用コンテナ要素）の終了 ***** %>
  <% else %>
  <%# ***** 「else」：上記条件に当てはまらない場合の分岐 ***** %>
    <div class="alert alert-info">表示できるリストがありません。</div>
    <%# ***** 「<div>【内容】</div>」：汎用コンテナ要素 ***** %>
    <%# ***** 「class ="【クラス名】"」：要素へスタイルを適用するクラス属性 ***** %>
  <% end %>
  <%# ***** 「end」：ブロック処理を終了するキーワード ***** %>
</div>
<%# ***** 「</div>」：divタグ（汎用コンテナ要素）の終了 ***** %>
