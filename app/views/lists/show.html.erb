<%# ***** lists/show のビュー ***** %>
<div class="container mt-4">
<%# ***** div：汎用コンテナ要素 ***** %>
  <div class="d-flex justify-content-between align-items-start mb-3">
  <%# ***** div：汎用コンテナ要素 ***** %>
    <div>
    <%# ***** div：汎用コンテナ要素 ***** %>
      <h2 class="mb-1"><%= @list.title %></h2>
      <%# ***** h2：見出し要素 ***** %>
      <p class="text-muted mb-2"><%= simple_format(@list.description) %></p>
      <%# ***** p：段落要素 ***** %>
      <span class="badge <%= @list.public_list? ? 'badge-success' : 'badge-secondary' %>">
      <%# ***** span：インライン要素 ***** %>
        <%= @list.public_list? ? '全体公開' : '非公開' %>
      </span>
      <%# ***** </span>：spanタグ（インライン要素）の終了 ***** %>
      <span class="ml-2 text-muted small">作成者: <%= @list.user.name.presence || @list.user.email %></span>
      <%# ***** span：インライン要素 ***** %>
    </div>
    <%# ***** </div>：divタグ（汎用コンテナ要素）の終了 ***** %>
    <div>
  <%# ***** 条件分岐セクション ***** %>
      <% if @list.owner?(current_user) %>
      <%# ***** if：条件を判定する分岐 ***** %>
        <%= link_to '編集', edit_list_path(@list), class: 'btn btn-sm btn-outline-primary' %>
        <%= link_to '削除', list_path(@list), method: :delete, data: { confirm: 'リストを削除しますか？' }, class: 'btn btn-sm btn-outline-danger' %>
      <% end %>
      <%= link_to '一覧へ戻る', lists_path, class: 'btn btn-sm btn-outline-secondary' %>
    </div>
    <%# ***** </div>：divタグ（汎用コンテナ要素）の終了 ***** %>
  </div>
  <%# ***** </div>：divタグ（汎用コンテナ要素）の終了 ***** %>

  <div class="card mb-4">
  <%# ***** div：汎用コンテナ要素 ***** %>
    <div class="card-header">リスト内の投稿</div>
    <%# ***** div：汎用コンテナ要素 ***** %>
    <div class="card-body">
    <%# ***** div：汎用コンテナ要素 ***** %>
      <% if @list_items.any? %>
      <%# ***** if：条件を判定する分岐 ***** %>
        <ul class="list-group list-group-flush">
        <%# ***** ul：順序なしリスト要素 ***** %>
          <% @list_items.each_with_index do |item, index| %>
            <li class="list-group-item">
            <%# ***** li：リスト項目要素 ***** %>
              <div class="d-flex justify-content-between align-items-center">
              <%# ***** div：汎用コンテナ要素 ***** %>
                <div>
                <%# ***** div：汎用コンテナ要素 ***** %>
                <span class="text-muted mr-2"><%= item.position %>.</span>
                <%# ***** span：インライン要素 ***** %>
                <%= link_to item.post.title, post_path(item.post) %>
                </div>
                <%# ***** </div>：divタグ（汎用コンテナ要素）の終了 ***** %>
                <% if @list.owner?(current_user) %>
                <%# ***** if：条件を判定する分岐 ***** %>
                  <div class="d-flex">
                  <%# ***** div：汎用コンテナ要素 ***** %>
                    <%= button_to '↑', move_list_list_item_path(@list, item, direction: 'up'), method: :patch, class: 'btn btn-sm btn-outline-secondary mr-1', disabled: index.zero? %>
                    <%= button_to '↓', move_list_list_item_path(@list, item, direction: 'down'), method: :patch, class: 'btn btn-sm btn-outline-secondary mr-1', disabled: index == @list_items.size - 1 %>
                    <%= button_to '削除', list_list_item_path(@list, item), method: :delete, data: { confirm: 'リストから削除しますか？' }, class: 'btn btn-sm btn-outline-danger' %>
                  </div>
                  <%# ***** </div>：divタグ（汎用コンテナ要素）の終了 ***** %>
                <% end %>
              </div>
              <%# ***** </div>：divタグ（汎用コンテナ要素）の終了 ***** %>

              <% if @list.owner?(current_user) %>
<%# ***** 入力フォームセクション ***** %>
                <%= form_with model: [@list, item], local: true, class: 'mt-2' do |f| %>
                  <div class="form-group mb-2">
                  <%# ***** div：汎用コンテナ要素 ***** %>
                    <%= f.label :memo, '投稿メモ（1件）', class: 'small text-muted' %>
<%# ***** フォーム入力欄セクション ***** %>
                    <%= f.text_area :memo, rows: 2, class: 'form-control' %>
                  </div>
<%# ***** 送信ボタンセクション ***** %>
                  <%= f.submit 'メモ保存', class: 'btn btn-sm btn-outline-primary' %>
                <% end %>
              <% elsif item.memo.present? %>
              <%# ***** elsif：前条件が偽の場合の追加分岐 ***** %>
                <div class="mt-2 small text-muted">
                <%# ***** div：汎用コンテナ要素 ***** %>
                  <strong>投稿メモ:</strong> <%= simple_format(item.memo) %>
                  <%# ***** strong：強調テキスト要素 ***** %>
                </div>
                <%# ***** </div>：divタグ（汎用コンテナ要素）の終了 ***** %>
              <% end %>
            </li>
            <%# ***** </li>：liタグ（リスト項目要素）の終了 ***** %>
          <% end %>
        </ul>
        <%# ***** </ul>：ulタグ（順序なしリスト要素）の終了 ***** %>
      <% else %>
      <%# ***** else：上記条件に当てはまらない場合の分岐 ***** %>
        <p class="text-muted mb-0">投稿はまだ登録されていません。</p>
        <%# ***** p：段落要素 ***** %>
      <% end %>
    </div>
    <%# ***** </div>：divタグ（汎用コンテナ要素）の終了 ***** %>
  </div>
  <%# ***** </div>：divタグ（汎用コンテナ要素）の終了 ***** %>

</div>
<%# ***** </div>：divタグ（汎用コンテナ要素）の終了 ***** %>
