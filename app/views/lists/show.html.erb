<%# ***** lists/show のビュー ***** %>
<div class="container mt-4">
<%# ***** 「<div>」：汎用コンテナ要素 ***** %>
<%# ***** 「class ="【クラス名】"」：要素へスタイルを適用するクラス属性 ***** %>
  <div class="d-flex justify-content-between align-items-start mb-3">
  <%# ***** 「<div>」：汎用コンテナ要素 ***** %>
  <%# ***** 「class ="【クラス名】"」：要素へスタイルを適用するクラス属性 ***** %>
    <div>
    <%# ***** 「<div>」：汎用コンテナ要素 ***** %>
      <h2 class="mb-1"><%= @list.title %></h2>
      <%# ***** 「<h2>【内容】</h2>」：見出し要素 ***** %>
      <%# ***** 「class ="【クラス名】"」：要素へスタイルを適用するクラス属性 ***** %>
      <p class="text-muted mb-2"><%= simple_format(@list.description) %></p>
      <%# ***** 「<p>【内容】</p>」：段落要素 ***** %>
      <%# ***** 「class ="【クラス名】"」：要素へスタイルを適用するクラス属性 ***** %>
      <span class="badge <%= @list.public_list? ? 'badge-success' : 'badge-secondary' %>">
      <%# ***** 「<span>【内容】</span>」：インライン要素 ***** %>
        <%= @list.public_list? ? '全体公開' : '非公開' %>
        <%# ***** 「@list.public_list? ? '全体公開' : '非公開'」：画面へ値を出力する式 ***** %>
      </span>
      <%# ***** 「<span>【内容】</span>」：インライン要素 ***** %>
      <span class="ml-2 text-muted small">作成者: <%= @list.user.name.presence || @list.user.email %></span>
      <%# ***** 「<span>【内容】</span>」：インライン要素 ***** %>
      <%# ***** 「class ="【クラス名】"」：要素へスタイルを適用するクラス属性 ***** %>
    </div>
    <%# ***** 「<div>【内容】</div>」：要素をまとめるための汎用コンテナ ***** %>
    <div>
    <%# ***** 「<div>」：汎用コンテナ要素 ***** %>
    <%# ***** 条件分岐セクション ***** %>
      <% if @list.owner?(current_user) %>
      <%# ***** 「if 【条件式】」：【条件式】が true の場合、以下の処理を実行する ***** %>
        <%= link_to '編集', edit_list_path(@list), class: 'btn btn-sm btn-outline-primary' %>
        <%# ***** 「link_to '編集', edit_list_path(@list), class: 'btn btn-sm btn-outline-primary'」：画面へ値を出力する式 ***** %>
        <%= link_to '削除', list_path(@list), method: :delete, data: { confirm: 'リストを削除しますか？' }, class: 'btn btn-sm btn-outline-danger' %>
        <%# ***** 「link_to '削除', list_path(@list), method: :delete, data: { confirm: 'リストを削除しますか？' }, class: 'btn btn-sm btn-outline-danger'」：画面へ値を出力する式 ***** %>
      <% end %>
      <%# ***** 「end」：ブロック処理を終了するキーワード ***** %>
      <%= link_to '一覧へ戻る', lists_path, class: 'btn btn-sm btn-outline-secondary' %>
      <%# ***** 「link_to '一覧へ戻る', lists_path, class: 'btn btn-sm btn-outline-secondary'」：画面へ値を出力する式 ***** %>
    </div>
    <%# ***** 「<div>【内容】</div>」：要素をまとめるための汎用コンテナ ***** %>
  </div>
  <%# ***** 「<div>【内容】</div>」：要素をまとめるための汎用コンテナ ***** %>

  <div class="card mb-4">
  <%# ***** 「<div>」：汎用コンテナ要素 ***** %>
  <%# ***** 「class ="【クラス名】"」：要素へスタイルを適用するクラス属性 ***** %>
    <div class="card-header">リスト内の投稿</div>
    <%# ***** 「<div>【内容】</div>」：汎用コンテナ要素 ***** %>
    <%# ***** 「class ="【クラス名】"」：要素へスタイルを適用するクラス属性 ***** %>
    <div class="card-body">
    <%# ***** 「<div>」：汎用コンテナ要素 ***** %>
    <%# ***** 「class ="【クラス名】"」：要素へスタイルを適用するクラス属性 ***** %>
      <% if @list_items.any? %>
      <%# ***** 「if 【条件式】」：【条件式】が true の場合、以下の処理を実行する ***** %>
        <ul class="list-group list-group-flush">
        <%# ***** 「<ul>」：順序なしリスト要素 ***** %>
        <%# ***** 「class ="【クラス名】"」：要素へスタイルを適用するクラス属性 ***** %>
          <% @list_items.each_with_index do |item, index| %>
          <%# ***** 「@list_items.each_with_index do |item, index|」：Ruby式を実行する処理 ***** %>
            <li class="list-group-item">
            <%# ***** 「<li>」：リスト項目要素 ***** %>
            <%# ***** 「class ="【クラス名】"」：要素へスタイルを適用するクラス属性 ***** %>
              <div class="d-flex justify-content-between align-items-center">
              <%# ***** 「<div>」：汎用コンテナ要素 ***** %>
              <%# ***** 「class ="【クラス名】"」：要素へスタイルを適用するクラス属性 ***** %>
                <div>
                <%# ***** 「<div>」：汎用コンテナ要素 ***** %>
                <span class="text-muted mr-2"><%= item.position %>.</span>
                <%# ***** 「<span>【内容】</span>」：インライン要素 ***** %>
                <%# ***** 「class ="【クラス名】"」：要素へスタイルを適用するクラス属性 ***** %>
                <%= link_to item.post.title, post_path(item.post) %>
                <%# ***** 「link_to item.post.title, post_path(item.post)」：画面へ値を出力する式 ***** %>
                </div>
                <%# ***** 「<div>【内容】</div>」：要素をまとめるための汎用コンテナ ***** %>
                <% if @list.owner?(current_user) %>
                <%# ***** 「if 【条件式】」：【条件式】が true の場合、以下の処理を実行する ***** %>
                  <div class="d-flex">
                  <%# ***** 「<div>」：汎用コンテナ要素 ***** %>
                  <%# ***** 「class ="【クラス名】"」：要素へスタイルを適用するクラス属性 ***** %>
                    <%= button_to '↑', move_list_list_item_path(@list, item, direction: 'up'), method: :patch, class: 'btn btn-sm btn-outline-secondary mr-1', disabled: index.zero? %>
                    <%# ***** 「button_to '↑', move_list_list_item_path(@list, item, direction: 'up'), method: :patch, class: 'btn btn-sm btn-outline-secondary mr-1', disabled: index.zero?」：画面へ値を出力する式 ***** %>
                    <%= button_to '↓', move_list_list_item_path(@list, item, direction: 'down'), method: :patch, class: 'btn btn-sm btn-outline-secondary mr-1', disabled: index == @list_items.size - 1 %>
                    <%# ***** 「button_to '↓', move_list_list_item_path(@list, item, direction: 'down'), method: :patch, class: 'btn btn-sm btn-outline-secondary mr-1', disabled: index == @list_items.size - 1」：画面へ値を出力する式 ***** %>
                    <%= button_to '削除', list_list_item_path(@list, item), method: :delete, data: { confirm: 'リストから削除しますか？' }, class: 'btn btn-sm btn-outline-danger' %>
                    <%# ***** 「button_to '削除', list_list_item_path(@list, item), method: :delete, data: { confirm: 'リストから削除しますか？' }, class: 'btn btn-sm btn-outline-danger'」：画面へ値を出力する式 ***** %>
                  </div>
                  <%# ***** 「<div>【内容】</div>」：要素をまとめるための汎用コンテナ ***** %>
                <% end %>
                <%# ***** 「end」：ブロック処理を終了するキーワード ***** %>
              </div>
              <%# ***** 「<div>【内容】</div>」：要素をまとめるための汎用コンテナ ***** %>

              <% if @list.owner?(current_user) %>
              <%# ***** 「if 【条件式】」：【条件式】が true の場合、以下の処理を実行する ***** %>
<%# ***** 入力フォームセクション ***** %>
                <%= form_with model: [@list, item], local: true, class: 'mt-2' do |f| %>
                <%# ***** 「form_with model: [@list, item], local: true, class: 'mt-2' do |f|」：画面へ値を出力する式 ***** %>
                  <div class="form-group mb-2">
                  <%# ***** 「<div>」：汎用コンテナ要素 ***** %>
                  <%# ***** 「class ="【クラス名】"」：要素へスタイルを適用するクラス属性 ***** %>
                    <%= f.label :memo, '投稿メモ（1件）', class: 'small text-muted' %>
                    <%# ***** 「f.label :memo, '投稿メモ（1件）', class: 'small text-muted'」：画面へ値を出力する式 ***** %>
                    <%# ***** フォーム入力欄セクション ***** %>
                    <%= f.text_area :memo, rows: 2, class: 'form-control' %>
                    <%# ***** 「f.text_area :memo, rows: 2, class: 'form-control'」：画面へ値を出力する式 ***** %>
                  </div>
                  <%# ***** 「<div>【内容】</div>」：要素をまとめるための汎用コンテナ ***** %>
                  <%# ***** 送信ボタンセクション ***** %>
                  <%= f.submit 'メモ保存', class: 'btn btn-sm btn-outline-primary' %>
                  <%# ***** 「f.submit 'メモ保存', class: 'btn btn-sm btn-outline-primary'」：画面へ値を出力する式 ***** %>
                <% end %>
                <%# ***** 「end」：ブロック処理を終了するキーワード ***** %>
              <% elsif item.memo.present? %>
              <%# ***** 「elsif item.memo.present?」：Ruby式を実行する処理 ***** %>
              <%# ***** 「elsif (item.memo.present?)」: 前条件が偽の場合にitem.memo.present?を追加判定する分岐 ***** %>
              <%# ***** 「elsif」：前条件が偽の場合の追加分岐 ***** %>
                <div class="mt-2 small text-muted">
                <%# ***** 「<div>」：汎用コンテナ要素 ***** %>
                <%# ***** 「class ="【クラス名】"」：要素へスタイルを適用するクラス属性 ***** %>
                  <strong>投稿メモ:</strong> <%= simple_format(item.memo) %>
                  <%# ***** 「<strong>【内容】</strong>」：強調テキスト要素 ***** %>
                </div>
                <%# ***** 「<div>【内容】</div>」：要素をまとめるための汎用コンテナ ***** %>
              <% end %>
              <%# ***** 「end」：ブロック処理を終了するキーワード ***** %>
            </li>
            <%# ***** 「<li>【内容】</li>」：リスト項目要素 ***** %>
          <% end %>
          <%# ***** 「end」：ブロック処理を終了するキーワード ***** %>
        </ul>
        <%# ***** 「<ul>【内容】</ul>」：順序なしリスト要素 ***** %>
      <% else %>
      <%# ***** 「else」：上記条件に当てはまらない場合の分岐 ***** %>
        <p class="text-muted mb-0">投稿はまだ登録されていません。</p>
        <%# ***** 「<p>【内容】</p>」：段落要素 ***** %>
        <%# ***** 「class ="【クラス名】"」：要素へスタイルを適用するクラス属性 ***** %>
      <% end %>
      <%# ***** 「end」：ブロック処理を終了するキーワード ***** %>
    </div>
    <%# ***** 「<div>【内容】</div>」：要素をまとめるための汎用コンテナ ***** %>
  </div>
  <%# ***** 「<div>【内容】</div>」：要素をまとめるための汎用コンテナ ***** %>

</div>
<%# ***** 「<div>【内容】</div>」：要素をまとめるための汎用コンテナ ***** %>
