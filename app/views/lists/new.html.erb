<%# ***** lists/new のビュー ***** %>
<%# ***** 「# ***** lists/new のビュー *****」：出力式/式 ***** %>
<div class="container mt-4">
<%# ***** 「<div>」：HTMLタグ ***** %>
<%# ***** 「<div>」：汎用コンテナ要素 ***** %>
<%# ***** 「# ***** 「<div>」：汎用コンテナ要素 *****」：出力式/式 ***** %>
<%# ***** 「class ="【クラス名】"」：要素へスタイルを適用するクラス属性 ***** %>
<%# ***** 「# ***** 「class ="【クラス名】"」：要素へスタイルを適用するクラス属性 *****」：出力式/式 ***** %>
  <h2 class="mb-3">リスト作成</h2>
  <%# ***** 「<h2>【内容】</h2>」：見出し要素 ***** %>
  <%# ***** 「class ="【クラス名】"」：要素へスタイルを適用するクラス属性 ***** %>
  <%= render 'form' %>
  <%# ***** 「render 'form'」：画面へ値を出力する式 ***** %>
  <div class="mt-3">
  <%# ***** 「<div>」：汎用コンテナ要素 ***** %>
  <%# ***** 「class ="【クラス名】"」：要素へスタイルを適用するクラス属性 ***** %>
    <%= link_to '一覧へ戻る', lists_path, class: 'btn btn-outline-secondary btn-sm' %>
    <%# ***** 「link_to '一覧へ戻る', lists_path, class: 'btn btn-outline-secondary btn-sm'」：画面へ値を出力する式 ***** %>
  </div>
  <%# ***** 「<div>【内容】</div>」：要素をまとめるための汎用コンテナ ***** %>
</div>
<%# ***** 「<div>【内容】</div>」：要素をまとめるための汎用コンテナ ***** %>
