<%# ***** admin/comments/index のビュー ***** %>
<div class="container mt-4">
<%# ***** div：汎用コンテナ要素 ***** %>
  <h1>コメント管理</h1>
  <%# ***** h1：見出し要素 ***** %>

  <%= search_form_for @q, url: admin_comments_path do |f| %>
    <div class="row mb-3">
    <%# ***** div：汎用コンテナ要素 ***** %>
      <div class="col-md-4">
      <%# ***** div：汎用コンテナ要素 ***** %>
        <%= f.label :body_cont, 'コメント本文検索' %>
      <%# ***** フォーム入力欄セクション ***** %>
        <%= f.search_field :body_cont, class: 'form-control', placeholder: 'コメント内容で検索' %>
      </div>
      <%# ***** </div>：divタグ（汎用コンテナ要素）の終了 ***** %>
      <div class="col-md-4">
      <%# ***** div：汎用コンテナ要素 ***** %>
        <%= f.label :user_name_cont, 'ユーザー名検索' %>
        <%= f.search_field :user_name_cont, class: 'form-control', placeholder: 'ユーザー名で検索' %>
      </div>
      <%# ***** </div>：divタグ（汎用コンテナ要素）の終了 ***** %>
      <div class="col-md-4">
      <%# ***** div：汎用コンテナ要素 ***** %>
        <%= f.label :post_title_cont, '投稿タイトル検索' %>
        <%= f.search_field :post_title_cont, class: 'form-control', placeholder: '投稿タイトルで検索' %>
      </div>
      <%# ***** </div>：divタグ（汎用コンテナ要素）の終了 ***** %>
    </div>
    <%# ***** </div>：divタグ（汎用コンテナ要素）の終了 ***** %>
    <div class="mb-3">
    <%# ***** 送信ボタンセクション ***** %>
      <%= f.submit '検索', class: 'btn btn-primary' %>
      <%= link_to 'リセット', admin_comments_path, class: 'btn btn-secondary' %>
    </div>
    <%# ***** </div>：divタグ（汎用コンテナ要素）の終了 ***** %>
  <% end %>

<%# ***** 一覧テーブルセクション ***** %>
  <table class="table table-striped">
  <%# ***** table：テーブル要素 ***** %>
    <thead>
    <%# ***** thead：テーブル見出し要素 ***** %>
      <tr>
      <%# ***** tr：テーブル行要素 ***** %>
        <th>ID</th>
        <%# ***** th：テーブル見出しセル要素 ***** %>
        <th>コメント内容</th>
        <%# ***** th：テーブル見出しセル要素 ***** %>
        <th>投稿者</th>
        <%# ***** th：テーブル見出しセル要素 ***** %>
        <th>投稿</th>
        <%# ***** th：テーブル見出しセル要素 ***** %>
        <th>作成日</th>
        <%# ***** th：テーブル見出しセル要素 ***** %>
        <th>操作</th>
        <%# ***** th：テーブル見出しセル要素 ***** %>
      </tr>
      <%# ***** </tr>：trタグ（テーブル行要素）の終了 ***** %>
    </thead>
    <%# ***** </thead>：theadタグ（テーブル見出し要素）の終了 ***** %>
    <tbody>
    <%# ***** 一覧ループセクション ***** %>
      <% @comments.each do |comment| %>
      <%# ***** each：コレクションを順に処理するループ ***** %>
        <tr>
        <%# ***** tr：テーブル行要素 ***** %>
          <td><%= comment.id %></td>
          <%# ***** td：テーブルデータセル要素 ***** %>
          <td><%= truncate(comment.body, length: 50) %></td>
          <%# ***** td：テーブルデータセル要素 ***** %>
          <td><%= link_to comment.user.name, admin_user_path(comment.user) %></td>
          <%# ***** td：テーブルデータセル要素 ***** %>
          <td><%= link_to truncate(comment.post.title, length: 30), post_path(comment.post) %></td>
          <%# ***** td：テーブルデータセル要素 ***** %>
          <td><%= comment.created_at.strftime('%Y/%m/%d %H:%M') %></td>
          <%# ***** td：テーブルデータセル要素 ***** %>
          <td>
          <%# ***** td：テーブルデータセル要素 ***** %>
            <%= link_to '削除', admin_comment_path(comment), method: :delete, data: { confirm: '本当に削除しますか？' }, class: 'btn btn-sm btn-danger' %>
          </td>
          <%# ***** </td>：tdタグ（テーブルデータセル要素）の終了 ***** %>
        </tr>
        <%# ***** </tr>：trタグ（テーブル行要素）の終了 ***** %>
      <% end %>
    </tbody>
    <%# ***** </tbody>：tbodyタグ（テーブル本文要素）の終了 ***** %>
  </table>
  <%# ***** </table>：tableタグ（テーブル要素）の終了 ***** %>

  <%= paginate @comments %>
</div>
<%# ***** </div>：divタグ（汎用コンテナ要素）の終了 ***** %>
