<%# ***** admin/users/show のビュー ***** %>
<div class="container mt-4">
<%# ***** 「<div>」：汎用コンテナ要素 ***** %>
<%# ***** 「class ="【クラス名】"」：要素へスタイルを適用するクラス属性 ***** %>
  <h1>ユーザー詳細</h1>
  <%# ***** 「<h1>【内容】</h1>」：見出し要素 ***** %>

  <div class="card">
  <%# ***** 「<div>」：汎用コンテナ要素 ***** %>
  <%# ***** 「class ="【クラス名】"」：要素へスタイルを適用するクラス属性 ***** %>
    <div class="card-body">
    <%# ***** 「<div>」：汎用コンテナ要素 ***** %>
    <%# ***** 「class ="【クラス名】"」：要素へスタイルを適用するクラス属性 ***** %>
      <dl class="row">
      <%# ***** 「<dl>」：HTML要素 ***** %>
      <%# ***** 「class ="【クラス名】"」：要素へスタイルを適用するクラス属性 ***** %>
        <dt class="col-sm-3">ID</dt>
        <%# ***** 「<dt>【内容】</dt>」：HTML要素 ***** %>
        <%# ***** 「class ="【クラス名】"」：要素へスタイルを適用するクラス属性 ***** %>
        <dd class="col-sm-9"><%= @user.id %></dd>
        <%# ***** 「<dd>【内容】</dd>」：HTML要素 ***** %>
        <%# ***** 「class ="【クラス名】"」：要素へスタイルを適用するクラス属性 ***** %>

        <dt class="col-sm-3">名前</dt>
        <%# ***** 「<dt>【内容】</dt>」：HTML要素 ***** %>
        <%# ***** 「class ="【クラス名】"」：要素へスタイルを適用するクラス属性 ***** %>
        <dd class="col-sm-9"><%= @user.name %></dd>
        <%# ***** 「<dd>【内容】</dd>」：HTML要素 ***** %>
        <%# ***** 「class ="【クラス名】"」：要素へスタイルを適用するクラス属性 ***** %>

        <dt class="col-sm-3">メールアドレス</dt>
        <%# ***** 「<dt>【内容】</dt>」：HTML要素 ***** %>
        <%# ***** 「class ="【クラス名】"」：要素へスタイルを適用するクラス属性 ***** %>
        <dd class="col-sm-9"><%= @user.email %></dd>
        <%# ***** 「<dd>【内容】</dd>」：HTML要素 ***** %>
        <%# ***** 「class ="【クラス名】"」：要素へスタイルを適用するクラス属性 ***** %>

        <dt class="col-sm-3">権限</dt>
        <%# ***** 「<dt>【内容】</dt>」：HTML要素 ***** %>
        <%# ***** 「class ="【クラス名】"」：要素へスタイルを適用するクラス属性 ***** %>
        <dd class="col-sm-9">
        <%# ***** 「<dd>」：HTML要素 ***** %>
        <%# ***** 「class ="【クラス名】"」：要素へスタイルを適用するクラス属性 ***** %>
          <span class="badge badge-<%= @user.admin? ? 'danger' : @user.general? ? 'primary' : 'secondary' %>">
          <%# ***** 「<span>【内容】</span>」：インライン要素 ***** %>
            <%= I18n.t("enums.user.role.#{@user.role}") %>
            <%# ***** 「I18n.t("enums.user.role.#{@user.role}")」：画面へ値を出力する式 ***** %>
          </span>
          <%# ***** 「<span>【内容】</span>」：インライン要素 ***** %>
        </dd>
        <%# ***** 「<dd>【内容】</dd>」：定義説明要素 ***** %>

        <dt class="col-sm-3">作成日</dt>
        <%# ***** 「<dt>【内容】</dt>」：HTML要素 ***** %>
        <%# ***** 「class ="【クラス名】"」：要素へスタイルを適用するクラス属性 ***** %>
        <dd class="col-sm-9"><%= @user.created_at.strftime('%Y年%m月%d日 %H:%M') %></dd>
        <%# ***** 「<dd>【内容】</dd>」：HTML要素 ***** %>
        <%# ***** 「class ="【クラス名】"」：要素へスタイルを適用するクラス属性 ***** %>

        <dt class="col-sm-3">更新日</dt>
        <%# ***** 「<dt>【内容】</dt>」：HTML要素 ***** %>
        <%# ***** 「class ="【クラス名】"」：要素へスタイルを適用するクラス属性 ***** %>
        <dd class="col-sm-9"><%= @user.updated_at.strftime('%Y年%m月%d日 %H:%M') %></dd>
        <%# ***** 「<dd>【内容】</dd>」：HTML要素 ***** %>
        <%# ***** 「class ="【クラス名】"」：要素へスタイルを適用するクラス属性 ***** %>
      </dl>
      <%# ***** 「<dl>【内容】</dl>」：定義リスト要素 ***** %>
    </div>
    <%# ***** 「<div>【内容】</div>」：要素をまとめるための汎用コンテナ ***** %>
  </div>
  <%# ***** 「<div>【内容】</div>」：要素をまとめるための汎用コンテナ ***** %>

  <h3 class="mt-4">投稿一覧（<%= @user.posts.count %>件）</h3>
  <%# ***** 「<h3>【内容】</h3>」：見出し要素 ***** %>
  <%# ***** 条件分岐セクション ***** %>
  <%# ***** 「class ="【クラス名】"」：要素へスタイルを適用するクラス属性 ***** %>
  <% if @user.posts.any? %>
  <%# ***** 「if 【条件式】」：【条件式】が true の場合、以下の処理を実行する ***** %>
    <ul class="list-group">
    <%# ***** 「<ul>」：順序なしリスト要素 ***** %>
    <%# ***** 一覧ループセクション ***** %>
    <%# ***** 「class ="【クラス名】"」：要素へスタイルを適用するクラス属性 ***** %>
      <% @user.posts.order(created_at: :desc).limit(10).each do |post| %>
      <%# ***** 「@user.posts.order(created_at: :desc).limit(10).each do |post|」：Ruby式を実行する処理 ***** %>
      <%# ***** 「each do |post|」: コレクションを順番に処理し、|post| で現在要素を受け取る反復構文 ***** %>
      <%# ***** 「@user.posts.order(created_at: :desc).limit(10)」：処理対象となるコレクション ***** %>
      <%# ***** 「|post|」：各反復で取り出した要素を受け取るブロック引数 ***** %>
      <%# ***** 「each」：コレクションを順に処理するループ ***** %>
        <li class="list-group-item">
        <%# ***** 「<li>」：リスト項目要素 ***** %>
        <%# ***** 「class ="【クラス名】"」：要素へスタイルを適用するクラス属性 ***** %>
          <%= link_to post.title, post_path(post) %>
          <%# ***** 「link_to post.title, post_path(post)」：画面へ値を出力する式 ***** %>
          <small class="text-muted">（<%= post.created_at.strftime('%Y/%m/%d') %>）</small>
          <%# ***** 「<small>【内容】</small>」：補足テキスト要素 ***** %>
          <%# ***** 「class ="【クラス名】"」：要素へスタイルを適用するクラス属性 ***** %>
        </li>
        <%# ***** 「<li>【内容】</li>」：リスト項目要素 ***** %>
      <% end %>
      <%# ***** 「end」：ブロック処理を終了するキーワード ***** %>
    </ul>
    <%# ***** 「<ul>【内容】</ul>」：順序なしリスト要素 ***** %>
  <% else %>
  <%# ***** 「else」：上記条件に当てはまらない場合の分岐 ***** %>
    <p class="text-muted">投稿はありません。</p>
    <%# ***** 「<p>【内容】</p>」：段落要素 ***** %>
    <%# ***** 「class ="【クラス名】"」：要素へスタイルを適用するクラス属性 ***** %>
  <% end %>
  <%# ***** 「end」：ブロック処理を終了するキーワード ***** %>

  <h3 class="mt-4">コメント一覧（<%= @user.comments.count %>件）</h3>
  <%# ***** 「<h3>【内容】</h3>」：見出し要素 ***** %>
  <%# ***** 「class ="【クラス名】"」：要素へスタイルを適用するクラス属性 ***** %>
  <% if @user.comments.any? %>
  <%# ***** 「if 【条件式】」：【条件式】が true の場合、以下の処理を実行する ***** %>
    <ul class="list-group">
    <%# ***** 「<ul>」：順序なしリスト要素 ***** %>
    <%# ***** 「class ="【クラス名】"」：要素へスタイルを適用するクラス属性 ***** %>
      <% @user.comments.order(created_at: :desc).limit(10).each do |comment| %>
      <%# ***** 「@user.comments.order(created_at: :desc).limit(10).each do |comment|」：Ruby式を実行する処理 ***** %>
      <%# ***** 「each do |comment|」: コレクションを順番に処理し、|comment| で現在要素を受け取る反復構文 ***** %>
      <%# ***** 「@user.comments.order(created_at: :desc).limit(10)」：処理対象となるコレクション ***** %>
      <%# ***** 「|comment|」：各反復で取り出した要素を受け取るブロック引数 ***** %>
      <%# ***** 「each」：コレクションを順に処理するループ ***** %>
        <li class="list-group-item">
        <%# ***** 「<li>」：リスト項目要素 ***** %>
        <%# ***** 「class ="【クラス名】"」：要素へスタイルを適用するクラス属性 ***** %>
          <%= truncate(comment.body, length: 100) %>
          <%# ***** 「truncate(comment.body, length: 100)」：画面へ値を出力する式 ***** %>
          <small class="text-muted">（<%= comment.created_at.strftime('%Y/%m/%d') %>）</small>
          <%# ***** 「<small>【内容】</small>」：補足テキスト要素 ***** %>
          <%# ***** 「class ="【クラス名】"」：要素へスタイルを適用するクラス属性 ***** %>
        </li>
        <%# ***** 「<li>【内容】</li>」：リスト項目要素 ***** %>
      <% end %>
      <%# ***** 「end」：ブロック処理を終了するキーワード ***** %>
    </ul>
    <%# ***** 「<ul>【内容】</ul>」：順序なしリスト要素 ***** %>
  <% else %>
  <%# ***** 「else」：上記条件に当てはまらない場合の分岐 ***** %>
    <p class="text-muted">コメントはありません。</p>
    <%# ***** 「<p>【内容】</p>」：段落要素 ***** %>
    <%# ***** 「class ="【クラス名】"」：要素へスタイルを適用するクラス属性 ***** %>
  <% end %>
  <%# ***** 「end」：ブロック処理を終了するキーワード ***** %>

  <div class="mt-4">
  <%# ***** 「<div>」：汎用コンテナ要素 ***** %>
  <%# ***** 「class ="【クラス名】"」：要素へスタイルを適用するクラス属性 ***** %>
    <%= link_to '編集', edit_admin_user_path(@user), class: 'btn btn-warning' %>
    <%# ***** 「link_to '編集', edit_admin_user_path(@user), class: 'btn btn-warning'」：画面へ値を出力する式 ***** %>
    <%= link_to '戻る', admin_users_path, class: 'btn btn-secondary' %>
    <%# ***** 「link_to '戻る', admin_users_path, class: 'btn btn-secondary'」：画面へ値を出力する式 ***** %>
    <% unless @user == current_user %>
    <%# ***** 「unless @user == current_user」：Ruby式を実行する処理 ***** %>
    <%# ***** 「unless (@user == current_user)」: @user == current_userが偽の場合に処理する条件分岐 ***** %>
    <%# ***** 「unless」：条件が偽の場合に処理する分岐 ***** %>
      <%= link_to '削除', admin_user_path(@user), method: :delete, data: { confirm: '本当に削除しますか？' }, class: 'btn btn-danger' %>
      <%# ***** 「link_to '削除', admin_user_path(@user), method: :delete, data: { confirm: '本当に削除しますか？' }, class: 'btn btn-danger'」：画面へ値を出力する式 ***** %>
    <% end %>
    <%# ***** 「end」：ブロック処理を終了するキーワード ***** %>
  </div>
  <%# ***** 「<div>【内容】</div>」：要素をまとめるための汎用コンテナ ***** %>
</div>
<%# ***** 「<div>【内容】</div>」：要素をまとめるための汎用コンテナ ***** %>
