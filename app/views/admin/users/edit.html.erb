<%# ***** admin/users/edit のビュー ***** %>
<div class="container mt-4">
<%# ***** div：汎用コンテナ要素 ***** %>
  <h1>ユーザー編集</h1>

  <%# ***** 入力フォームセクション ***** %>
  <%= form_with(model: @user, url: admin_user_path(@user), local: true) do |f| %>
  <%# ***** エラーメッセージ表示セクション ***** %>
  <%# ***** 条件分岐セクション ***** %>
    <% if @user.errors.any? %>
    <%# ***** 「if (【条件】)」: 【条件】を判定する条件分岐 ***** %>
    <%# ***** if：条件を判定する分岐 ***** %>
      <div class="alert alert-danger">
      <%# ***** div：汎用コンテナ要素 ***** %>
        <h4><%= pluralize(@user.errors.count, "error") %> prohibited this user from being saved:</h4>
        <%# ***** h4：見出し要素 ***** %>
        <ul>
        <%# ***** 一覧ループセクション ***** %>
          <% @user.errors.full_messages.each do |message| %>
          <%# ***** 「each do |【要素】|」: コレクションを順番に処理し、|【要素】| で現在要素を受け取る反復構文 ***** %>
          <%# ***** 「@user.errors.full_messages」：処理対象となるコレクション ***** %>
          <%# ***** 「|message|」：各反復で取り出した要素を受け取るブロック引数 ***** %>
          <%# ***** each：コレクションを順に処理するループ ***** %>
            <li><%= message %></li>
            <%# ***** li：リスト項目要素 ***** %>
          <% end %>
        </ul>
        <%# ***** </ul>：ulタグ（順序なしリスト要素）の終了 ***** %>
      </div>
      <%# ***** </div>：divタグ（汎用コンテナ要素）の終了 ***** %>
    <% end %>

    <div class="form-group">
    <%# ***** div：汎用コンテナ要素 ***** %>
      <%= f.label :name, '名前' %>
      <%# ***** フォーム入力欄セクション ***** %>
      <%= f.text_field :name, class: 'form-control' %>
    </div>
    <%# ***** </div>：divタグ（汎用コンテナ要素）の終了 ***** %>

    <div class="form-group">
    <%# ***** div：汎用コンテナ要素 ***** %>
      <%= f.label :email, 'メールアドレス' %>
      <%= f.email_field :email, class: 'form-control' %>
    </div>
    <%# ***** </div>：divタグ（汎用コンテナ要素）の終了 ***** %>

    <div class="form-group">
    <%# ***** div：汎用コンテナ要素 ***** %>
      <%= f.label :role, '権限' %>
      <%= f.select :role, User.roles.keys.map { |k| [I18n.t("enums.user.role.#{k}"), k] }, {}, class: 'form-control' %>
      <small class="form-text text-muted">
      <%# ***** small：補足テキスト要素 ***** %>
        管理者: すべての機能にアクセス可能 / 一般: 通常ユーザー / ゲスト: 閲覧のみ
      </small>
      <%# ***** </small>：smallタグ（補足テキスト要素）の終了 ***** %>
    </div>
    <%# ***** </div>：divタグ（汎用コンテナ要素）の終了 ***** %>

    <div class="actions mt-4">
    <%# ***** 送信ボタンセクション ***** %>
      <%= f.submit '更新', class: 'btn btn-primary' %>
      <%= link_to 'キャンセル', admin_user_path(@user), class: 'btn btn-secondary' %>
    </div>
    <%# ***** </div>：divタグ（汎用コンテナ要素）の終了 ***** %>
  <% end %>
</div>
<%# ***** </div>：divタグ（汎用コンテナ要素）の終了 ***** %>
