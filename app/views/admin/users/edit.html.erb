<%# ***** admin/users/edit のビュー ***** %>
<div class="container mt-4">
<%# ***** 「<div>」：汎用コンテナ要素 ***** %>
<%# ***** 「class ="【クラス名】"」：要素へスタイルを適用するクラス属性 ***** %>
  <h1>ユーザー編集</h1>
  <%# ***** 「<h1>【内容】</h1>」：見出し要素 ***** %>

  <%# ***** 「<h1>【内容】</h1>」：見出し要素 ***** %>
  <%# ***** 入力フォームセクション ***** %>
  <%= form_with(model: @user, url: admin_user_path(@user), local: true) do |f| %>
  <%# ***** 「form_with(model: @user, url: admin_user_path(@user), local: true) do |f|」：画面へ値を出力する式 ***** %>
  <%# ***** エラーメッセージ表示セクション ***** %>
  <%# ***** 条件分岐セクション ***** %>
    <% if @user.errors.any? %>
    <%# ***** 「if 【条件式】」：【条件式】が true の場合、以下の処理を実行する ***** %>
      <div class="alert alert-danger">
      <%# ***** 「<div>」：汎用コンテナ要素 ***** %>
      <%# ***** 「class ="【クラス名】"」：要素へスタイルを適用するクラス属性 ***** %>
        <h4><%= pluralize(@user.errors.count, "error") %> prohibited this user from being saved:</h4>
        <%# ***** 「<h4>【内容】</h4>」：見出し要素 ***** %>
        <ul>
        <%# ***** 「<ul>」：順序なしリスト要素 ***** %>
        <%# ***** 一覧ループセクション ***** %>
          <% @user.errors.full_messages.each do |message| %>
          <%# ***** 「@user.errors.full_messages.each do |message|」：Ruby式を実行する処理 ***** %>
          <%# ***** 「each do |message|」: コレクションを順番に処理し、|message| で現在要素を受け取る反復構文 ***** %>
          <%# ***** 「@user.errors.full_messages」：処理対象となるコレクション ***** %>
          <%# ***** 「|message|」：各反復で取り出した要素を受け取るブロック引数 ***** %>
          <%# ***** 「each」：コレクションを順に処理するループ ***** %>
            <li><%= message %></li>
            <%# ***** 「<li>【内容】</li>」：リスト項目要素 ***** %>
          <% end %>
          <%# ***** 「end」：ブロック処理を終了するキーワード ***** %>
        </ul>
        <%# ***** 「<ul>【内容】</ul>」：順序なしリスト要素 ***** %>
      </div>
      <%# ***** 「<div>【内容】</div>」：要素をまとめるための汎用コンテナ ***** %>
    <% end %>
    <%# ***** 「end」：ブロック処理を終了するキーワード ***** %>

    <div class="form-group">
    <%# ***** 「<div>」：汎用コンテナ要素 ***** %>
    <%# ***** 「class ="【クラス名】"」：要素へスタイルを適用するクラス属性 ***** %>
      <%= f.label :name, '名前' %>
      <%# ***** 「f.label :name, '名前'」：画面へ値を出力する式 ***** %>
      <%# ***** フォーム入力欄セクション ***** %>
      <%= f.text_field :name, class: 'form-control' %>
      <%# ***** 「f.text_field :name, class: 'form-control'」：画面へ値を出力する式 ***** %>
    </div>
    <%# ***** 「<div>【内容】</div>」：要素をまとめるための汎用コンテナ ***** %>

    <div class="form-group">
    <%# ***** 「<div>」：汎用コンテナ要素 ***** %>
    <%# ***** 「class ="【クラス名】"」：要素へスタイルを適用するクラス属性 ***** %>
      <%= f.label :email, 'メールアドレス' %>
      <%# ***** 「f.label :email, 'メールアドレス'」：画面へ値を出力する式 ***** %>
      <%= f.email_field :email, class: 'form-control' %>
      <%# ***** 「f.email_field :email, class: 'form-control'」：画面へ値を出力する式 ***** %>
    </div>
    <%# ***** 「<div>【内容】</div>」：要素をまとめるための汎用コンテナ ***** %>

    <div class="form-group">
    <%# ***** 「<div>」：汎用コンテナ要素 ***** %>
    <%# ***** 「class ="【クラス名】"」：要素へスタイルを適用するクラス属性 ***** %>
      <%= f.label :role, '権限' %>
      <%# ***** 「f.label :role, '権限'」：画面へ値を出力する式 ***** %>
      <%= f.select :role, User.roles.keys.map { |k| [I18n.t("enums.user.role.#{k}"), k] }, {}, class: 'form-control' %>
      <%# ***** 「f.select :role, User.roles.keys.map { |k| [I18n.t("enums.user.role.#{k}"), k] }, {}, class: 'form-control'」：画面へ値を出力する式 ***** %>
      <small class="form-text text-muted">
      <%# ***** 「<small>」：補足テキスト要素 ***** %>
      <%# ***** 「class ="【クラス名】"」：要素へスタイルを適用するクラス属性 ***** %>
        管理者: すべての機能にアクセス可能 / 一般: 通常ユーザー / ゲスト: 閲覧のみ
      </small>
      <%# ***** 「<small>【内容】</small>」：補足テキスト要素 ***** %>
    </div>
    <%# ***** 「<div>【内容】</div>」：要素をまとめるための汎用コンテナ ***** %>

    <div class="actions mt-4">
    <%# ***** 「<div>」：汎用コンテナ要素 ***** %>
    <%# ***** 送信ボタンセクション ***** %>
    <%# ***** 「class ="【クラス名】"」：要素へスタイルを適用するクラス属性 ***** %>
      <%= f.submit '更新', class: 'btn btn-primary' %>
      <%# ***** 「f.submit '更新', class: 'btn btn-primary'」：画面へ値を出力する式 ***** %>
      <%= link_to 'キャンセル', admin_user_path(@user), class: 'btn btn-secondary' %>
      <%# ***** 「link_to 'キャンセル', admin_user_path(@user), class: 'btn btn-secondary'」：画面へ値を出力する式 ***** %>
    </div>
    <%# ***** 「<div>【内容】</div>」：要素をまとめるための汎用コンテナ ***** %>
  <% end %>
  <%# ***** 「end」：ブロック処理を終了するキーワード ***** %>
</div>
<%# ***** 「<div>【内容】</div>」：要素をまとめるための汎用コンテナ ***** %>
