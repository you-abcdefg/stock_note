<%# ***** ユーザーページ用の投稿検索フォーム（パーシャル） ***** %>
<%# ***** 「# ***** ユーザーページ用の投稿検索フォーム（パーシャル） *****」：出力式/式 ***** %>
<%# ***** ユーザー名検索は除外（すでにユーザーで絞り込み済み） ***** %>
<%# ***** 「# ***** ユーザー名検索は除外（すでにユーザーで絞り込み済み） *****」：出力式/式 ***** %>
<% selected_tags = Array(params.dig(:q, :tags_name_in)).reject(&:blank?) %>
<%# ***** 「selected_tags = Array(params.dig(:q, :tags_name_in)).reject(&:blank?)」：出力式/式 ***** %>
<%# ***** 「selected_tags = Array(params.dig(:q, :tags_name_in)).reject(&:blank?)」: selected_tagsに計算結果を代入して保持する式 ***** %>
<%# ***** 「# ***** 「selected_tags = Array(params.dig(:q, :tags_name_in)).reject(&:blank?)」: selected_tagsに計算結果を代入して保持する式 *****」：出力式/式 ***** %>
<%# ***** selected_tags：この行で使用する値を保持する変数 ***** %>
<%# ***** 「# ***** selected_tags：この行で使用する値を保持する変数 *****」：出力式/式 ***** %>
<% tag_select_class = "form-control form-control-sm" %>
<%# ***** 「tag_select_class = "form-control form-control-sm"」：出力式/式 ***** %>
<%# ***** 「tag_select_class = "form-control form-control-sm"」: tag_select_classに計算結果を代入して保持する式 ***** %>
<%# ***** 「# ***** 「tag_select_class = "form-control form-control-sm"」: tag_select_classに計算結果を代入して保持する式 *****」：出力式/式 ***** %>
<%# ***** tag_select_class：この行で使用する値を保持する変数 ***** %>
<%# ***** 「# ***** tag_select_class：この行で使用する値を保持する変数 *****」：出力式/式 ***** %>

<div class="card mb-3 bg-dark text-white">
<%# ***** 「<div>」：HTMLタグ ***** %>
<%# ***** 「<div>」：汎用コンテナ要素 ***** %>
<%# ***** 「# ***** 「<div>」：汎用コンテナ要素 *****」：出力式/式 ***** %>
<%# ***** 「class ="【クラス名】"」：要素へスタイルを適用するクラス属性 ***** %>
<%# ***** 「# ***** 「class ="【クラス名】"」：要素へスタイルを適用するクラス属性 *****」：出力式/式 ***** %>
  <div class="card-header">
  <%# ***** 「<div>」：汎用コンテナ要素 ***** %>
  <%# ***** 「class ="【クラス名】"」：要素へスタイルを適用するクラス属性 ***** %>
    <h5 class="mb-0">
    <%# ***** 「<h5>」：見出し要素 ***** %>
    <%# ***** 「class ="【クラス名】"」：要素へスタイルを適用するクラス属性 ***** %>
      <i class="fas fa-filter"></i> フィルター・並び替え
      <%# ***** i：HTML要素 ***** %>
    </h5>
    <%# ***** 「<h5>【内容】</h5>」：見出し要素 ***** %>
  </div>
  <%# ***** 「<div>【内容】</div>」：要素をまとめるための汎用コンテナ ***** %>
  <div class="card-body">
  <%# ***** 「<div>」：汎用コンテナ要素 ***** %>
  <%# ***** 「class ="【クラス名】"」：要素へスタイルを適用するクラス属性 ***** %>
    <%= search_form_for @q, url: user_path(@user), local: true, method: :get do |f| %>
    <%# ***** 「search_form_for @q, url: user_path(@user), local: true, method: :get do |f|」：画面へ値を出力する式 ***** %>
      <div class="row">
      <%# ***** 「<div>」：汎用コンテナ要素 ***** %>
      <%# ***** 「class ="【クラス名】"」：要素へスタイルを適用するクラス属性 ***** %>
        <!-- タグ検索 -->
        <div class="col-md-6 mb-2">
        <%# ***** 「<div>」：汎用コンテナ要素 ***** %>
        <%# ***** 「class ="【クラス名】"」：要素へスタイルを適用するクラス属性 ***** %>
          <%= f.label :tags_name_in, 'タグ', class: 'form-label text-white' %>
          <%# ***** 「f.label :tags_name_in, 'タグ', class: 'form-label text-white'」：画面へ値を出力する式 ***** %>
          <%# ***** フォーム入力欄セクション ***** %>
          <%= f.select :tags_name_in,
              [['すべて', '']] + ActsAsTaggableOn::Tag.pluck(:name).map { |tag| [tag, tag] },
              {},
              { multiple: true, class: tag_select_class, size: 5 } %>
              <%# ***** スクリプトセクション ***** %>
          <script>
          <%# ***** 「<script>」：スクリプト要素 ***** %>
            document.addEventListener('DOMContentLoaded', function() {
              const tagSelects = document.querySelectorAll('select[name="q[tags_name_in][]"]');
              tagSelects.forEach(function(tagSelect) {
                if (tagSelect && !tagSelect.value) {
                  tagSelect.options[0].selected = true;
                }
              });
            });
          </script>
          <%# ***** 「<script>【内容】</script>」：スクリプト要素 ***** %>
        </div>
        <%# ***** 「<div>【内容】</div>」：要素をまとめるための汎用コンテナ ***** %>

        <!-- ソート順 -->
        <div class="col-md-6 mb-2">
        <%# ***** 「<div>」：汎用コンテナ要素 ***** %>
        <%# ***** 「class ="【クラス名】"」：要素へスタイルを適用するクラス属性 ***** %>
          <%= f.label :s, '並び順', class: 'form-label text-white' %>
          <%# ***** 「f.label :s, '並び順', class: 'form-label text-white'」：画面へ値を出力する式 ***** %>
          <%= f.select :s,
              [
                ['新しい順', 'created_at desc'],
                ['古い順', 'created_at asc'],
                ['更新日時（新しい順）', 'updated_at desc'],
                ['更新日時（古い順）', 'updated_at asc']
              ],
              { include_blank: '新しい順（デフォルト）' },
              class: 'form-control form-control-sm' %>
        </div>
        <%# ***** 「<div>【内容】</div>」：要素をまとめるための汎用コンテナ ***** %>
      </div>
      <%# ***** 「<div>【内容】</div>」：要素をまとめるための汎用コンテナ ***** %>

      <div class="row mt-2">
      <%# ***** 「<div>」：汎用コンテナ要素 ***** %>
      <%# ***** 「class ="【クラス名】"」：要素へスタイルを適用するクラス属性 ***** %>
        <!-- 投稿日時（開始） -->
        <div class="col-md-6 mb-2">
        <%# ***** 「<div>」：汎用コンテナ要素 ***** %>
        <%# ***** 「class ="【クラス名】"」：要素へスタイルを適用するクラス属性 ***** %>
          <%= f.label :created_at_gteq, '投稿日時（開始）', class: 'form-label text-white' %>
          <%# ***** 「f.label :created_at_gteq, '投稿日時（開始）', class: 'form-label text-white'」：画面へ値を出力する式 ***** %>
          <%= f.date_field :created_at_gteq, class: 'form-control form-control-sm', placeholder: 'yyyy-mm-dd' %>
          <%# ***** 「f.date_field :created_at_gteq, class: 'form-control form-control-sm', placeholder: 'yyyy-mm-dd'」：画面へ値を出力する式 ***** %>
          <small class="form-text text-white-50">未指定の場合：最も古い投稿から</small>
          <%# ***** 「<small>【内容】</small>」：補足テキスト要素 ***** %>
          <%# ***** 「class ="【クラス名】"」：要素へスタイルを適用するクラス属性 ***** %>
        </div>
        <%# ***** 「<div>【内容】</div>」：要素をまとめるための汎用コンテナ ***** %>

        <!-- 投稿日時（終了） -->
        <div class="col-md-6 mb-2">
        <%# ***** 「<div>」：汎用コンテナ要素 ***** %>
        <%# ***** 「class ="【クラス名】"」：要素へスタイルを適用するクラス属性 ***** %>
          <%= f.label :created_at_lteq_end_of_day, '投稿日時（終了）', class: 'form-label text-white' %>
          <%# ***** 「f.label :created_at_lteq_end_of_day, '投稿日時（終了）', class: 'form-label text-white'」：画面へ値を出力する式 ***** %>
          <%= f.date_field :created_at_lteq_end_of_day, class: 'form-control form-control-sm', placeholder: 'yyyy-mm-dd' %>
          <%# ***** 「f.date_field :created_at_lteq_end_of_day, class: 'form-control form-control-sm', placeholder: 'yyyy-mm-dd'」：画面へ値を出力する式 ***** %>
          <small class="form-text text-white-50">未指定の場合：最新の投稿まで</small>
          <%# ***** 「<small>【内容】</small>」：補足テキスト要素 ***** %>
          <%# ***** 「class ="【クラス名】"」：要素へスタイルを適用するクラス属性 ***** %>
        </div>
        <%# ***** 「<div>【内容】</div>」：要素をまとめるための汎用コンテナ ***** %>
      </div>
      <%# ***** 「<div>【内容】</div>」：要素をまとめるための汎用コンテナ ***** %>

      <div class="d-flex justify-content-end mt-3">
      <%# ***** 「<div>」：汎用コンテナ要素 ***** %>
      <%# ***** 「class ="【クラス名】"」：要素へスタイルを適用するクラス属性 ***** %>
        <%= link_to 'リセット', user_path(@user), class: 'btn btn-sm btn-secondary mr-2' %>
        <%# ***** 「link_to 'リセット', user_path(@user), class: 'btn btn-sm btn-secondary mr-2'」：画面へ値を出力する式 ***** %>
        <%# ***** 送信ボタンセクション ***** %>
        <%= f.submit '検索', class: 'btn btn-sm btn-primary' %>
        <%# ***** 「f.submit '検索', class: 'btn btn-sm btn-primary'」：画面へ値を出力する式 ***** %>
      </div>
      <%# ***** 「<div>【内容】</div>」：要素をまとめるための汎用コンテナ ***** %>
    <% end %>
    <%# ***** 「end」：ブロック処理を終了するキーワード ***** %>
  </div>
  <%# ***** 「<div>【内容】</div>」：要素をまとめるための汎用コンテナ ***** %>
</div>
<%# ***** 「<div>【内容】</div>」：要素をまとめるための汎用コンテナ ***** %>
<%# ***** 「# ***** 「<div>【内容】</div>」：要素をまとめるための汎用コンテナ *****」：出力式/式 ***** %>