<%# ***** users/show のビュー ***** %>
<div class="container mt-5">
<%# ***** div：汎用コンテナ要素 ***** %>
  <div class="row">
  <%# ***** div：汎用コンテナ要素 ***** %>
    <!-- ===== プロフィール情報 ===== -->
    <div class="col-md-4 mb-4">
    <%# ***** div：汎用コンテナ要素 ***** %>
      <div class="card shadow-sm">
      <%# ***** div：汎用コンテナ要素 ***** %>
        <div class="card-body text-center">
        <%# ***** div：汎用コンテナ要素 ***** %>
          <!-- ユーザーアバター -->
          <div class="mb-3">
          <%# ***** div：汎用コンテナ要素 ***** %>
            <i class="fas fa-user-circle fa-5x text-primary"></i>
            <%# ***** i：HTML要素 ***** %>
          </div>
          <%# ***** </div>：divタグ（汎用コンテナ要素）の終了 ***** %>

          <!-- ユーザー情報 -->
          <h3 class="card-title"><%= @user.name %></h3>
          <%# ***** h3：見出し要素 ***** %>
          <p class="text-muted"><%= @user.email %></p>
          <%# ***** p：段落要素 ***** %>

          <!-- ロール表示 -->
          <div class="mb-3">
<%# ***** 条件分岐セクション ***** %>
            <% if @user.admin? %>
            <%# ***** if：条件を判定する分岐 ***** %>
              <span class="badge badge-danger">管理者</span>
              <%# ***** span：インライン要素 ***** %>
            <% elsif @user.guest? %>
            <%# ***** elsif：前条件が偽の場合の追加分岐 ***** %>
              <span class="badge badge-secondary">ゲスト</span>
              <%# ***** span：インライン要素 ***** %>
            <% else %>
            <%# ***** else：上記条件に当てはまらない場合の分岐 ***** %>
              <span class="badge badge-primary">一般ユーザー</span>
              <%# ***** span：インライン要素 ***** %>
            <% end %>
          </div>
          <%# ***** </div>：divタグ（汎用コンテナ要素）の終了 ***** %>

          <!-- 登録日時 -->
          <p class="text-muted small">
          <%# ***** p：段落要素 ***** %>
            登録日時: <%= @user.created_at.strftime("%Y年%m月%d日") %>
          </p>
          <%# ***** </p>：pタグ（段落要素）の終了 ***** %>

          <!-- アクションボタン（本人のみ表示） -->
          <% if current_user == @user %>
          <%# ***** if：条件を判定する分岐 ***** %>
            <div class="btn-group d-flex gap-2 mt-4" role="group">
            <%# ***** div：汎用コンテナ要素 ***** %>
              <%= link_to "編集", edit_user_path(@user), class: "btn btn-primary btn-sm flex-grow-1" %>
              <%= link_to "ユーザー一覧", users_path, class: "btn btn-outline-secondary btn-sm flex-grow-1" %>
            </div>
            <%# ***** </div>：divタグ（汎用コンテナ要素）の終了 ***** %>

            <%# 退会ボタン %>
            <% if @user.guest? %>
            <%# ***** if：条件を判定する分岐 ***** %>
              <button class="btn btn-outline-danger btn-sm w-100 mt-3" disabled>退会（ゲストは不可）</button>
              <%# ***** button：ボタン要素 ***** %>
            <% else %>
            <%# ***** else：上記条件に当てはまらない場合の分岐 ***** %>
              <%= link_to "退会", user_registration_path, method: :delete,
                          data: { confirm: "本当に退会しますか？この操作は取り消せません。" },
                          class: "btn btn-outline-danger btn-sm w-100 mt-3" %>
            <% end %>
          <% else %>
          <%# ***** else：上記条件に当てはまらない場合の分岐 ***** %>
            <div class="btn-group d-flex gap-2 mt-4" role="group">
            <%# ***** div：汎用コンテナ要素 ***** %>
              <%= link_to "ユーザー一覧", users_path, class: "btn btn-outline-secondary btn-sm flex-grow-1" %>
            </div>
            <%# ***** </div>：divタグ（汎用コンテナ要素）の終了 ***** %>
          <% end %>
        </div>
        <%# ***** </div>：divタグ（汎用コンテナ要素）の終了 ***** %>
      </div>
      <%# ***** </div>：divタグ（汎用コンテナ要素）の終了 ***** %>
    </div>
    <%# ***** </div>：divタグ（汎用コンテナ要素）の終了 ***** %>

    <!-- ===== 投稿一覧 ===== -->
    <div class="col-md-8">
    <%# ***** div：汎用コンテナ要素 ***** %>
      <div class="card shadow-sm">
      <%# ***** div：汎用コンテナ要素 ***** %>
        <div class="card-header bg-primary text-white d-flex align-items-center justify-content-between">
        <%# ***** div：汎用コンテナ要素 ***** %>
          <h5 class="mb-0">
          <%# ***** h5：見出し要素 ***** %>
            <i class="fas fa-file-alt"></i> 
            <%# ***** i：HTML要素 ***** %>
            <% if current_user == @user %>
            <%# ***** if：条件を判定する分岐 ***** %>
              マイ投稿
            <% else %>
            <%# ***** else：上記条件に当てはまらない場合の分岐 ***** %>
              投稿一覧
            <% end %>
            <span class="badge badge-light ml-2"><%= @posts.count %></span>
            <%# ***** span：インライン要素 ***** %>
          </h5>
          <%# ***** </h5>：h5タグ（見出し要素）の終了 ***** %>
          <% if current_user == @user %>
          <%# ***** if：条件を判定する分岐 ***** %>
            <%= link_to "新規投稿", new_post_path, class: "btn btn-sm btn-outline-light" %>
          <% end %>
        </div>
        <%# ***** </div>：divタグ（汎用コンテナ要素）の終了 ***** %>

        <!-- 検索フォーム（パーシャル） -->
        <div class="p-3">
        <%# ***** div：汎用コンテナ要素 ***** %>
          <%= render 'user_posts_search_form' %>
        </div>
        <%# ***** </div>：divタグ（汎用コンテナ要素）の終了 ***** %>

        <div class="card-body">
        <%# ***** div：汎用コンテナ要素 ***** %>
          <% if @posts.any? %>
          <%# ***** if：条件を判定する分岐 ***** %>
            <div class="row">
<%# ***** 一覧ループセクション ***** %>
              <% @posts.each do |post| %>
              <%# ***** each：コレクションを順に処理するループ ***** %>
                <div class="col-12 mb-3">
                <%# ***** div：汎用コンテナ要素 ***** %>
                  <div class="card border-left-primary shadow-sm">
                  <%# ***** div：汎用コンテナ要素 ***** %>
                    <div class="card-body">
                    <%# ***** div：汎用コンテナ要素 ***** %>
                      <div class="d-flex justify-content-between align-items-start mb-2">
                      <%# ***** div：汎用コンテナ要素 ***** %>
                        <div class="flex-grow-1">
                        <%# ***** div：汎用コンテナ要素 ***** %>
                          <h5 class="card-title mb-1">
                          <%# ***** h5：見出し要素 ***** %>
                            <%= link_to post.title, post_path(post), class: "text-decoration-none" %>
                          </h5>
                          <%# ***** </h5>：h5タグ（見出し要素）の終了 ***** %>
                          <!-- ステータスバッジ -->
                          <% if post.status == "published" %>
                          <%# ***** if：条件を判定する分岐 ***** %>
                            <span class="badge badge-success">公開</span>
                            <%# ***** span：インライン要素 ***** %>
                          <% elsif post.status == "draft" %>
                          <%# ***** elsif：前条件が偽の場合の追加分岐 ***** %>
                            <span class="badge badge-warning">下書き</span>
                            <%# ***** span：インライン要素 ***** %>
                          <% end %>
                        </div>
                        <%# ***** </div>：divタグ（汎用コンテナ要素）の終了 ***** %>
                        <!-- 本人の場合は編集・削除ボタンを表示 -->
                        <% if current_user == @user %>
                        <%# ***** if：条件を判定する分岐 ***** %>
                          <div class="ml-3">
                          <%# ***** div：汎用コンテナ要素 ***** %>
                            <%= link_to post_path(post), class: "btn btn-sm btn-outline-primary" do %>
                              <i class="fas fa-eye"></i>
                              <%# ***** i：HTML要素 ***** %>
                            <% end %>
                            <%= link_to edit_post_path(post), class: "btn btn-sm btn-outline-secondary" do %>
                              <i class="fas fa-edit"></i>
                              <%# ***** i：HTML要素 ***** %>
                            <% end %>
                            <%= link_to post_path(post), method: :delete, data: { confirm: "削除しますか？" }, class: "btn btn-sm btn-outline-danger" do %>
                              <i class="fas fa-trash"></i>
                              <%# ***** i：HTML要素 ***** %>
                            <% end %>
                          </div>
                          <%# ***** </div>：divタグ（汎用コンテナ要素）の終了 ***** %>
                        <% end %>
                      </div>
                      <%# ***** </div>：divタグ（汎用コンテナ要素）の終了 ***** %>
                      <p class="card-text text-muted small mb-2">
                      <%# ***** p：段落要素 ***** %>
                        <%= truncate(strip_tags(post.body), length: 150) %>
                      </p>
                      <%# ***** </p>：pタグ（段落要素）の終了 ***** %>
                      <small class="text-muted">
                      <%# ***** small：補足テキスト要素 ***** %>
                        <i class="fas fa-calendar"></i> 更新: <%= post.updated_at.strftime("%Y年%m月%d日 %H:%M") %>
                        <%# ***** i：HTML要素 ***** %>
                      </small>
                      <%# ***** </small>：smallタグ（補足テキスト要素）の終了 ***** %>
                    </div>
                    <%# ***** </div>：divタグ（汎用コンテナ要素）の終了 ***** %>
                  </div>
                  <%# ***** </div>：divタグ（汎用コンテナ要素）の終了 ***** %>
                </div>
                <%# ***** </div>：divタグ（汎用コンテナ要素）の終了 ***** %>
              <% end %>
            </div>
            <%# ***** </div>：divタグ（汎用コンテナ要素）の終了 ***** %>
          <% else %>
          <%# ***** else：上記条件に当てはまらない場合の分岐 ***** %>
            <div class="alert alert-info text-center" role="alert">
            <%# ***** div：汎用コンテナ要素 ***** %>
              <i class="fas fa-info-circle"></i> 投稿がまだありません。
              <%# ***** i：HTML要素 ***** %>
              <% if current_user == @user %>
              <%# ***** if：条件を判定する分岐 ***** %>
                <%= link_to "最初の投稿を作成してみましょう", new_post_path, class: "alert-link" %>
              <% end %>
            </div>
            <%# ***** </div>：divタグ（汎用コンテナ要素）の終了 ***** %>
          <% end %>
        </div>
        <%# ***** </div>：divタグ（汎用コンテナ要素）の終了 ***** %>
      </div>
      <%# ***** </div>：divタグ（汎用コンテナ要素）の終了 ***** %>
    </div>
    <%# ***** </div>：divタグ（汎用コンテナ要素）の終了 ***** %>
  </div>
  <%# ***** </div>：divタグ（汎用コンテナ要素）の終了 ***** %>
</div>
<%# ***** </div>：divタグ（汎用コンテナ要素）の終了 ***** %>

<style>
<%# ***** style：スタイル定義要素 ***** %>
  .card {
    border: none;
    border-radius: 8px;
  }

  .border-left-primary {
    border-left: 4px solid #007bff !important;
  }

  .gap-2 {
    gap: 0.5rem;
  }
</style>
<%# ***** </style>：styleタグ（スタイル定義要素）の終了 ***** %>
