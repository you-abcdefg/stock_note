<%# ***** users/search.html.erb - ユーザー検索結果ページ ***** %>
<%# ***** 【このページの役割】 ***** %>
<%# ***** ユーザーのキーワード検索結果を表示する ***** %>
<%# ***** Ransackで複数条件での検索に対応 ***** %>

<div class="container px-5 px-sm-0 mt-4">
<%# ***** 「<div>」：汎用コンテナ要素 ***** %>
<%# ***** 「class ="【クラス名】"」：要素へスタイルを適用するクラス属性 ***** %>
  <div class="row">
  <%# ***** 「<div>」：汎用コンテナ要素 ***** %>
  <%# ***** 「class ="【クラス名】"」：要素へスタイルを適用するクラス属性 ***** %>
    <div class="col-md-12">
    <%# ***** 「<div>」：汎用コンテナ要素 ***** %>
    <%# ***** 「class ="【クラス名】"」：要素へスタイルを適用するクラス属性 ***** %>
      <h2 class="mb-4">ユーザーを検索</h2>

      <%# ***** 「<h2>【内容】</h2>」：見出し要素 ***** %>
      <%# ***** 検索フォーム ***** %>
      <div class="card mb-4">
      <%# ***** 「<div>」：汎用コンテナ要素 ***** %>
      <%# ***** 「class ="【クラス名】"」：要素へスタイルを適用するクラス属性 ***** %>
        <div class="card-body">
        <%# ***** 「<div>」：汎用コンテナ要素 ***** %>
        <%# ***** 「class ="【クラス名】"」：要素へスタイルを適用するクラス属性 ***** %>
          <%= search_form_for @q, url: search_users_path, local: true do |f| %>
          <%# ***** 「search_form_for @q, url: search_users_path, local: true do |f|」：画面へ値を出力する式 ***** %>
            <div class="form-group">
            <%# ***** 「<div>」：汎用コンテナ要素 ***** %>
            <%# ***** 「class ="【クラス名】"」：要素へスタイルを適用するクラス属性 ***** %>
              <label for="q_name_cont">ユーザー名で検索</label>
              <%# ***** 「<label>【内容】</label>」：フォームラベル要素 ***** %>
              <%# ***** フォーム入力欄セクション ***** %>
              <%= f.search_field :name_cont, class: 'form-control', placeholder: 'ユーザー名キーワード', id: 'q_name_cont' %>
              <%# ***** 「f.search_field :name_cont, class: 'form-control', placeholder: 'ユーザー名キーワード', id: 'q_name_cont'」：画面へ値を出力する式 ***** %>
            </div>
            <%# ***** 「</div>」：divタグ（汎用コンテナ要素）の終了 ***** %>

            <div class="form-group">
            <%# ***** 「<div>」：汎用コンテナ要素 ***** %>
            <%# ***** 「class ="【クラス名】"」：要素へスタイルを適用するクラス属性 ***** %>
              <label for="q_email_cont">メールアドレスで検索</label>
              <%# ***** 「<label>【内容】</label>」：フォームラベル要素 ***** %>
              <%= f.search_field :email_cont, class: 'form-control', placeholder: 'メールアドレス', id: 'q_email_cont' %>
              <%# ***** 「f.search_field :email_cont, class: 'form-control', placeholder: 'メールアドレス', id: 'q_email_cont'」：画面へ値を出力する式 ***** %>
            </div>
            <%# ***** 「</div>」：divタグ（汎用コンテナ要素）の終了 ***** %>

            <div class="form-group">
            <%# ***** 「<div>」：汎用コンテナ要素 ***** %>
            <%# ***** 送信ボタンセクション ***** %>
            <%# ***** 「class ="【クラス名】"」：要素へスタイルを適用するクラス属性 ***** %>
              <%= f.submit '検索', class: 'btn btn-primary' %>
              <%# ***** 「f.submit '検索', class: 'btn btn-primary'」：画面へ値を出力する式 ***** %>
              <%= link_to 'リセット', search_users_path, class: 'btn btn-secondary' %>
              <%# ***** 「link_to 'リセット', search_users_path, class: 'btn btn-secondary'」：画面へ値を出力する式 ***** %>
            </div>
            <%# ***** 「</div>」：divタグ（汎用コンテナ要素）の終了 ***** %>
          <% end %>
          <%# ***** 「end」：ブロック処理を終了するキーワード ***** %>
        </div>
        <%# ***** 「</div>」：divタグ（汎用コンテナ要素）の終了 ***** %>
      </div>
      <%# ***** 「</div>」：divタグ（汎用コンテナ要素）の終了 ***** %>

      <%# ***** 検索結果 ***** %>
      <% if @users.any? %>
      <%# ***** 「if @users.any?」：Ruby式を実行する処理 ***** %>
      <%# ***** 「if (@users.any?)」: @users.any?を判定する条件分岐 ***** %>
      <%# ***** 「if」：条件を判定する分岐 ***** %>
        <div class="alert alert-info" role="alert">
        <%# ***** 「<div>」：汎用コンテナ要素 ***** %>
        <%# ***** 「class ="【クラス名】"」：要素へスタイルを適用するクラス属性 ***** %>
        <%# ***** 「role ="【ロール】"」：要素の役割を示す属性 ***** %>
          検索結果: <%= @users.count %>件
        </div>
        <%# ***** 「</div>」：divタグ（汎用コンテナ要素）の終了 ***** %>

        <div class="row">
        <%# ***** 「<div>」：汎用コンテナ要素 ***** %>
        <%# ***** 一覧ループセクション ***** %>
        <%# ***** 「class ="【クラス名】"」：要素へスタイルを適用するクラス属性 ***** %>
          <% @users.each do |user| %>
          <%# ***** 「@users.each do |user|」：Ruby式を実行する処理 ***** %>
          <%# ***** 「each do |user|」: コレクションを順番に処理し、|user| で現在要素を受け取る反復構文 ***** %>
          <%# ***** 「@users」：処理対象となるコレクション ***** %>
          <%# ***** 「|user|」：各反復で取り出した要素を受け取るブロック引数 ***** %>
          <%# ***** 「each」：コレクションを順に処理するループ ***** %>
            <div class="col-md-6 mb-3">
            <%# ***** 「<div>」：汎用コンテナ要素 ***** %>
            <%# ***** 「class ="【クラス名】"」：要素へスタイルを適用するクラス属性 ***** %>
              <div class="card h-100">
              <%# ***** 「<div>」：汎用コンテナ要素 ***** %>
              <%# ***** 「class ="【クラス名】"」：要素へスタイルを適用するクラス属性 ***** %>
                <div class="card-body">
                <%# ***** 「<div>」：汎用コンテナ要素 ***** %>
                <%# ***** 「class ="【クラス名】"」：要素へスタイルを適用するクラス属性 ***** %>
                  <h5 class="card-title">
                  <%# ***** 「<h5>」：見出し要素 ***** %>
                  <%# ***** 「class ="【クラス名】"」：要素へスタイルを適用するクラス属性 ***** %>
                    <%= link_to(user.name.presence || '未設定', user_path(user)) %>
                    <%# ***** 「link_to(user.name.presence || '未設定', user_path(user))」：画面へ値を出力する式 ***** %>
                  </h5>
                  <%# ***** 「</h5>」：h5タグ（見出し要素）の終了 ***** %>
                  <p class="card-text text-muted">
                  <%# ***** 「<p>」：段落要素 ***** %>
                  <%# ***** 「class ="【クラス名】"」：要素へスタイルを適用するクラス属性 ***** %>
                    <small><%= user.email %></small>
                    <%# ***** 「<small>【内容】</small>」：補足テキスト要素 ***** %>
                  </p>
                  <%# ***** 「</p>」：pタグ（段落要素）の終了 ***** %>
                  <div class="btn-group btn-group-sm" role="group">
                  <%# ***** 「<div>」：汎用コンテナ要素 ***** %>
                  <%# ***** 「class ="【クラス名】"」：要素へスタイルを適用するクラス属性 ***** %>
                  <%# ***** 「role ="【ロール】"」：要素の役割を示す属性 ***** %>
                    <%= link_to 'プロフィール', user_path(user), class: 'btn btn-info' %>
                    <%# ***** 「link_to 'プロフィール', user_path(user), class: 'btn btn-info'」：画面へ値を出力する式 ***** %>
                    <%# ***** 条件分岐セクション ***** %>
                    <% if user_signed_in? && current_user == user %>
                    <%# ***** 「if user_signed_in? && current_user == user」：Ruby式を実行する処理 ***** %>
                    <%# ***** 「if (user_signed_in? && current_user == user)」: user_signed_in? && current_user == userを判定する条件分岐 ***** %>
                    <%# ***** 「user_signed_in?」：Deviseで定義されたログイン状態判定ヘルパー関数 ***** %>
                    <%# ***** 「if」：条件を判定する分岐 ***** %>
                      <%= link_to '編集', edit_user_path(user), class: 'btn btn-warning' %>
                      <%# ***** 「link_to '編集', edit_user_path(user), class: 'btn btn-warning'」：画面へ値を出力する式 ***** %>
                    <% end %>
                    <%# ***** 「end」：ブロック処理を終了するキーワード ***** %>
                  </div>
                  <%# ***** 「</div>」：divタグ（汎用コンテナ要素）の終了 ***** %>
                </div>
                <%# ***** 「</div>」：divタグ（汎用コンテナ要素）の終了 ***** %>
              </div>
              <%# ***** 「</div>」：divタグ（汎用コンテナ要素）の終了 ***** %>
            </div>
            <%# ***** 「</div>」：divタグ（汎用コンテナ要素）の終了 ***** %>
            <%# ***** 「</div>」：divタグ（汎用コンテナ要素）の終了 ***** %>
          <% end %>
          <%# ***** 「end」：ブロック処理を終了するキーワード ***** %>
        </div>
        <%# ***** 「</div>」：divタグ（汎用コンテナ要素）の終了 ***** %>
      <% else %>
      <%# ***** 「else」：上記条件に当てはまらない場合の分岐 ***** %>
      <%# ***** 「else」：上記条件に当てはまらない場合の分岐 ***** %>
        <div class="alert alert-warning" role="alert">
        <%# ***** 「<div>」：汎用コンテナ要素 ***** %>
        <%# ***** 「class ="【クラス名】"」：要素へスタイルを適用するクラス属性 ***** %>
        <%# ***** 「role ="【ロール】"」：要素の役割を示す属性 ***** %>
          検索条件に一致するユーザーが見つかりませんでした。
        </div>
        <%# ***** 「</div>」：divタグ（汎用コンテナ要素）の終了 ***** %>
      <% end %>
      <%# ***** 「end」：ブロック処理を終了するキーワード ***** %>

      <div class="mt-3">
      <%# ***** 「<div>」：汎用コンテナ要素 ***** %>
      <%# ***** 「class ="【クラス名】"」：要素へスタイルを適用するクラス属性 ***** %>
        <%= link_to 'ユーザー一覧に戻る', users_path, class: 'btn btn-secondary' %>
        <%# ***** 「link_to 'ユーザー一覧に戻る', users_path, class: 'btn btn-secondary'」：画面へ値を出力する式 ***** %>
      </div>
      <%# ***** 「</div>」：divタグ（汎用コンテナ要素）の終了 ***** %>
    </div>
    <%# ***** 「</div>」：divタグ（汎用コンテナ要素）の終了 ***** %>
  </div>
  <%# ***** 「</div>」：divタグ（汎用コンテナ要素）の終了 ***** %>
</div>
<%# ***** 「</div>」：divタグ（汎用コンテナ要素）の終了 ***** %>
<%# ***** 「</div>」：divタグ（汎用コンテナ要素）の終了 ***** %>
