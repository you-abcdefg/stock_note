<%# ***** users/mypage のビュー ***** %>
<div class="container mt-5">
<%# ***** 「<div>」：汎用コンテナ要素 ***** %>
<%# ***** 「class ="【クラス名】"」：要素へスタイルを適用するクラス属性 ***** %>
  <div class="row">
  <%# ***** 「<div>」：汎用コンテナ要素 ***** %>
  <%# ***** 「class ="【クラス名】"」：要素へスタイルを適用するクラス属性 ***** %>
    <!-- ===== プロフィール情報 ===== -->
    <div class="col-md-4 mb-4">
    <%# ***** 「<div>」：汎用コンテナ要素 ***** %>
    <%# ***** 「class ="【クラス名】"」：要素へスタイルを適用するクラス属性 ***** %>
      <div class="card shadow-sm">
      <%# ***** 「<div>」：汎用コンテナ要素 ***** %>
      <%# ***** 「class ="【クラス名】"」：要素へスタイルを適用するクラス属性 ***** %>
        <div class="card-body text-center">
        <%# ***** 「<div>」：汎用コンテナ要素 ***** %>
        <%# ***** 「class ="【クラス名】"」：要素へスタイルを適用するクラス属性 ***** %>
          <!-- ユーザーアバター -->
          <div class="mb-3">
          <%# ***** 「<div>」：汎用コンテナ要素 ***** %>
          <%# ***** 「class ="【クラス名】"」：要素へスタイルを適用するクラス属性 ***** %>
            <i class="fas fa-user-circle fa-5x text-primary"></i>
            <%# ***** 「i」：i要素 ***** %>
            <%# ***** i：HTML要素 ***** %>
          </div>
          <%# ***** 「</div>」：divタグ（汎用コンテナ要素）の終了 ***** %>

          <!-- ユーザー情報 -->
          <h3 class="card-title"><%= @user.name %></h3>
          <%# ***** 「<h3>【内容】</h3>」：見出し要素 ***** %>
          <p class="text-muted"><%= @user.email %></p>
          <%# ***** 「<p>【内容】</p>」：段落要素 ***** %>

          <!-- ロール表示 -->
          <div class="mb-3">
          <%# ***** 「<div>」：汎用コンテナ要素 ***** %>
          <%# ***** 条件分岐セクション ***** %>
          <%# ***** 「class ="【クラス名】"」：要素へスタイルを適用するクラス属性 ***** %>
            <% if @user.admin? %>
            <%# ***** 「if @user.admin?」：Ruby式を実行する処理 ***** %>
            <%# ***** 「if (@user.admin?)」: @user.admin?を判定する条件分岐 ***** %>
            <%# ***** 「if」：条件を判定する分岐 ***** %>
              <span class="badge badge-danger">管理者</span>
              <%# ***** 「<span>【内容】</span>」：インライン要素 ***** %>
            <% elsif @user.guest? %>
            <%# ***** 「elsif @user.guest?」：Ruby式を実行する処理 ***** %>
            <%# ***** 「elsif (@user.guest?)」: 前条件が偽の場合に@user.guest?を追加判定する分岐 ***** %>
            <%# ***** 「elsif」：前条件が偽の場合の追加分岐 ***** %>
              <span class="badge badge-secondary">ゲスト</span>
              <%# ***** 「<span>【内容】</span>」：インライン要素 ***** %>
            <% else %>
            <%# ***** 「else」：上記条件に当てはまらない場合の分岐 ***** %>
            <%# ***** 「else」：上記条件に当てはまらない場合の分岐 ***** %>
              <span class="badge badge-primary">一般ユーザー</span>
              <%# ***** 「<span>【内容】</span>」：インライン要素 ***** %>
            <% end %>
            <%# ***** 「end」：ブロック処理を終了するキーワード ***** %>
          </div>
          <%# ***** 「</div>」：divタグ（汎用コンテナ要素）の終了 ***** %>

          <!-- 登録日時 -->
          <p class="text-muted small">
          <%# ***** 「<p>」：段落要素 ***** %>
          <%# ***** 「class ="【クラス名】"」：要素へスタイルを適用するクラス属性 ***** %>
            登録日時: <%= @user.created_at.strftime("%Y年%m月%d日") %>
          </p>
          <%# ***** 「</p>」：pタグ（段落要素）の終了 ***** %>

          <!-- アクションボタン -->
          <div class="btn-group d-flex gap-2 mt-4" role="group">
          <%# ***** 「<div>」：汎用コンテナ要素 ***** %>
          <%# ***** 「class ="【クラス名】"」：要素へスタイルを適用するクラス属性 ***** %>
          <%# ***** 「role ="【ロール】"」：要素の役割を示す属性 ***** %>
            <%= link_to "編集", edit_user_path(@user), class: "btn btn-primary btn-sm flex-grow-1" %>
            <%# ***** 「link_to "編集", edit_user_path(@user), class: "btn btn-primary btn-sm flex-grow-1"」：画面へ値を出力する式 ***** %>
            <%= link_to "ユーザー一覧", users_path, class: "btn btn-outline-secondary btn-sm flex-grow-1" %>
            <%# ***** 「link_to "ユーザー一覧", users_path, class: "btn btn-outline-secondary btn-sm flex-grow-1"」：画面へ値を出力する式 ***** %>
          </div>
          <%# ***** 「</div>」：divタグ（汎用コンテナ要素）の終了 ***** %>

          <%# ***** 退会ボタンセクション ***** %>
          <% if @user.guest? %>
          <%# ***** 「if @user.guest?」：Ruby式を実行する処理 ***** %>
          <%# ***** 「if (@user.guest?)」: @user.guest?を判定する条件分岐 ***** %>
          <%# ***** 「if」：条件を判定する分岐 ***** %>
            <button class="btn btn-outline-danger btn-sm w-100 mt-3" disabled>退会（ゲストは不可）</button>
            <%# ***** 「<button>【内容】</button>」：ボタン要素 ***** %>
          <% else %>
          <%# ***** 「else」：上記条件に当てはまらない場合の分岐 ***** %>
          <%# ***** 「else」：上記条件に当てはまらない場合の分岐 ***** %>
            <%= link_to "退会", user_registration_path, method: :delete,
                        data: { confirm: "本当に退会しますか？この操作は取り消せません。" },
                        class: "btn btn-outline-danger btn-sm w-100 mt-3" %>
          <% end %>
          <%# ***** 「end」：ブロック処理を終了するキーワード ***** %>
        </div>
        <%# ***** 「</div>」：divタグ（汎用コンテナ要素）の終了 ***** %>
      </div>
      <%# ***** 「</div>」：divタグ（汎用コンテナ要素）の終了 ***** %>
    </div>
    <%# ***** 「</div>」：divタグ（汎用コンテナ要素）の終了 ***** %>
    <%# ***** 「</div>」：divタグ（汎用コンテナ要素）の終了 ***** %>

    <!-- ===== マイページ投稿一覧 ===== -->
    <div class="col-md-8">
    <%# ***** 「<div>」：汎用コンテナ要素 ***** %>
    <%# ***** 「class ="【クラス名】"」：要素へスタイルを適用するクラス属性 ***** %>
      <div class="card shadow-sm">
      <%# ***** 「<div>」：汎用コンテナ要素 ***** %>
      <%# ***** 「class ="【クラス名】"」：要素へスタイルを適用するクラス属性 ***** %>
        <div class="card-header bg-primary text-white d-flex align-items-center justify-content-between">
        <%# ***** 「<div>」：汎用コンテナ要素 ***** %>
        <%# ***** 「class ="【クラス名】"」：要素へスタイルを適用するクラス属性 ***** %>
          <h5 class="mb-0">
          <%# ***** 「<h5>」：見出し要素 ***** %>
          <%# ***** 「class ="【クラス名】"」：要素へスタイルを適用するクラス属性 ***** %>
            <i class="fas fa-file-alt"></i> マイ投稿
            <%# ***** i：HTML要素 ***** %>
            <span class="badge badge-light ml-2"><%= @posts.count %></span>
            <%# ***** 「<span>【内容】</span>」：インライン要素 ***** %>
          </h5>
          <%# ***** 「</h5>」：h5タグ（見出し要素）の終了 ***** %>
          <%= link_to "新規投稿", new_post_path, class: "btn btn-sm btn-outline-light" %>
          <%# ***** 「link_to "新規投稿", new_post_path, class: "btn btn-sm btn-outline-light"」：画面へ値を出力する式 ***** %>
        </div>
        <%# ***** 「</div>」：divタグ（汎用コンテナ要素）の終了 ***** %>

        <div class="card-body">
        <%# ***** 「<div>」：汎用コンテナ要素 ***** %>
        <%# ***** 「class ="【クラス名】"」：要素へスタイルを適用するクラス属性 ***** %>
          <% if @posts.any? %>
          <%# ***** 「if @posts.any?」：Ruby式を実行する処理 ***** %>
          <%# ***** 「if (@posts.any?)」: @posts.any?を判定する条件分岐 ***** %>
          <%# ***** 「if」：条件を判定する分岐 ***** %>
            <div class="list-group list-group-flush">
            <%# ***** 「<div>」：汎用コンテナ要素 ***** %>
            <%# ***** 一覧ループセクション ***** %>
            <%# ***** 「class ="【クラス名】"」：要素へスタイルを適用するクラス属性 ***** %>
              <% @posts.each do |post| %>
              <%# ***** 「@posts.each do |post|」：Ruby式を実行する処理 ***** %>
              <%# ***** 「each do |post|」: コレクションを順番に処理し、|post| で現在要素を受け取る反復構文 ***** %>
              <%# ***** 「@posts」：処理対象となるコレクション ***** %>
              <%# ***** 「|post|」：各反復で取り出した要素を受け取るブロック引数 ***** %>
              <%# ***** 「each」：コレクションを順に処理するループ ***** %>
                <div class="list-group-item d-flex justify-content-between align-items-center">
                <%# ***** 「<div>」：汎用コンテナ要素 ***** %>
                <%# ***** 「class ="【クラス名】"」：要素へスタイルを適用するクラス属性 ***** %>
                  <div class="flex-grow-1">
                  <%# ***** 「<div>」：汎用コンテナ要素 ***** %>
                  <%# ***** 「class ="【クラス名】"」：要素へスタイルを適用するクラス属性 ***** %>
                    <div class="d-flex align-items-center mb-2">
                    <%# ***** 「<div>」：汎用コンテナ要素 ***** %>
                    <%# ***** 「class ="【クラス名】"」：要素へスタイルを適用するクラス属性 ***** %>
                      <h6 class="mb-0">
                      <%# ***** 「<h6>」：見出し要素 ***** %>
                      <%# ***** 「class ="【クラス名】"」：要素へスタイルを適用するクラス属性 ***** %>
                        <%= link_to post.title, post_path(post), class: "text-decoration-none" %>
                        <%# ***** 「link_to post.title, post_path(post), class: "text-decoration-none"」：画面へ値を出力する式 ***** %>
                      </h6>
                      <%# ***** 「</h6>」：h6タグ（見出し要素）の終了 ***** %>
                      <!-- ステータスバッジ -->
                      <% if post.status == "published" %>
                      <%# ***** 「if post.status == "published"」：Ruby式を実行する処理 ***** %>
                      <%# ***** 「if (post.status == "published")」: post.status == "published"を判定する条件分岐 ***** %>
                      <%# ***** 「if」：条件を判定する分岐 ***** %>
                        <span class="badge badge-success ml-2">公開</span>
                        <%# ***** 「<span>【内容】</span>」：インライン要素 ***** %>
                      <% elsif post.status == "draft" %>
                      <%# ***** 「elsif post.status == "draft"」：Ruby式を実行する処理 ***** %>
                      <%# ***** 「elsif (post.status == "draft")」: 前条件が偽の場合にpost.status == "draft"を追加判定する分岐 ***** %>
                      <%# ***** 「elsif」：前条件が偽の場合の追加分岐 ***** %>
                        <span class="badge badge-warning ml-2">下書き</span>
                        <%# ***** 「<span>【内容】</span>」：インライン要素 ***** %>
                      <% end %>
                      <%# ***** 「end」：ブロック処理を終了するキーワード ***** %>
                    </div>
                    <%# ***** 「</div>」：divタグ（汎用コンテナ要素）の終了 ***** %>
                    <p class="text-muted small mb-1">
                    <%# ***** 「<p>」：段落要素 ***** %>
                    <%# ***** 「class ="【クラス名】"」：要素へスタイルを適用するクラス属性 ***** %>
                      <%= truncate(strip_tags(post.content), length: 100) %>
                      <%# ***** 「truncate(strip_tags(post.content), length: 100)」：画面へ値を出力する式 ***** %>
                    </p>
                    <%# ***** 「</p>」：pタグ（段落要素）の終了 ***** %>
                    <small class="text-muted">
                    <%# ***** 「<small>」：補足テキスト要素 ***** %>
                    <%# ***** 「class ="【クラス名】"」：要素へスタイルを適用するクラス属性 ***** %>
                      更新: <%= post.updated_at.strftime("%Y年%m月%d日 %H:%M") %>
                    </small>
                    <%# ***** 「</small>」：smallタグ（補足テキスト要素）の終了 ***** %>
                  </div>
                  <%# ***** 「</div>」：divタグ（汎用コンテナ要素）の終了 ***** %>
                  <div class="ml-3">
                  <%# ***** 「<div>」：汎用コンテナ要素 ***** %>
                  <%# ***** 「class ="【クラス名】"」：要素へスタイルを適用するクラス属性 ***** %>
                    <%= link_to post_path(post), class: "btn btn-sm btn-outline-primary" do %>
                    <%# ***** 「link_to post_path(post), class: "btn btn-sm btn-outline-primary" do」：画面へ値を出力する式 ***** %>
                      <i class="fas fa-eye"></i>
                      <%# ***** 「i」：i要素 ***** %>
                      <%# ***** i：HTML要素 ***** %>
                    <% end %>
                    <%# ***** 「end」：ブロック処理を終了するキーワード ***** %>
                    <%= link_to edit_post_path(post), class: "btn btn-sm btn-outline-secondary" do %>
                    <%# ***** 「link_to edit_post_path(post), class: "btn btn-sm btn-outline-secondary" do」：画面へ値を出力する式 ***** %>
                      <i class="fas fa-edit"></i>
                      <%# ***** 「i」：i要素 ***** %>
                      <%# ***** i：HTML要素 ***** %>
                    <% end %>
                    <%# ***** 「end」：ブロック処理を終了するキーワード ***** %>
                    <%= link_to post_path(post), method: :delete, data: { confirm: "削除しますか？" }, class: "btn btn-sm btn-outline-danger" do %>
                    <%# ***** 「link_to post_path(post), method: :delete, data: { confirm: "削除しますか？" }, class: "btn btn-sm btn-outline-danger" do」：画面へ値を出力する式 ***** %>
                      <i class="fas fa-trash"></i>
                      <%# ***** 「i」：i要素 ***** %>
                      <%# ***** i：HTML要素 ***** %>
                    <% end %>
                    <%# ***** 「end」：ブロック処理を終了するキーワード ***** %>
                  </div>
                  <%# ***** 「</div>」：divタグ（汎用コンテナ要素）の終了 ***** %>
                </div>
                <%# ***** 「</div>」：divタグ（汎用コンテナ要素）の終了 ***** %>
                <%# ***** 「</div>」：divタグ（汎用コンテナ要素）の終了 ***** %>
              <% end %>
              <%# ***** 「end」：ブロック処理を終了するキーワード ***** %>
            </div>
            <%# ***** 「</div>」：divタグ（汎用コンテナ要素）の終了 ***** %>
          <% else %>
          <%# ***** 「else」：上記条件に当てはまらない場合の分岐 ***** %>
          <%# ***** 「else」：上記条件に当てはまらない場合の分岐 ***** %>
            <div class="alert alert-info text-center" role="alert">
            <%# ***** 「<div>」：汎用コンテナ要素 ***** %>
            <%# ***** 「class ="【クラス名】"」：要素へスタイルを適用するクラス属性 ***** %>
            <%# ***** 「role ="【ロール】"」：要素の役割を示す属性 ***** %>
              <i class="fas fa-info-circle"></i> 投稿がまだありません。
              <%# ***** i：HTML要素 ***** %>
              <%= link_to "最初の投稿を作成してみましょう", new_post_path, class: "alert-link" %>
              <%# ***** 「link_to "最初の投稿を作成してみましょう", new_post_path, class: "alert-link"」：画面へ値を出力する式 ***** %>
            </div>
            <%# ***** 「</div>」：divタグ（汎用コンテナ要素）の終了 ***** %>
          <% end %>
          <%# ***** 「end」：ブロック処理を終了するキーワード ***** %>
        </div>
        <%# ***** 「</div>」：divタグ（汎用コンテナ要素）の終了 ***** %>
      </div>
      <%# ***** 「</div>」：divタグ（汎用コンテナ要素）の終了 ***** %>
    </div>
    <%# ***** 「</div>」：divタグ（汎用コンテナ要素）の終了 ***** %>
  </div>
  <%# ***** 「</div>」：divタグ（汎用コンテナ要素）の終了 ***** %>
</div>
<%# ***** 「</div>」：divタグ（汎用コンテナ要素）の終了 ***** %>
<%# ***** 「</div>」：divタグ（汎用コンテナ要素）の終了 ***** %>

<style>
<%# ***** 「<style>」：スタイル定義要素 ***** %>
  .card {
    border: none;
    border-radius: 8px;
  }

  .list-group-item {
    border: none;
    border-bottom: 1px solid #e9ecef;
    padding: 1.25rem 0;
  }

  .list-group-item:last-child {
    border-bottom: none;
  }

  .gap-2 {
    gap: 0.5rem;
  }
</style>
<%# ***** 「</style>」：styleタグ（スタイル定義要素）の終了 ***** %>
