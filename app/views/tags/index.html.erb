<%# ***** tags/index.html.erb - タグ一覧ページ ***** %>
<%# ***** 【このページの役割】 ***** %>
<%# ***** すべてのタグと、それぞれに付けられた投稿数を表示 ***** %>
<%# ***** ユーザーがタグをクリックして関連投稿を検索できる ***** %>

<div class="container px-5 px-sm-0 mt-4">
<%# ***** div：汎用コンテナ要素 ***** %>
  <div class="row">
  <%# ***** div：汎用コンテナ要素 ***** %>
    <div class="col-md-12">
    <%# ***** div：汎用コンテナ要素 ***** %>
      <h2 class="mb-4">タグ一覧</h2>

    <%# ***** 条件分岐セクション ***** %>
      <% if @tags.any? %>
        <%# ***** タグの詳細テーブル表示 ***** %>
        <div class="table-responsive">
<%# ***** 一覧テーブルセクション ***** %>
          <table class="table table-hover">
          <%# ***** table：テーブル要素 ***** %>
            <thead>
            <%# ***** thead：テーブル見出し要素 ***** %>
              <tr>
              <%# ***** tr：テーブル行要素 ***** %>
                <th>タグ名</th>
                <%# ***** th：テーブル見出しセル要素 ***** %>
                <th>使用数</th>
                <%# ***** th：テーブル見出しセル要素 ***** %>
                <th>操作</th>
                <%# ***** th：テーブル見出しセル要素 ***** %>
              </tr>
              <%# ***** </tr>：trタグ（テーブル行要素）の終了 ***** %>
            </thead>
            <%# ***** </thead>：theadタグ（テーブル見出し要素）の終了 ***** %>
            <tbody>
<%# ***** 一覧ループセクション ***** %>
              <% @tags.each do |tag| %>
              <%# ***** each：コレクションを順に処理するループ ***** %>
                <tr>
                <%# ***** tr：テーブル行要素 ***** %>
                  <td><strong><%= tag.name %></strong></td>
                  <%# ***** td：テーブルデータセル要素 ***** %>
                  <td>
                  <%# ***** td：テーブルデータセル要素 ***** %>
                    <span class="badge badge-info"><%= tag.taggings_count %>件</span>
                    <%# ***** span：インライン要素 ***** %>
                  </td>
                  <%# ***** </td>：tdタグ（テーブルデータセル要素）の終了 ***** %>
                  <td>
                  <%# ***** td：テーブルデータセル要素 ***** %>
                    <%= link_to '投稿を見る', tagged_posts_path(tag.name), class: 'btn btn-sm btn-primary' %>
                  </td>
                  <%# ***** </td>：tdタグ（テーブルデータセル要素）の終了 ***** %>
                </tr>
                <%# ***** </tr>：trタグ（テーブル行要素）の終了 ***** %>
              <% end %>
            </tbody>
            <%# ***** </tbody>：tbodyタグ（テーブル本文要素）の終了 ***** %>
          </table>
          <%# ***** </table>：tableタグ（テーブル要素）の終了 ***** %>
        </div>
        <%# ***** </div>：divタグ（汎用コンテナ要素）の終了 ***** %>
      <% else %>
      <%# ***** else：上記条件に当てはまらない場合の分岐 ***** %>
        <div class="alert alert-warning" role="alert">
        <%# ***** div：汎用コンテナ要素 ***** %>
          まだタグが登録されていません。
        </div>
        <%# ***** </div>：divタグ（汎用コンテナ要素）の終了 ***** %>
      <% end %>

      <div class="mt-3">
      <%# ***** div：汎用コンテナ要素 ***** %>
        <%= link_to '投稿一覧に戻る', posts_path, class: 'btn btn-secondary' %>
      </div>
      <%# ***** </div>：divタグ（汎用コンテナ要素）の終了 ***** %>
    </div>
    <%# ***** </div>：divタグ（汎用コンテナ要素）の終了 ***** %>
  </div>
  <%# ***** </div>：divタグ（汎用コンテナ要素）の終了 ***** %>
</div>
<%# ***** </div>：divタグ（汎用コンテナ要素）の終了 ***** %>
