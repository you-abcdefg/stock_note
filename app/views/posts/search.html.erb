<%# ***** posts/search.html.erb - 投稿検索結果ページ ***** %>
<%# ***** 「# ***** posts/search.html.erb - 投稿検索結果ページ *****」：出力式/式 ***** %>
<%# ***** 【このページの役割】 ***** %>
<%# ***** 「# ***** 【このページの役割】 *****」：出力式/式 ***** %>
<%# ***** 投稿キーワード検索の結果を表示する ***** %>
<%# ***** 「# ***** 投稿キーワード検索の結果を表示する *****」：出力式/式 ***** %>
<%# ***** Ransackで複数条件での検索に対応 ***** %>
<%# ***** 「# ***** Ransackで複数条件での検索に対応 *****」：出力式/式 ***** %>

<div class="container px-5 px-sm-0 mt-4">
<%# ***** 「<div>」：HTMLタグ ***** %>
<%# ***** 「<div>」：汎用コンテナ要素 ***** %>
<%# ***** 「# ***** 「<div>」：汎用コンテナ要素 *****」：出力式/式 ***** %>
<%# ***** 「class ="【クラス名】"」：要素へスタイルを適用するクラス属性 ***** %>
<%# ***** 「# ***** 「class ="【クラス名】"」：要素へスタイルを適用するクラス属性 *****」：出力式/式 ***** %>
  <div class="row">
  <%# ***** 「<div>」：汎用コンテナ要素 ***** %>
  <%# ***** 「class ="【クラス名】"」：要素へスタイルを適用するクラス属性 ***** %>
    <div class="col-md-12">
    <%# ***** 「<div>」：汎用コンテナ要素 ***** %>
    <%# ***** 「class ="【クラス名】"」：要素へスタイルを適用するクラス属性 ***** %>
      <h2 class="mb-4">投稿を検索</h2>
      <%# ***** 「<h2>【内容】</h2>」：見出し要素 ***** %>
      <%# ***** 「class ="【クラス名】"」：要素へスタイルを適用するクラス属性 ***** %>

      <%# ***** 「<h2>【内容】</h2>」：見出し要素 ***** %>
      <%# ***** 検索フォーム ***** %>
      <%= render 'search_form' %>
      <%# ***** 「render 'search_form'」：画面へ値を出力する式 ***** %>
      <%# ***** 検索結果 ***** %>
      <% if @posts.any? %>
      <%# ***** 「if 【条件式】」：【条件式】が true の場合、以下の処理を実行する ***** %>
        <div class="alert alert-info" role="alert">
        <%# ***** 「<div>」：汎用コンテナ要素 ***** %>
        <%# ***** 「class ="【クラス名】"」：要素へスタイルを適用するクラス属性 ***** %>
        <%# ***** 「role ="【ロール】"」：要素の役割を示す属性 ***** %>
          検索結果: <%= @posts.count %>件
        </div>
        <%# ***** 「<div>【内容】</div>」：要素をまとめるための汎用コンテナ ***** %>

        <%# ***** 「<div>【内容】</div>」：要素をまとめるための汎用コンテナ ***** %>
        <%# ***** 一覧テーブルセクション ***** %>
        <table class="table table-hover">
        <%# ***** 「<table>」：テーブル要素 ***** %>
        <%# ***** 「class ="【クラス名】"」：要素へスタイルを適用するクラス属性 ***** %>
          <thead>
          <%# ***** 「<thead>」：テーブル見出し要素 ***** %>
            <tr>
            <%# ***** 「<tr>」：テーブル行要素 ***** %>
              <th>投稿日時</th>
              <%# ***** 「<th>【内容】</th>」：テーブル見出しセル要素 ***** %>
              <th>ユーザー</th>
              <%# ***** 「<th>【内容】</th>」：テーブル見出しセル要素 ***** %>
              <th>タイトル</th>
              <%# ***** 「<th>【内容】</th>」：テーブル見出しセル要素 ***** %>
              <th>ステータス</th>
              <%# ***** 「<th>【内容】</th>」：テーブル見出しセル要素 ***** %>
              <th>タグ</th>
              <%# ***** 「<th>【内容】</th>」：テーブル見出しセル要素 ***** %>
              <th>操作</th>
              <%# ***** 「<th>【内容】</th>」：テーブル見出しセル要素 ***** %>
            </tr>
            <%# ***** 「<tr>【内容】</tr>」：表の行要素 ***** %>
          </thead>
          <%# ***** 「<thead>【内容】</thead>」：表ヘッダー要素 ***** %>
          <tbody>
          <%# ***** 「<tbody>」：テーブル本文要素 ***** %>
          <%# ***** 一覧ループセクション ***** %>
            <% @posts.each do |post| %>
            <%# ***** 「@posts.each do |post|」：Ruby式を実行する処理 ***** %>
            <%# ***** 「each do |post|」: コレクションを順番に処理し、|post| で現在要素を受け取る反復構文 ***** %>
            <%# ***** 「@posts」：処理対象となるコレクション ***** %>
            <%# ***** 「|post|」：各反復で取り出した要素を受け取るブロック引数 ***** %>
            <%# ***** 「each」：コレクションを順に処理するループ ***** %>
              <tr>
              <%# ***** 「<tr>」：テーブル行要素 ***** %>
                <td><%= post.created_at.strftime('%Y/%m/%d %H:%M') %></td>
                <%# ***** 「<td>【内容】</td>」：テーブルデータセル要素 ***** %>
                <td><%= link_to(post.user.name.presence || '未設定', user_path(post.user)) %></td>
                <%# ***** 「<td>【内容】</td>」：テーブルデータセル要素 ***** %>
                <td><%= link_to post.title, post_path(post) %></td>
                <%# ***** 「<td>【内容】</td>」：テーブルデータセル要素 ***** %>
                <td>
                <%# ***** 「<td>」：テーブルデータセル要素 ***** %>
<%# ***** 条件分岐セクション ***** %>
<%# ***** 「# ***** 条件分岐セクション *****」：出力式/式 ***** %>
                  <% if post.published? %>
                  <%# ***** 「if 【条件式】」：【条件式】が true の場合、以下の処理を実行する ***** %>
                    <span class="badge badge-success">公開</span>
                    <%# ***** 「<span>【内容】</span>」：インライン要素 ***** %>
                    <%# ***** 「class ="【クラス名】"」：要素へスタイルを適用するクラス属性 ***** %>
                  <% else %>
                  <%# ***** 「else」：上記条件に当てはまらない場合の分岐 ***** %>
                    <span class="badge badge-secondary">下書き</span>
                    <%# ***** 「<span>【内容】</span>」：インライン要素 ***** %>
                    <%# ***** 「class ="【クラス名】"」：要素へスタイルを適用するクラス属性 ***** %>
                  <% end %>
                  <%# ***** 「end」：ブロック処理を終了するキーワード ***** %>
                </td>
                <%# ***** 「<td>【内容】</td>」：表のデータセル要素 ***** %>
                <td>
                <%# ***** 「<td>」：テーブルデータセル要素 ***** %>
                  <% post.tags.each do |tag| %>
                  <%# ***** 「post.tags.each do |tag|」：Ruby式を実行する処理 ***** %>
                  <%# ***** 「each do |tag|」: コレクションを順番に処理し、|tag| で現在要素を受け取る反復構文 ***** %>
                  <%# ***** 「post.tags」：処理対象となるコレクション ***** %>
                  <%# ***** 「|tag|」：各反復で取り出した要素を受け取るブロック引数 ***** %>
                  <%# ***** 「each」：コレクションを順に処理するループ ***** %>
                    <%= link_to tag.name, tagged_posts_path(tag.name), class: 'badge badge-info' %>
                    <%# ***** 「link_to tag.name, tagged_posts_path(tag.name), class: 'badge badge-info'」：画面へ値を出力する式 ***** %>
                  <% end %>
                  <%# ***** 「end」：ブロック処理を終了するキーワード ***** %>
                </td>
                <%# ***** 「<td>【内容】</td>」：表のデータセル要素 ***** %>
                <td>
                <%# ***** 「<td>」：テーブルデータセル要素 ***** %>
                  <div class="btn-group btn-group-sm" role="group">
                  <%# ***** 「<div>」：汎用コンテナ要素 ***** %>
                  <%# ***** 「class ="【クラス名】"」：要素へスタイルを適用するクラス属性 ***** %>
                  <%# ***** 「role ="【ロール】"」：要素の役割を示す属性 ***** %>
                    <%= link_to '詳細', post_path(post), class: 'btn btn-info' %>
                    <%# ***** 「link_to '詳細', post_path(post), class: 'btn btn-info'」：画面へ値を出力する式 ***** %>
                    <% if user_signed_in? && (current_user == post.user || current_user.admin?) %>
                    <%# ***** 「if 【条件式】」：【条件式】が true の場合、以下の処理を実行する ***** %>
                    <%# ***** 「user_signed_in?」：Deviseで定義されたログイン状態判定ヘルパー関数 ***** %>
                    <%# ***** 「if 【条件式】」：【条件式】が true の場合、以下の処理を実行する ***** %>
                    <%# ***** 「user_signed_in?」：Deviseのログイン状態を判定するヘルパーメソッド（true / false を返す） ***** %>
                      <%= link_to '編集', edit_post_path(post), class: 'btn btn-warning' %>
                      <%# ***** 「link_to '編集', edit_post_path(post), class: 'btn btn-warning'」：画面へ値を出力する式 ***** %>
                      <%= link_to '削除', post_path(post), method: :delete, data: { confirm: '削除してもよろしいですか？' }, class: 'btn btn-danger' %>
                      <%# ***** 「link_to '削除', post_path(post), method: :delete, data: { confirm: '削除してもよろしいですか？' }, class: 'btn btn-danger'」：画面へ値を出力する式 ***** %>
                    <% end %>
                    <%# ***** 「end」：ブロック処理を終了するキーワード ***** %>
                  </div>
                  <%# ***** 「<div>【内容】</div>」：要素をまとめるための汎用コンテナ ***** %>
                </td>
                <%# ***** 「<td>【内容】</td>」：表のデータセル要素 ***** %>
              </tr>
              <%# ***** 「<tr>【内容】</tr>」：表の行要素 ***** %>
            <% end %>
            <%# ***** 「end」：ブロック処理を終了するキーワード ***** %>
          </tbody>
          <%# ***** 「<tbody>【内容】</tbody>」：表本体要素 ***** %>
        </table>
        <%# ***** 「<table>【内容】</table>」：表要素 ***** %>
      <% else %>
      <%# ***** 「else」：上記条件に当てはまらない場合の分岐 ***** %>
        <div class="alert alert-warning" role="alert">
        <%# ***** 「<div>」：汎用コンテナ要素 ***** %>
        <%# ***** 「class ="【クラス名】"」：要素へスタイルを適用するクラス属性 ***** %>
        <%# ***** 「role ="【ロール】"」：要素の役割を示す属性 ***** %>
          検索条件に一致する投稿が見つかりませんでした。
        </div>
        <%# ***** 「<div>【内容】</div>」：要素をまとめるための汎用コンテナ ***** %>
      <% end %>
      <%# ***** 「end」：ブロック処理を終了するキーワード ***** %>

      <div class="mt-3">
      <%# ***** 「<div>」：汎用コンテナ要素 ***** %>
      <%# ***** 「class ="【クラス名】"」：要素へスタイルを適用するクラス属性 ***** %>
        <%= link_to '投稿一覧に戻る', posts_path, class: 'btn btn-secondary' %>
        <%# ***** 「link_to '投稿一覧に戻る', posts_path, class: 'btn btn-secondary'」：画面へ値を出力する式 ***** %>
      </div>
      <%# ***** 「<div>【内容】</div>」：要素をまとめるための汎用コンテナ ***** %>
    </div>
    <%# ***** 「<div>【内容】</div>」：要素をまとめるための汎用コンテナ ***** %>
  </div>
  <%# ***** 「<div>【内容】</div>」：要素をまとめるための汎用コンテナ ***** %>
</div>
<%# ***** 「<div>【内容】</div>」：要素をまとめるための汎用コンテナ ***** %>
<%# ***** 「# ***** 「<div>【内容】</div>」：要素をまとめるための汎用コンテナ *****」：出力式/式 ***** %>