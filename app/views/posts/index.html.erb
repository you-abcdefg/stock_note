<%# ***** posts/index.html.erb - 投稿一覧ページ ***** %>
<%# ***** 【このページの役割】 ***** %>
<%# ***** すべての公開済み投稿を一覧表示する ***** %>
<%# ***** ログイン中のユーザーには編集・削除ボタンも表示 ***** %>

<div class="container px-5 px-sm-0 mt-4">
<%# ***** 「<div>」：汎用コンテナ要素 ***** %>
<%# ***** 「class ="【クラス名】"」：要素へスタイルを適用するクラス属性 ***** %>
  <div class="row">
  <%# ***** 「<div>」：汎用コンテナ要素 ***** %>
  <%# ***** 「class ="【クラス名】"」：要素へスタイルを適用するクラス属性 ***** %>
    <div class="col-md-12">
    <%# ***** 「<div>」：汎用コンテナ要素 ***** %>
    <%# ***** 「class ="【クラス名】"」：要素へスタイルを適用するクラス属性 ***** %>
      <div class="d-flex justify-content-between align-items-center mb-3">
      <%# ***** 「<div>」：汎用コンテナ要素 ***** %>
      <%# ***** 「class ="【クラス名】"」：要素へスタイルを適用するクラス属性 ***** %>
        <h2>投稿一覧</h2>
        <%# ***** 「<h2>【内容】</h2>」：見出し要素 ***** %>
        <div>
        <%# ***** 「<div>」：汎用コンテナ要素 ***** %>
        <%# ***** 条件分岐セクション ***** %>
          <% if user_signed_in? %>
          <%# ***** 「if user_signed_in?」：Ruby式を実行する処理 ***** %>
          <%# ***** 「if (user_signed_in?)」: user_signed_in?を判定する条件分岐 ***** %>
          <%# ***** 「user_signed_in?」：Deviseで定義されたログイン状態判定ヘルパー関数 ***** %>
          <%# ***** 「if」：条件を判定する分岐 ***** %>
            <%= link_to "新規作成", new_post_path, class: "btn btn-primary" %>
            <%# ***** 「link_to "新規作成", new_post_path, class: "btn btn-primary"」：画面へ値を出力する式 ***** %>
          <% end %>
          <%# ***** 「end」：ブロック処理を終了するキーワード ***** %>
        </div>
        <%# ***** 「</div>」：divタグ（汎用コンテナ要素）の終了 ***** %>
      </div>
      <%# ***** 「</div>」：divタグ（汎用コンテナ要素）の終了 ***** %>
      <%# ***** 「</div>」：divタグ（汎用コンテナ要素）の終了 ***** %>

      <% unless user_signed_in? %>
      <%# ***** 「unless user_signed_in?」：Ruby式を実行する処理 ***** %>
      <%# ***** 「unless (user_signed_in?)」: user_signed_in?が偽の場合に処理する条件分岐 ***** %>
      <%# ***** 「user_signed_in?」：Deviseで定義されたログイン状態判定ヘルパー関数 ***** %>
      <%# ***** 「unless」：条件が偽の場合に処理する分岐 ***** %>
        <div class="alert alert-info mt-3" role="alert">
        <%# ***** 「<div>」：汎用コンテナ要素 ***** %>
        <%# ***** 「class ="【クラス名】"」：要素へスタイルを適用するクラス属性 ***** %>
        <%# ***** 「role ="【ロール】"」：要素の役割を示す属性 ***** %>
          新規投稿を作成するには、ログインが必要です。
        </div>
        <%# ***** 「</div>」：divタグ（汎用コンテナ要素）の終了 ***** %>
      <% end %>
      <%# ***** 「end」：Ruby式を実行する処理 ***** %>
      <%# ***** 検索フォーム ***** %>
      <%= render 'search_form' %>
      <%# ***** 「render 'search_form'」：画面へ値を出力する式 ***** %>
      <%# ***** Bootstrap のテーブルで一覧表示 ***** %>
    <%# ***** 一覧テーブルセクション ***** %>
      <table class="table table-hover">
      <%# ***** 「<table>」：テーブル要素 ***** %>
      <%# ***** 「class ="【クラス名】"」：要素へスタイルを適用するクラス属性 ***** %>
        <thead>
        <%# ***** 「<thead>」：テーブル見出し要素 ***** %>
          <tr>
          <%# ***** 「<tr>」：テーブル行要素 ***** %>
            <th>投稿日時</th>
            <%# ***** 「<th>【内容】</th>」：テーブル見出しセル要素 ***** %>
            <th>ユーザー</th>
            <%# ***** 「<th>【内容】</th>」：テーブル見出しセル要素 ***** %>
            <th>タイトル</th>
            <%# ***** 「<th>【内容】</th>」：テーブル見出しセル要素 ***** %>
            <th>本文</th>
            <%# ***** 「<th>【内容】</th>」：テーブル見出しセル要素 ***** %>
            <th>ステータス</th>
            <%# ***** 「<th>【内容】</th>」：テーブル見出しセル要素 ***** %>
            <th>タグ</th>
            <%# ***** 「<th>【内容】</th>」：テーブル見出しセル要素 ***** %>
            <th>操作</th>
            <%# ***** 「<th>【内容】</th>」：テーブル見出しセル要素 ***** %>
            <%# ***** 「<th>【内容】</th>」：テーブル見出しセル要素 ***** %>
          </tr>
          <%# ***** 「</tr>」：trタグ（テーブル行要素）の終了 ***** %>
        </thead>
        <%# ***** 「</thead>」：theadタグ（テーブル見出し要素）の終了 ***** %>
        <tbody>
        <%# ***** 「<tbody>」：テーブル本文要素 ***** %>
        <%# ***** @postsの各投稿をループ処理 ***** %>
          <% @posts.each do |post| %>
          <%# ***** 「@posts.each do |post|」：Ruby式を実行する処理 ***** %>
          <%# ***** 「each do |post|」: コレクションを順番に処理し、|post| で現在要素を受け取る反復構文 ***** %>
          <%# ***** 「@posts」：処理対象となるコレクション ***** %>
          <%# ***** 「|post|」：各反復で取り出した要素を受け取るブロック引数 ***** %>
          <%# ***** 「each」：コレクションを順に処理するループ ***** %>
            <tr>
            <%# ***** 「<tr>」：テーブル行要素 ***** %>
            <%# ***** 投稿日時を表示 ***** %>
              <td><%= post.created_at.strftime('%Y/%m/%d %H:%M') %></td>

              <%# ***** 「<td>【内容】</td>」：テーブルデータセル要素 ***** %>
              <%# ***** ユーザー名をクリックするとユーザー詳細ページへ ***** %>
              <td><%= link_to(post.user.name.presence || '未設定', user_path(post.user)) %></td>

              <%# ***** 「<td>【内容】</td>」：テーブルデータセル要素 ***** %>
              <%# ***** タイトルをクリックすると投稿詳細ページへ ***** %>
              <td><%= link_to post.title, post_path(post) %></td>

              <%# ***** 「<td>【内容】</td>」：テーブルデータセル要素 ***** %>
              <%# ***** 本文は10文字まで表示（長い場合は「...」で省略） ***** %>
              <td><%= truncate(post.body, length: 10) %></td>

              <%# ***** 「<td>【内容】</td>」：テーブルデータセル要素 ***** %>
              <%# ***** ステータスをバッジで表示 ***** %>
              <td>
              <%# ***** 「<td>」：テーブルデータセル要素 ***** %>
                <% if post.published? %>
                <%# ***** 「if post.published?」：Ruby式を実行する処理 ***** %>
                <%# ***** 「if (post.published?)」: post.published?を判定する条件分岐 ***** %>
                <%# ***** 「if」：条件を判定する分岐 ***** %>
                  <span class="badge badge-success">公開</span>
                  <%# ***** 「<span>【内容】</span>」：インライン要素 ***** %>
                <% else %>
                <%# ***** 「else」：上記条件に当てはまらない場合の分岐 ***** %>
                <%# ***** 「else」：上記条件に当てはまらない場合の分岐 ***** %>
                  <span class="badge badge-secondary">下書き</span>
                  <%# ***** 「<span>【内容】</span>」：インライン要素 ***** %>
                <% end %>
                <%# ***** 「end」：ブロック処理を終了するキーワード ***** %>
              </td>

              <%# ***** 「</td>」：tdタグ（テーブルデータセル要素）の終了 ***** %>
              <%# ***** タグがあれば表示（クリックでタグ検索） ***** %>
              <td>
              <%# ***** 「<td>」：テーブルデータセル要素 ***** %>
                <% if post.respond_to?(:tags) %>
                <%# ***** 「if post.respond_to?(:tags)」：Ruby式を実行する処理 ***** %>
                <%# ***** 「if (post.respond_to?(:tags))」: post.respond_to?(:tags)を判定する条件分岐 ***** %>
<%# ***** 一覧ループセクション ***** %>
                  <% post.tags.each do |tag| %>
                  <%# ***** 「post.tags.each do |tag|」：Ruby式を実行する処理 ***** %>
                  <%# ***** 「each do |tag|」: コレクションを順番に処理し、|tag| で現在要素を受け取る反復構文 ***** %>
                  <%# ***** 「post.tags」：処理対象となるコレクション ***** %>
                  <%# ***** 「|tag|」：各反復で取り出した要素を受け取るブロック引数 ***** %>
                  <%# ***** 「each」：コレクションを順に処理するループ ***** %>
                    <span class="badge badge-info"><%= link_to tag.name, tagged_posts_path(tag.name), class: "text-white" %></span>
                    <%# ***** 「<span>【内容】</span>」：インライン要素 ***** %>
                  <% end %>
                  <%# ***** 「end」：ブロック処理を終了するキーワード ***** %>
                <% end %>
                <%# ***** 「end」：ブロック処理を終了するキーワード ***** %>
              </td>

              <%# ***** 「</td>」：tdタグ（テーブルデータセル要素）の終了 ***** %>
              <%# ***** 操作ボタン（表示・編集・削除） ***** %>
              <td>
              <%# ***** 「<td>」：テーブルデータセル要素 ***** %>
                <% if user_signed_in? %>
                <%# ***** 「if user_signed_in?」：Ruby式を実行する処理 ***** %>
                <%# ***** 「if (user_signed_in?)」: user_signed_in?を判定する条件分岐 ***** %>
                <%# ***** 「user_signed_in?」：Deviseで定義されたログイン状態判定ヘルパー関数 ***** %>
                <%# ***** 「表示」ボタンは誰でも表示 ***** %>
                  <%= link_to "表示", post_path(post), class: "btn btn-sm btn-info" %>
                  <%# ***** 「link_to "表示", post_path(post), class: "btn btn-sm btn-info"」：画面へ値を出力する式 ***** %>
                  <%# ***** 「編集」「削除」は投稿者本人または管理者のみ ***** %>
                  <% if current_user == post.user || current_user.admin? %>
                  <%# ***** 「if current_user == post.user || current_user.admin?」：Ruby式を実行する処理 ***** %>
                  <%# ***** 「if (current_user == post.user || current_user.admin?)」: current_user == post.user || current_user.admin?を判定する条件分岐 ***** %>
                  <%# ***** 「if」：条件を判定する分岐 ***** %>
                    <%= link_to "編集", edit_post_path(post), class: "btn btn-sm btn-warning" %>
                    <%# ***** 「link_to "編集", edit_post_path(post), class: "btn btn-sm btn-warning"」：画面へ値を出力する式 ***** %>
                    <%= link_to "削除", post_path(post), method: :delete, data: { confirm: "本当に削除しますか？" }, class: "btn btn-sm btn-danger" %>
                    <%# ***** 「link_to "削除", post_path(post), method: :delete, data: { confirm: "本当に削除しますか？" }, class: "btn btn-sm btn-danger"」：画面へ値を出力する式 ***** %>
                  <% end %>
                  <%# ***** 「end」：ブロック処理を終了するキーワード ***** %>
                <% end %>
                <%# ***** 「end」：ブロック処理を終了するキーワード ***** %>
              </td>
              <%# ***** 「</td>」：tdタグ（テーブルデータセル要素）の終了 ***** %>
            </tr>
            <%# ***** 「</tr>」：trタグ（テーブル行要素）の終了 ***** %>
          <% end %>
          <%# ***** 「end」：ブロック処理を終了するキーワード ***** %>
        </tbody>
        <%# ***** 「</tbody>」：tbodyタグ（テーブル本文要素）の終了 ***** %>
      </table>
      <%# ***** 「</table>」：tableタグ（テーブル要素）の終了 ***** %>

    </div>
    <%# ***** 「</div>」：divタグ（汎用コンテナ要素）の終了 ***** %>
  </div>
  <%# ***** 「</div>」：divタグ（汎用コンテナ要素）の終了 ***** %>
</div>
<%# ***** 「</div>」：divタグ（汎用コンテナ要素）の終了 ***** %>
<%# ***** 「</div>」：divタグ（汎用コンテナ要素）の終了 ***** %>
