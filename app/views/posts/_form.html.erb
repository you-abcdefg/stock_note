<%= form_with(model: @post, local: true) do |form| %>
  <div class="form-group">
    <%= form.label :title, 'タイトル' %>
    <%= form.text_field :title, class: 'form-control', style: 'height: 48px; min-height: 48px; max-height: 48px; border: 2px solid #007bff; border-radius: 10px; background: #f4f8ff; box-shadow: 0 0 8px #b3d1ff; padding: 12px;' %>
  </div>
  <div class="form-group">
    <%= form.label :body, '本文' %>
    <!-- 本文エディタ内のカード間ボタン方式に一本化 -->
    <div id="body-editor" contenteditable="true" class="mb-2" style="height: 400px; min-height: 400px; max-height: 400px; overflow-y: auto; border: 2px solid #007bff; border-radius: 10px; background: #f4f8ff; box-shadow: 0 0 8px #b3d1ff; padding: 12px;"></div>
    <%= form.hidden_field :body, id: 'body-hidden' %>
    <%= render 'card_modal' %>
  </div>
  <%= render 'tag_modal' %>
<% end %>
