<div class="container px-5 px-sm-0 mt-4">
<%# ***** 「<div>」：HTMLタグ ***** %>
<%# ***** 「<div>」：汎用コンテナ要素 ***** %>
<%# ***** 「# ***** 「<div>」：汎用コンテナ要素 *****」：出力式/式 ***** %>
<%# ***** posts/new のビュー ***** %>
<%# ***** 「# ***** posts/new のビュー *****」：出力式/式 ***** %>
<%# ***** container：レスポンシブコンテナクラス ***** %>
<%# ***** 「# ***** container：レスポンシブコンテナクラス *****」：出力式/式 ***** %>
<%# ***** px-5 px-sm-0：パディング調整（小画面で0、大画面で5） ***** %>
<%# ***** 「# ***** px-5 px-sm-0：パディング調整（小画面で0、大画面で5） *****」：出力式/式 ***** %>
<%# ***** 「class ="【クラス名】"」：要素へスタイルを適用するクラス属性 ***** %>
<%# ***** 「# ***** 「class ="【クラス名】"」：要素へスタイルを適用するクラス属性 *****」：出力式/式 ***** %>
  <div class="row">
  <%# ***** 「<div>」：汎用コンテナ要素 ***** %>
  <%# ***** mt-4：上部マージンを追加 ***** %>
  <%# ***** 「class ="【クラス名】"」：要素へスタイルを適用するクラス属性 ***** %>
    <div class="col-md-12">
    <%# ***** 「<div>」：汎用コンテナ要素 ***** %>
    <%# ***** row：Bootstrapのグリッドシステムを使用する行 ***** %>
    <%# ***** 「class ="【クラス名】"」：要素へスタイルを適用するクラス属性 ***** %>

      <h2>投稿を作成</h2>
      <%# ***** col-md-12：全幅を占めるカラム ***** %>
      <%# ***** 「<h2>【内容】</h2>」：2番目のレベルの見出し ***** %>

      <%= form_with(model: @post, local: true) do |form| %>
        <div class="form-group">
          <%= form.label :title, 'タイトル' %>
          <%= form.text_field :title, class: 'form-control', style: 'height: 48px; min-height: 48px; max-height: 48px; border: 2px solid #007bff; border-radius: 10px; background: #f4f8ff; box-shadow: 0 0 8px #b3d1ff; padding: 12px;' %>
        </div>
        <div class="form-group">
          <%= form.label :body, '本文' %>
          <%= form.hidden_field :body, id: 'body-hidden' %>
          <div id="cards-list" class="mb-2" style="height: 400px; min-height: 400px; max-height: 400px; overflow-y: auto; border: 2px solid #007bff; border-radius: 10px; background: #f4f8ff; box-shadow: 0 0 8px #b3d1ff; padding: 12px;"></div>
          <!-- カード編集モーダル -->
          <div class="modal fade" id="cardEditModal" tabindex="-1" role="dialog" aria-labelledby="cardEditModalLabel" aria-hidden="true">
            <div class="modal-dialog" role="document">
              <div class="modal-content">
                <div class="modal-header">
                  <h5 class="modal-title" id="cardEditModalLabel">カード編集</h5>
                  <button type="button" class="close" data-dismiss="modal" aria-label="Close">
                    <span aria-hidden="true">&times;</span>
                  </button>
                </div>
                <div class="modal-body">
                  <div class="form-group">
                    <label for="edit-card-content">内容</label>
                    <textarea id="edit-card-content" class="form-control" rows="4"></textarea>
                  </div>
                </div>
                <div class="modal-footer">
                  <button type="button" class="btn btn-primary" id="save-card-edit">保存</button>
                  <button type="button" class="btn btn-secondary" data-dismiss="modal">キャンセル</button>
                </div>
              </div>
            </div>
          </div>
          <!-- カード種別選択ダイアログ -->
          <div class="modal fade" id="cardTypeModal" tabindex="-1" role="dialog" aria-labelledby="cardTypeModalLabel" aria-hidden="true">
            <div class="modal-dialog" role="document">
              <div class="modal-content">
                <div class="modal-header">
                  <h5 class="modal-title" id="cardTypeModalLabel">カードの種類を選択</h5>
                  <button type="button" class="close" data-dismiss="modal" aria-label="Close">
                    <span aria-hidden="true">&times;</span>
                  </button>
                </div>
                <div class="modal-body">
                  <button type="button" class="btn btn-secondary btn-block mb-2" data-card-type="text">テキスト</button>
                  <button type="button" class="btn btn-secondary btn-block mb-2" data-card-type="url">URL</button>
                  <button type="button" class="btn btn-secondary btn-block mb-2" data-card-type="image">画像</button>
                  <button type="button" class="btn btn-secondary btn-block mb-2" data-card-type="math">数式</button>
                  <button type="button" class="btn btn-secondary btn-block mb-2" data-card-type="code">コード</button>
                </div>
              </div>
            </div>
          </div>
        </div>
        <!-- 画像ファイル選択フォームはカード埋め込み方式のため削除 -->
        <%= form.label :tag_list, 'タグ' %>
        <div class="form-group" style="border: 2px solid #007bff; border-radius: 10px; background: #f4f8ff; box-shadow: 0 0 8px #b3d1ff; padding: 16px 12px;">
          <div class="mt-2 mb-2">
            <button type="button" id="open-tag-modal" class="btn btn-outline-primary">タグ選択</button>
          </div>
          <span id="selected-tags" class="ml-2">未選択</span>
        </div>
        <!-- タグ選択モーダル -->
        <div class="modal fade" id="tagSelectModal" tabindex="-1" role="dialog" aria-labelledby="tagSelectModalLabel" aria-hidden="true">
          <div class="modal-dialog" role="document">
            <div class="modal-content">
              <div class="modal-header">
                <h5 class="modal-title" id="tagSelectModalLabel">タグ選択</h5>
                <button type="button" class="close" data-dismiss="modal" aria-label="Close">
                  <span aria-hidden="true">&times;</span>
                </button>
              </div>
              <div class="modal-body">
                <div id="tag-checkboxes-modal">
                  <% @available_tags.each do |tag| %>
                    <div class="custom-control custom-checkbox mr-3 mb-2">
                      <input type="checkbox" value="<%= tag.name %>" id="tag_modal_<%= tag.id %>" class="custom-control-input tag-modal-checkbox">
                      <label class="custom-control-label" for="tag_modal_<%= tag.id %>"><%= tag.name %></label>
                    </div>
                  <% end %>
                </div>
              </div>
              <div class="modal-footer">
                <button type="button" class="btn btn-success mr-auto" id="add-tag-in-modal">タグ追加</button>
                <button type="button" class="btn btn-primary" id="apply-tag-selection">決定</button>
                <button type="button" class="btn btn-secondary" data-dismiss="modal">閉じる</button>
              </div>
            </div>
          </div>
        </div>
        <hr class="my-4">
        <div class="form-group d-flex align-items-center">
          <%= form.submit '投稿する', class: 'btn btn-primary mr-2' %>
          <a href="/posts" class="btn btn-secondary">キャンセル</a>
        </div>
      <% end %>

      <script>
        (function() {
          // --- カードリストUI ---
          const cardsList = document.getElementById('cards-list');
          const cardTypeModal = document.getElementById('cardTypeModal');
          let cards = [];
          // 編集用
          const cardEditModal = document.getElementById('cardEditModal');
          const editCardContent = document.getElementById('edit-card-content');
          const saveCardEditBtn = document.getElementById('save-card-edit');
          let editingCardIdx = null;

          // Bootstrapモーダル表示
          function showCardTypeModal() {
            if (window.jQuery) {
              window.jQuery(cardTypeModal).modal('show');
            } else {
              cardTypeModal.style.display = 'block';
            }
          }
          function hideCardTypeModal() {
            if (window.jQuery) {
              window.jQuery(cardTypeModal).modal('hide');
            } else {
              cardTypeModal.style.display = 'none';
            }
          }

          // n+1個のカード追加ボタンを含めて描画
          function renderCards() {
            cardsList.innerHTML = '';
            for (let i = 0; i <= cards.length; i++) {
              // 追加ボタン
              const addBtn = document.createElement('button');
              addBtn.type = 'button';
              addBtn.className = 'btn btn-outline-success btn-block mb-2 card-insert-btn';
              addBtn.textContent = '＋ カード追加';
              addBtn.dataset.insertIdx = i;
              cardsList.appendChild(addBtn);
              // カード本体
              if (i < cards.length) {
                const card = cards[i];
                const cardDiv = document.createElement('div');
                cardDiv.className = 'card mb-2';
                cardDiv.innerHTML = `
                  <div class="card-body d-flex align-items-center justify-content-between">
                    <span>${card.type}カード</span>
                    <div>
                      <button type="button" class="btn btn-sm btn-outline-secondary mr-1" data-move-up="${i}">↑</button>
                      <button type="button" class="btn btn-sm btn-outline-secondary mr-2" data-move-down="${i}">↓</button>
                      <button type="button" class="btn btn-sm btn-outline-primary mr-2" data-edit-idx="${i}">編集</button>
                      <button type="button" class="btn btn-sm btn-outline-danger" data-del-idx="${i}">削除</button>
                    </div>
                  </div>
                `;
                cardsList.appendChild(cardDiv);
              }
            }
          }

          // n+1個の追加ボタンでカード挿入
          let pendingInsertIdx = null;
          cardsList.addEventListener('click', function(e) {
            // 編集
            if (e.target.dataset.editIdx !== undefined) {
              editingCardIdx = parseInt(e.target.dataset.editIdx);
              // 編集内容をセット
              editCardContent.value = cards[editingCardIdx].content || '';
              // モーダル表示
              if (window.jQuery) {
                window.jQuery(cardEditModal).modal('show');
              } else {
                cardEditModal.style.display = 'block';
              }
              return;
            }
                      // 編集保存
                      if (saveCardEditBtn) {
                        saveCardEditBtn.addEventListener('click', function() {
                          if (editingCardIdx !== null) {
                            cards[editingCardIdx].content = editCardContent.value;
                            renderCards();
                            if (window.jQuery) {
                              window.jQuery(cardEditModal).modal('hide');
                            } else {
                              cardEditModal.style.display = 'none';
                            }
                            editingCardIdx = null;
                          }
                        });
                      }
            if (e.target.classList.contains('card-insert-btn')) {
              pendingInsertIdx = parseInt(e.target.dataset.insertIdx);
              showCardTypeModal();
            }
          });
          if (cardTypeModal) {
            cardTypeModal.addEventListener('click', function(e) {
              if (e.target.dataset.cardType && pendingInsertIdx !== null) {
                cards.splice(pendingInsertIdx, 0, {type: e.target.dataset.cardType, content: ''});
                renderCards();
                hideCardTypeModal();
                pendingInsertIdx = null;
              }
            });
          }
          // カード削除・上下移動
          cardsList.addEventListener('click', function(e) {
            // 削除
            if (e.target.dataset.delIdx !== undefined) {
              const idx = parseInt(e.target.dataset.delIdx);
              cards.splice(idx, 1);
              renderCards();
              return;
            }
            // 上移動
            if (e.target.dataset.moveUp !== undefined) {
              const idx = parseInt(e.target.dataset.moveUp);
              if (idx > 0) {
                [cards[idx - 1], cards[idx]] = [cards[idx], cards[idx - 1]];
                renderCards();
              }
              return;
            }
            // 下移動
            if (e.target.dataset.moveDown !== undefined) {
              const idx = parseInt(e.target.dataset.moveDown);
              if (idx < cards.length - 1) {
                [cards[idx + 1], cards[idx]] = [cards[idx], cards[idx + 1]];
                renderCards();
              }
              return;
            }
          });
          // 初期描画
          renderCards();
          // ここから元のJSコード全体をIIFEでラップ
          // --- 既存フォーム初期化 ---
          const initPostForm = () => {
            const bodyEditor = document.getElementById('body-editor');
            const bodyHidden = document.getElementById('body-hidden');
            if (bodyEditor && bodyEditor.dataset.insertBindings === 'true') return;
            if (bodyEditor) {
              bodyEditor.dataset.insertBindings = 'true';
            }
            const insertImageButton = document.getElementById('insert-image-button');
            const insertCodeButton = document.getElementById('insert-code-button');
            const imageInput = document.getElementById('post_images');
            const selectedTags = document.getElementById('selected-tags');
            const openTagModalBtn = document.getElementById('open-tag-modal');
            const tagSelectModal = document.getElementById('tagSelectModal');
            const tagCheckboxesModal = document.getElementById('tag-checkboxes-modal');
            const applyTagSelectionBtn = document.getElementById('apply-tag-selection');
            // 選択状態保持用
            let selectedTagValues = [];
            const imageObjectsContainer = document.getElementById('image-objects');
            const codeObjectsContainer = document.getElementById('code-objects');
            const imageCountSpan = document.getElementById('image-count');
            const codeCountSpan = document.getElementById('code-count');
            const noImagesMessage = document.getElementById('no-images-message');
            const noCodeMessage = document.getElementById('no-code-message');
            const codeTemplate = "\n```ruby\n\n```\n";
            const resolveImageUrl = (filename) => {
              if (window.localImageUrlMap && window.localImageUrlMap.has(filename)) {
                return window.localImageUrlMap.get(filename);
              }
              if (window.imageUrlMap && window.imageUrlMap[filename]) {
                return window.imageUrlMap[filename];
              }
              return null;
            };
            const hasContentEditable = !!bodyEditor;
            const setBodyText = (text) => {
              if (bodyEditor) {
                bodyEditor.textContent = text;
                bodyEditor.dispatchEvent(new Event('input'));
                return;
              }
              if (bodyHidden) {
                bodyHidden.value = text;
                bodyHidden.dispatchEvent(new Event('input'));
              }
            };
            const insertAtCursor = (text) => {
              if (!bodyHidden) return;
              const start = bodyHidden.selectionStart || 0;
              const end = bodyHidden.selectionEnd || 0;
              const before = bodyHidden.value.slice(0, start);
              const after = bodyHidden.value.slice(end);
              bodyHidden.value = `${before}${text}${after}`;
              bodyHidden.dispatchEvent(new Event('input'));
            };
            const updateMediaDisplay = () => {
            };
            if (insertImageButton && !hasContentEditable) {
              insertImageButton.addEventListener('click', function () {
                if (!imageInput) return;
                imageInput.click();
              });
            }
            const allFiles = [];
            if (imageInput && !hasContentEditable) {
              imageInput.addEventListener('change', function () {
                if (!imageInput.files || imageInput.files.length === 0) return;
                const newFiles = Array.from(imageInput.files);
                newFiles.forEach((file) => {
                  if (!allFiles.find((f) => f.name === file.name && f.size === file.size)) {
                    allFiles.push(file);
                  }
                });
                const dt = new DataTransfer();
                allFiles.forEach((file) => {
                  dt.items.add(file);
                });
                imageInput.files = dt.files;
                const lines = newFiles.map((file) => `![説明](image:${file.name})`);
                insertAtCursor(lines.join("\n"));
                updateMediaDisplay();
              });
            }
            if (bodyEditor) {
              bodyEditor.addEventListener('input', updateMediaDisplay);
            }
            if (bodyHidden) {
              bodyHidden.addEventListener('input', updateMediaDisplay);
            }
            const updateSelected = () => {
              const names = Array.from(getCheckboxes())
                .filter((cb) => cb.checked)
                .map((cb) => cb.value);
              selectedTags.textContent = names.length ? names.join(', ') : '未選択';
            };
            const bindCheckboxEvents = () => {
              getCheckboxes().forEach((cb) => cb.addEventListener('change', updateSelected));
            };
            // タグ選択モーダルの制御
            if (openTagModalBtn && tagSelectModal) {
              openTagModalBtn.addEventListener('click', function() {
                if (window.jQuery) {
                  window.jQuery(tagSelectModal).modal('show');
                } else {
                  tagSelectModal.style.display = 'block';
                }
                // モーダル表示時、既存選択を反映
                Array.from(tagCheckboxesModal.querySelectorAll('input[type="checkbox"]')).forEach(cb => {
                  cb.checked = selectedTagValues.includes(cb.value);
                });
              });
            }
            if (applyTagSelectionBtn && tagCheckboxesModal) {
              applyTagSelectionBtn.addEventListener('click', function() {
                // 選択値を反映
                selectedTagValues = Array.from(tagCheckboxesModal.querySelectorAll('input[type="checkbox"]:checked')).map(cb => cb.value);
                selectedTags.textContent = selectedTagValues.length ? selectedTagValues.join(', ') : '未選択';
                // hiddenフィールドへ反映
                let hidden = document.querySelector('input[name="post[tag_list]"]');
                if (!hidden) {
                  hidden = document.createElement('input');
                  hidden.type = 'hidden';
                  hidden.name = 'post[tag_list]';
                  document.querySelector('form').appendChild(hidden);
                }
                hidden.value = selectedTagValues.join(',');
                if (window.jQuery) {
                  window.jQuery(tagSelectModal).modal('hide');
                } else {
                  tagSelectModal.style.display = 'none';
                }
              });
            }
          };
          // turbolinks:loadで初期化
          document.addEventListener('turbolinks:load', initPostForm);
        })();
      </script>
      </script>


        <div class="modal fade" id="tagSelectModal" tabindex="-1" role="dialog" aria-labelledby="tagSelectModalLabel" aria-hidden="true">
        <%# ***** 「<div>」：タグ選択用Bootstrapモーダル ***** %>
        <%# ***** modal fade：モーダルコンポーネント + フェードアニメーション ***** %>
        <%# ***** id="tagSelectModal"：モーダルのID ***** %>
        <%# ***** tabindex="-1"：タブオーダーから除外 ***** %>
        <%# ***** role="dialog"：アクセシビリティロール ***** %>
        <%# ***** aria-labelledby="tagSelectModalLabel"：ラベルIDの指定 ***** %>
        <%# ***** 「class ="【クラス名】"」：要素へスタイルを適用するクラス属性 ***** %>
        <%# ***** 「id ="【ID】"」：要素を一意に識別する属性 ***** %>
        <%# ***** 「tabindex ="【設定値】"」：要素の振る舞いや表示を指定する属性 ***** %>
        <%# ***** 「role ="【ロール】"」：要素の役割を示す属性 ***** %>
        <%# ***** 「aria-labelledby ="【設定値】"」：アクセシビリティ情報を補足する属性 ***** %>
        <%# ***** 「aria-hidden ="【設定値】"」：アクセシビリティ情報を補足する属性 ***** %>
        <%# ***** 「tabindex ="【設定値】"」：属性 ***** %>
        <%# ***** 「aria-labelledby ="【設定値】"」：支援技術向け情報を指定する属性 ***** %>
        <%# ***** 「aria-hidden ="【設定値】"」：支援技術向け情報を指定する属性 ***** %>
          <div class="modal-dialog" role="document">
          <%# ***** 「<div>」：汎用コンテナ要素 ***** %>
          <%# ***** aria-hidden="true"：初期状態では隠す ***** %>
          <%# ***** 「<div>【内容】</div>」：モーダルダイアログコンテナ ***** %>
          <%# ***** modal-dialog：モーダルダイアログのスタイル ***** %>
          <%# ***** 「class ="【クラス名】"」：要素へスタイルを適用するクラス属性 ***** %>
          <%# ***** 「role ="【ロール】"」：要素の役割を示す属性 ***** %>
            <div class="modal-content">
            <%# ***** 「<div>」：汎用コンテナ要素 ***** %>
            <%# ***** role="document"：アクセシビリティロール ***** %>
            <%# ***** 「class ="【クラス名】"」：要素へスタイルを適用するクラス属性 ***** %>
              <div class="modal-header">
              <%# ***** 「<div>」：モーダルコンテンツを囲むセクション ***** %>
              <%# ***** modal-content：モーダルコンテンツのスタイル ***** %>
              <%# ***** 「<div>【内容】</div>」：モーダルヘッダー ***** %>
              <%# ***** 「class ="【クラス名】"」：要素へスタイルを適用するクラス属性 ***** %>
                <h5 class="modal-title" id="tagSelectModalLabel">タグ選択</h5>
                <%# ***** modal-header：モーダルヘッダーのスタイル ***** %>
                <%# ***** 「<h5>【内容】</h5>」：5番目のレベルの見出し ***** %>
                <%# ***** modal-title：モーダルタイトルのスタイル ***** %>
                <%# ***** 「class ="【クラス名】"」：要素へスタイルを適用するクラス属性 ***** %>
                <%# ***** 「id ="【ID】"」：要素を一意に識別する属性 ***** %>
                <button type="button" class="close" data-dismiss="modal" aria-label="Close">
                <%# ***** 「<button>」：ボタン要素 ***** %>
                <%# ***** id="tagSelectModalLabel"：モーダルのラベルID ***** %>
                <%# ***** 「<button>【内容】</button>」：モーダル閉じるボタン ***** %>
                <%# ***** type="button"：ボタンの種類を指定 ***** %>
                <%# ***** class="close"：Bootstrapの閉じるボタンスタイル ***** %>
                <%# ***** data-dismiss="modal"：Bootstrapモーダル閉じる機能を有効化 ***** %>
                <%# ***** 「type ="【種別】"」：要素や入力値の種類を指定する属性 ***** %>
                <%# ***** 「class ="【クラス名】"」：要素へスタイルを適用するクラス属性 ***** %>
                <%# ***** 「data-dismiss ="【設定値】"」：JavaScript連携に使うカスタムデータ属性 ***** %>
                <%# ***** 「aria-label ="【ラベル】"」：支援技術向けの要素ラベルを指定する属性 ***** %>
                  <span aria-hidden="true">&times;</span>
                  <%# ***** aria-label="Close"：スクリーンリーダー用ラベル ***** %>
                  <%# ***** 「<span>【内容】</span>」：バツ記号（HTML実体参照） ***** %>
                  <%# ***** aria-hidden="true"：スクリーンリーダーから隠す ***** %>
                  <%# ***** 「aria-hidden ="【設定値】"」：支援技術向け情報を指定する属性 ***** %>
                </button>
                <%# ***** 「<button>【内容】</button>」：クリックできるボタンを作るHTML要素 ***** %>
                <%# ***** &times；：× 記号のHTML実体参照 ***** %>
              </div>
              <%# ***** 「<div>【内容】</div>」：要素をまとめるための汎用コンテナ ***** %>
              <!-- 重複していたタグ選択モーダル（form_with外）は削除 -->

        <script>
        <%# ***** 「<script>」：スクリプト要素 ***** %>
        <%# ***** スクリプトセクション ***** %>
          const initPostForm = () => {
          <%# ***** 「const initPostForm = () => {」：スタイルルールの開始 ***** %>
            const bodyEditor = document.getElementById('body-editor');
            const bodyHidden = document.getElementById('body-hidden');
            // タグ関連のバインドはbodyEditorの有無に関わらず必ず行う
            if (bodyEditor && bodyEditor.dataset.insertBindings === 'true') return;
            if (bodyEditor) {
              bodyEditor.dataset.insertBindings = 'true';
            }
            const insertImageButton = document.getElementById('insert-image-button');
            <%# ***** 「const insertImageButton = document.getElementById('insert-image-button')」：JavaScriptで定数を宣言する処理 ***** %>
            const insertCodeButton = document.getElementById('insert-code-button');
            <%# ***** 「const insertCodeButton = document.getElementById('insert-code-button')」：JavaScriptで定数を宣言する処理 ***** %>
