<div class="container px-5 px-sm-0 mt-4">
<%# ***** posts/new のビュー ***** %>
<%# ***** container：レスポンシブコンテナクラス ***** %>
<%# ***** px-5 px-sm-0：パディング調整（小画面で0、大画面で5） ***** %>
  <div class="row">
  <%# ***** mt-4：上部マージンを追加 ***** %>
    <div class="col-md-12">
    <%# ***** row：Bootstrapのグリッドシステムを使用する行 ***** %>
      <h2>投稿を作成</h2>
      <%# ***** col-md-12：全幅を占めるカラム ***** %>
      <%# ***** h2：2番目のレベルの見出し ***** %>

      <script>
      <%# ***** 画像URLマップをJavaScriptで利用できるようにする ***** %>
        window.imageUrlMap = {
        <%# ***** script：スクリプト要素 ***** %>
<%# ***** 一覧ループセクション ***** %>
          <% @post.images.each do |image| %>
          <%# ***** 「each do |【要素】|」: コレクションを順番に処理し、|【要素】| で現在要素を受け取る反復構文 ***** %>
          <%# ***** 「@post.images」：処理対象となるコレクション ***** %>
          <%# ***** 「|image|」：各反復で取り出した要素を受け取るブロック引数 ***** %>
            '<%= image.filename %>': '<%= url_for(image) %>',
            <%# ***** each：コレクションを順に処理するループ ***** %>
          <% end %>
        };
      </script>

      <%# ***** 入力フォームセクション ***** %>
      <%= form_with(model: @post, local: true, html: { multipart: true }) do |form| %>
      <%# ***** form_with：投稿フォーム生成ヘルパー ***** %>
      <%# ***** model: @post：Postモデルをフォームに紐づける ***** %>
      <%# ***** local: true：Turboドライブを無効化して同期通信で送信 ***** %>
      <%# ***** html: { multipart: true }：ファイルアップロードを有効化 ***** %>
      <%# ***** エラーメッセージ表示セクション ***** %>
      <%# ***** 条件分岐セクション ***** %>
        <% if @post.errors.any? %>
        <%# ***** 「if (【条件】)」: 【条件】を判定する条件分岐 ***** %>

        <%# ***** if：投稿にエラーがある場合の条件 ***** %>
          <div class="alert alert-danger">
          <%# ***** @post.errors.any?：1つ以上のエラーが存在するか判定 ***** %>
          <%# ***** div：エラーメッセージを囲む警告アラート ***** %>
            <h4><%= pluralize(@post.errors.count, "error") %> prohibited this post from being saved:</h4>
            <%# ***** alert alert-danger：赤色の危険アラートのスタイル ***** %>
            <%# ***** h4：4番目のレベルの見出し ***** %>
            <%# ***** pluralize：数に応じて単数・複数形を使い分ける ***** %>
            <ul>
            <%# ***** @post.errors.count：エラー数を取得 ***** %>
            <%# ***** ul：順序なしリスト ***** %>
              <% @post.errors.full_messages.each do |message| %>
              <%# ***** 「each do |【要素】|」: コレクションを順番に処理し、|【要素】| で現在要素を受け取る反復構文 ***** %>
              <%# ***** 「@post.errors.full_messages」：処理対象となるコレクション ***** %>
              <%# ***** 「|message|」：各反復で取り出した要素を受け取るブロック引数 ***** %>

              <%# ***** each：エラーメッセージをループして各メッセージを処理 ***** %>
                <li><%= message %></li>
                <%# ***** message：ループ内の現在のエラーメッセージ ***** %>
                <%# ***** li：リストアイテム ***** %>
                <%# ***** message：エラーメッセージを表示 ***** %>
              <% end %>
            </ul>
            <%# ***** end：eachループの終了 ***** %>
          </div>
          <%# ***** </ul>：ulタグ（順序なしリスト要素）の終了 ***** %>
          <%# ***** </div>：divタグ（汎用コンテナ要素）の終了 ***** %>
        <% end %>
        <%# ***** end：if文の終了 ***** %>

        <div class="form-group mb-3">
        <%# ***** div：タイトル入力フォームグループ ***** %>
        <%# ***** form-group：Bootstrapのフォームグループスタイル ***** %>
        <%# ***** mb-3：下部マージンを追加 ***** %>
          <%= form.label :title %>
          <%# ***** form.label：タイトル入力フィールドのラベルを表示 ***** %>
          <%# ***** :title：ラベル対象属性 ***** %>
          <%= form.text_field :title, class: "form-control" %>
          <%# ***** フォーム入力欄セクション ***** %>
          <%# ***** form.text_field：単一行テキスト入力フィールド ***** %>
          <%# ***** :title：投稿タイトル属性を対象 ***** %>
        </div>
        <%# ***** class: "form-control"：Bootstrapのフォームコントロールスタイル ***** %>
        <%# ***** </div>：divタグ（汎用コンテナ要素）の終了 ***** %>

        <div class="form-group mb-3">
        <%# ***** div：本文入力フォームグループ ***** %>
        <%# ***** form-group：Bootstrapのフォームグループスタイル ***** %>
          <label>カード配置</label>
          <%# ***** mb-3：下部マージンを追加 ***** %>
          <%# ***** form.label：本文入力フィールドのラベルを表示 ***** %>
          <%# ***** :body：ラベル対象属性 ***** %>
          <textarea id="body-source" class="d-none" rows="1" aria-hidden="true"></textarea>
          <%# ***** "本文"：ラベルのテキスト ***** %>
          <div id="body-editor" contenteditable="false" data-preview-only="true" class="form-control" style="min-height: 250px; max-height: 400px; white-space: pre-wrap; word-wrap: break-word; overflow-y: auto; background: #f8f9fa;"></div>
          <%# ***** textarea：複数行入力要素 ***** %>
          <%# ***** div contenteditable：テキスト編集可能なdiv（textareaの代わり） ***** %>
          <%# ***** id="body-editor"：JavaScriptで参照するID ***** %>
          <%# ***** contenteditable="true"：ユーザーが編集可能に ***** %>
          <%# ***** class: "form-control"：Bootstrapのフォームコントロールスタイル ***** %>
          <input type="hidden" id="body-hidden" name="post[body]" value="<%= @post.body %>">
          <%# ***** style: min-height, max-height等：表示を調整 ***** %>
          <%# ***** input hidden：フォーム送信時に本文を格納する隠れたフィールド ***** %>
          <div class="mt-2">
          <%# ***** name="post[body]"：Railsフォームパラメータ ***** %>
          <%# ***** div：本文挿入ボタンを配置する行 ***** %>
            <button type="button" class="btn btn-sm btn-outline-dark mr-2" id="insert-text-button">
            <%# ***** mt-2：上部マージンを追加 ***** %>
              テキストを挿入
            </button>
            <%# ***** button：ボタン要素 ***** %>
            <button type="button" class="btn btn-sm btn-outline-success mr-2" id="insert-url-button">
            <%# ***** </button>：buttonタグ（ボタン要素）の終了 ***** %>
              URLを挿入
            </button>
            <%# ***** button：ボタン要素 ***** %>
            <button type="button" class="btn btn-sm btn-outline-primary mr-2" id="insert-image-button">
            <%# ***** </button>：buttonタグ（ボタン要素）の終了 ***** %>
            <%# ***** button：本文中へ画像記法を挿入するボタン ***** %>
            <%# ***** type="button"：フォーム送信を行わないボタン ***** %>
            <%# ***** class: "btn btn-sm btn-outline-primary mr-2"：小さめの青枠ボタン + 右マージン ***** %>
              画像を挿入
              <%# ***** id="insert-image-button"：JavaScriptで参照するID ***** %>
            </button>
            <%# ***** ボタンの表示テキスト ***** %>
            <button type="button" class="btn btn-sm btn-outline-secondary mr-2" id="insert-code-button">
            <%# ***** </button>：buttonタグ（ボタン要素）の終了 ***** %>
            <%# ***** button：本文中へコードブロック記法を挿入するボタン ***** %>
            <%# ***** type="button"：フォーム送信を行わないボタン ***** %>
            <%# ***** class: "btn btn-sm btn-outline-secondary"：小さめのグレー枠ボタン ***** %>
              コードを挿入
              <%# ***** id="insert-code-button"：JavaScriptで参照するID ***** %>
            </button>
            <%# ***** ボタンの表示テキスト ***** %>
            <button type="button" class="btn btn-sm btn-outline-info" id="insert-formula-button">
            <%# ***** </button>：buttonタグ（ボタン要素）の終了 ***** %>
            <%# ***** button：本文中へ数式（上付き・下付き文字）を挿入するボタン ***** %>
            <%# ***** type="button"：フォーム送信を行わないボタン ***** %>
            <%# ***** class: "btn btn-sm btn-outline-info"：小さめの水色枠ボタン ***** %>
              数式を挿入
              <%# ***** id="insert-formula-button"：JavaScriptで参照するID ***** %>
            </button>
            <%# ***** ボタンの表示テキスト ***** %>
            <button type="button" class="btn btn-sm btn-outline-dark ml-2" id="open-preview-modal-button">
            <%# ***** </button>：buttonタグ（ボタン要素）の終了 ***** %>
              全体プレビュー
            </button>
            <%# ***** button：ボタン要素 ***** %>
          </div>
          <%# ***** </button>：buttonタグ（ボタン要素）の終了 ***** %>
          <style>
          <%# ***** ==== 本文内メディア表示用スタイル ==== ***** %>
            #body-editor {
            <%# ***** style：スタイル定義要素 ***** %>
              overflow-y: auto;
              <%# ***** overflow-y: auto：縦方向のスクロールを許可 ***** %>
              overflow-x: hidden;
              <%# ***** overflow-x: hidden：横方向のはみ出しを隠す ***** %>
              word-break: break-word;
              <%# ***** word-break: break-word：単語途中での改行を許可 ***** %>
              word-wrap: break-word;
              <%# ***** word-wrap: break-word：長い単語を折り返す ***** %>
              line-height: 1.6;
              <%# ***** line-height: 1.6：行の高さを広めに設定 ***** %>
              padding: 10px 12px;
              <%# ***** padding: 10px 12px：内側余白を上下左右に付与 ***** %>
              box-sizing: border-box;
              <%# ***** box-sizing: border-box：paddingを幅/高さに含める ***** %>
              text-align: left;
              <%# ***** text-align: left：テキストを左寄せ ***** %>
            }
            #body-editor .card-spacer {
            <%# ***** .card-spacer：カードとテキストの間隔調整用スペーサー ***** %>
              display: inline-block;
              <%# ***** display: inline-block：インライン要素として配置 ***** %>
              width: 12px;
              <%# ***** width: 12px：横方向の空白幅 ***** %>
              height: 1px;
              <%# ***** height: 1px：高さを最小化 ***** %>
            }
            #body-editor .media-card {
            <%# ***** .media-card：画像カードのコンテナ ***** %>
              display: inline-flex;
              <%# ***** display: inline-flex：インラインでフレックス配置 ***** %>
              margin: 0 0 8px 0;
              <%# ***** margin: 0 12px 8px 0：外側余白を調整 ***** %>
              vertical-align: top;
              <%# ***** vertical-align: top：上端揃え ***** %>
              cursor: pointer;
              <%# ***** cursor: pointer：ホバー時にポインタ表示 ***** %>
              border: 1px solid #000;
              <%# ***** border: 1px solid #e9ecef：枠線を薄く表示 ***** %>
              border-radius: 3px;
              <%# ***** border-radius: 3px：角丸 ***** %>
              background: white;
              <%# ***** background: white：背景色を白に設定 ***** %>
              position: relative;
              <%# ***** position: relative：絶対配置ボタンの基準 ***** %>
              transition: all 0.2s;
              <%# ***** transition: all 0.2s：ホバー時の変化を滑らかに ***** %>
              width: 100%;
              <%# ***** width: 100px：カードの横幅 ***** %>
              height: auto;
              <%# ***** height: 72px：カードの縦幅 ***** %>
              aspect-ratio: 25 / 18;
              <%# ***** aspect-ratio: 25 / 18：サムネイル比率を維持 ***** %>
              overflow: hidden;
              <%# ***** overflow: hidden：はみ出しを隠す ***** %>
              top: 0;
              <%# ***** top: 0：上方向の位置調整 ***** %>
              font-size: 0;
              <%# ***** font-size: 0：余白文字の影響を防止 ***** %>
              align-items: stretch;
              <%# ***** align-items: stretch：子要素を高さに合わせる ***** %>
            }
            #body-editor .media-card:hover {
            <%# ***** .media-card:hover：ホバー時の装飾 ***** %>
              border-color: #000;
              <%# ***** border-color: #0d6efd：枠線色を強調 ***** %>
              box-shadow: 0 1px 4px rgba(0, 0, 0, 0.1);
              <%# ***** box-shadow：影を付けて浮き上がり感を出す ***** %>
            }
            #body-editor .media-card img {
            <%# ***** .media-card img：画像の表示設定 ***** %>
              width: 100%;
              <%# ***** width: 100%：横幅をカードに合わせる ***** %>
              height: 100%;
              <%# ***** height: 100%：縦幅をカードに合わせる ***** %>
              object-fit: contain;
              <%# ***** object-fit: contain：縦横比を保ち全体表示（トリミングしない） ***** %>
              object-position: left center;
              <%# ***** object-position: left center：左寄せで中央高さに配置 ***** %>
              border-radius: 2px;
              <%# ***** border-radius: 2px：画像の角丸 ***** %>
              display: block;
              <%# ***** display: block：余白のないブロック表示 ***** %>
            }
            #body-editor .media-card .filename {
            <%# ***** .media-card .filename：ファイル名表示（現在は非表示） ***** %>
              display: none;
              <%# ***** display: none：ファイル名を非表示 ***** %>
            }
            #body-editor .code-card,
            <%# ***** .code-card：コードカードのコンテナ ***** %>
            #body-editor .url-card {
              display: block;
              <%# ***** display: block：ブロック要素として配置 ***** %>
              margin: 0 !important;
              <%# ***** margin: 0：上下左右の余白をなくす ***** %>
              margin-top: 0 !important;
              <%# ***** margin-top: 0：上余白を明示的に削除 ***** %>
              padding: 0 !important;
              <%# ***** padding: 0：全padding削除 ***** %>
              background: #f8f9fa;
              <%# ***** background: #f8f9fa：背景色を薄いグレー ***** %>
              border: 1px solid #000;
              <%# ***** border-left: 3px solid #0d6efd：左のアクセント線 ***** %>
              border-radius: 3px;
              <%# ***** border-radius: 3px：角丸 ***** %>
              cursor: pointer;
              <%# ***** cursor: pointer：ポインタ表示 ***** %>
              position: relative;
              <%# ***** position: relative：ボタン配置の基準 ***** %>
              overflow: hidden;
              <%# ***** overflow: hidden：はみ出しを隠す ***** %>
              transition: all 0.2s;
              <%# ***** transition: all 0.2s：ホバー時の変化を滑らかに ***** %>
              height: 100px;
              <%# ***** height: 100px：高さを統一 ***** %>
            }
            #body-editor .code-card:hover,
            <%# ***** .code-card:hover：ホバー時の装飾 ***** %>
            #body-editor .url-card:hover {
              background: #e7f1ff;
              <%# ***** background: #e7f1ff：背景色を強調 ***** %>
              border-color: #000;
              <%# ***** border-left-color: #0056b3：左線の色を変更 ***** %>
            }
            #body-editor .code-card pre,
            <%# ***** .code-card pre：コード表示のテキスト領域 ***** %>
            #body-editor .url-card pre {
              margin: 0;
              <%# ***** margin: 0：余白をリセット ***** %>
              font-size: 12px;
              <%# ***** font-size: 12px：文字サイズを調整 ***** %>
              line-height: 1.5;
              <%# ***** line-height: 1.5：行の高さ ***** %>
              white-space: pre-wrap;
              <%# ***** white-space: pre-wrap：折り返し表示を許可 ***** %>
              word-break: break-word;
              <%# ***** word-break: break-word：単語途中での折り返し ***** %>
              overflow: auto;
              <%# ***** overflow: auto：はみ出しをスクロール表示 ***** %>
              height: 100%;
              <%# ***** height: 100%：親の高さに合わせる ***** %>
            }
            #body-editor .formula-card {
            <%# ***** .formula-card：数式カード ***** %>
              display: block;
              <%# ***** display: block：ブロック要素として配置 ***** %>
              width: 100%;
              <%# ***** width: 100%：横幅を100%に統一 ***** %>
              margin: 0 !important;
              <%# ***** margin: 0：上下左右の余白をなくす ***** %>
              margin-top: 0 !important;
              <%# ***** margin-top: 0：上余白を明示的に削除 ***** %>
              padding: 0 !important;
              <%# ***** padding: 0：内側余白も0に ***** %>
              text-align: left;
              <%# ***** text-align: left：左寄せを明示的に設定 ***** %>
              height: 100px;
              <%# ***** height: 100px：高さを統一 ***** %>
              position: relative;
              <%# ***** position: relative：配置基準 ***** %>
              float: none;
              <%# ***** float: none：浮動を無効化 ***** %>
              border: 1px solid #000;
            }
            #body-editor .text-card {
              display: block;
              width: 100%;
              margin: 0 !important;
              margin-top: 0 !important;
              padding: 0 !important;
              text-align: left;
              height: 100px;
              position: relative;
              float: none;
              background: #f8f9fa;
              border: 1px solid #000;
              border-radius: 3px;
            }
            #body-editor .code-card-body {
            <%# ***** .code-card-body：コードカード本体 ***** %>
              padding: 3px 4px 0 4px !important;
              <%# ***** padding: 3px 4px 0 4px：上3px、左右4pxの余白 ***** %>
              margin: 0 !important;
              <%# ***** margin: 0：余白なし ***** %>
              height: 100%;
              <%# ***** height: 100%：親の高さに合わせる ***** %>
              display: block !important;
              <%# ***** display: block：ブロック要素 ***** %>
              line-height: 1.2 !important;
              <%# ***** line-height: 1.2：行の高さ ***** %>
            }
            #body-editor .formula-card-body {
            <%# ***** .formula-card-body：数式カード本体 ***** %>
              padding: 3px 4px 0 4px !important;
              <%# ***** padding: 3px 4px 0 4px：上3px、左右4pxの余白 ***** %>
              margin: 0 !important;
              <%# ***** margin: 0：余白なし ***** %>
              height: 100%;
              <%# ***** height: 100%：親の高さに合わせる ***** %>
              display: block !important;
              <%# ***** display: block：ブロック要素 ***** %>
              line-height: 1.2 !important;
              <%# ***** line-height: 1.2：行の高さ ***** %>
            }
            #body-editor .text-card-body {
              padding: 10px 12px 8px 8px !important;
              margin: 0 !important;
              min-height: 100%;
              display: block !important;
              line-height: 1.5 !important;
              white-space: pre-wrap;
              word-break: break-word;
            }
            #body-editor .url-card-body {
              padding: 3px 4px 0 4px !important;
              margin: 0 !important;
              height: 100%;
              display: block !important;
              line-height: 1.2 !important;
              white-space: pre-wrap;
              word-break: break-word;
              overflow: auto;
            }
            #body-editor .card-delete-btn {
            <%# ***** .card-delete-btn：カード削除ボタンの共通スタイル ***** %>
              position: absolute;
              <%# ***** position: absolute：カード右上に配置 ***** %>
              top: 0;
              <%# ***** top: 0：上からの位置を0に ***** %>
              right: 2px;
              <%# ***** right: 2px：右からの位置 ***** %>
              padding: 1px 3px;
              <%# ***** padding: 1px 3px：内側余白 ***** %>
              font-size: 9px;
              <%# ***** font-size: 9px：文字サイズ ***** %>
              background: #dc3545;
              <%# ***** background: #dc3545：背景色（赤） ***** %>
              color: white;
              <%# ***** color: white：文字色 ***** %>
              border: none;
              <%# ***** border: none：枠線なし ***** %>
              border-radius: 2px;
              <%# ***** border-radius: 2px：角丸 ***** %>
              cursor: pointer;
              <%# ***** cursor: pointer：ポインタ表示 ***** %>
              z-index: 10;
              <%# ***** z-index: 10：前面表示 ***** %>
            }
            #body-editor .media-card .card-delete-btn {
            <%# ***** .media-card .card-delete-btn：画像カードの削除ボタン ***** %>
              z-index: 20;
              <%# ***** z-index: 20：画像の上に表示 ***** %>
              opacity: 0.95;
              <%# ***** opacity: 0.95：少しだけ透過 ***** %>
              display: inline-block;
              <%# ***** display: inline-block：ボタンを表示 ***** %>
            }
            #body-editor .card-delete-btn:hover {
            <%# ***** .card-delete-btn:hover：削除ボタンのホバー色 ***** %>
              background: #bb2d3b;
              <%# ***** background: #bb2d3b：ホバー時の色 ***** %>
            }
            .code-editor-overlay {
            <%# ***** .code-editor-overlay：コード編集モーダルの背景 ***** %>
              position: fixed;
              <%# ***** position: fixed：画面全体に固定 ***** %>
              inset: 0;
              <%# ***** inset: 0：上下左右を0に設定 ***** %>
              background: rgba(0, 0, 0, 0.4);
              <%# ***** background: rgba(0, 0, 0, 0.4)：半透明の背景 ***** %>
              display: none;
              <%# ***** display: none：初期状態は非表示 ***** %>
              align-items: center;
              <%# ***** align-items: center：縦中央揃え ***** %>
              justify-content: center;
              <%# ***** justify-content: center：横中央揃え ***** %>
              z-index: 9999;
              <%# ***** z-index: 9999：最前面表示 ***** %>
            }
            .code-editor-overlay.is-open {
            <%# ***** .code-editor-overlay.is-open：モーダル表示時 ***** %>
              display: flex;
              <%# ***** display: flex：フレックスで表示 ***** %>
            }
            .code-editor-modal {
            <%# ***** .code-editor-modal：モーダル本体 ***** %>
              background: #fff;
              <%# ***** background: #fff：背景色を白 ***** %>
              width: 90%;
              <%# ***** width: 90%：横幅を SCSS と統一 ***** %>
              max-width: 1200px;
              <%# ***** max-width: 1200px：最大幅を統一 ***** %>
