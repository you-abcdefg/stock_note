              if (!trimmed) return;
              <%# ***** 「if 【条件式】」：【条件式】が true の場合、以下の処理を実行する ***** %>
              <%# ***** if (!trimmed)：空文字列の場合は関数を抜ける ***** %>

              const existing = Array.from(getCheckboxes()).find((cb) => cb.value === trimmed);
              <%# ***** 「const existing = Array.from(getCheckboxes()).find((cb) => cb.value === trimmed)」：JavaScriptで定数を宣言する処理 ***** %>
              <%# ***** (cb) => cb.value === trimmed：値が入力したタグ名と一致するか判定 ***** %>
              if (existing) {
