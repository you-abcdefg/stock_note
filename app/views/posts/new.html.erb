            <%# ***** 「}」：スタイルルールの終了 ***** %>

            const updateSelected = () => {
              const names = Array.from(getCheckboxes())
              <%# ***** updateSelected()：選択されたタグの表示を更新する関数 ***** %>
              <%# ***** Array.from()：NodeListを配列に変換 ***** %>
