            updateMediaDisplay();
            <%# ***** 「updateMediaDisplay()」：JavaScriptの処理を実行する式 ***** %>
          };
          <%# ***** 「}」：スタイルルールの終了 ***** %>

          // 上記でまとめて呼ぶため、ここは削除
