<%# ***** pages/top.html.erb - トップページ ***** %>
<%# ***** 【このファイルの役割】 ***** %>
<%# ***** アプリケーションのメインランディングページを表示 ***** %>
<%# ***** ユーザーを主要機能へガイドするリンクを配置 ***** %>

<div class="container mt-5">
<%# ***** 「<div>」：汎用コンテナ要素 ***** %>
<%# ***** 「class ="【クラス名】"」：要素へスタイルを適用するクラス属性 ***** %>
  <div class="jumbotron bg-light">
  <%# ***** 「<div>」：汎用コンテナ要素 ***** %>
    <%# ***** ウェルカムメッセージ ***** %>
  <%# ***** 「class ="【クラス名】"」：要素へスタイルを適用するクラス属性 ***** %>
    <h1 class="display-4">Stock Note へようこそ</h1>
    <%# ***** 「<h1>【内容】</h1>」：見出し要素 ***** %>
    <%# ***** 「class ="【クラス名】"」：要素へスタイルを適用するクラス属性 ***** %>
    <p class="lead">報告書や技術書のような知識集約コンテンツを整理・共有するプラットフォーム</p>
    <%# ***** 「<p>【内容】</p>」：段落要素 ***** %>
    <%# ***** 「class ="【クラス名】"」：要素へスタイルを適用するクラス属性 ***** %>
    <hr class="my-4">
    <%# ***** 「<hr>」：HTML要素 ***** %>
    <%# ***** 「class ="【クラス名】"」：要素へスタイルを適用するクラス属性 ***** %>
    <p>Stock Noteは、調査結果や設計判断、手順書などを蓄積し、再利用できる知識ベースとして活用できます。</p>
    <%# ***** 「<p>【内容】</p>」：段落要素 ***** %>

    <%# ***** 「<p>【内容】</p>」：段落要素 ***** %>
    <%# ***** ボタン配置 ***** %>
    <div class="mt-4">
    <%# ***** 「<div>」：汎用コンテナ要素 ***** %>
    <%# ***** 条件分岐セクション ***** %>
    <%# ***** 「class ="【クラス名】"」：要素へスタイルを適用するクラス属性 ***** %>
      <% if user_signed_in? %>
      <%# ***** 「if user_signed_in?」：Ruby式を実行する処理 ***** %>
      <%# ***** 「if (user_signed_in?)」: user_signed_in?を判定する条件分岐 ***** %>
      <%# ***** 「user_signed_in?」：Deviseで定義されたログイン状態判定ヘルパー関数 ***** %>
      <%# ***** ログイン済みユーザー向けボタン ***** %>
      <%# ***** 「user_signed_in?」：Deviseのログイン状態を判定するヘルパーメソッド（true / false を返す） ***** %>
        <p>知見を記録・共有してみましょう：</p>
        <%# ***** 「<p>【内容】</p>」：段落要素 ***** %>
        <div class="btn-group mt-3" role="group">
        <%# ***** 「<div>」：汎用コンテナ要素 ***** %>
        <%# ***** 「class ="【クラス名】"」：要素へスタイルを適用するクラス属性 ***** %>
        <%# ***** 「role ="【ロール】"」：要素の役割を示す属性 ***** %>
          <%= link_to '投稿一覧を見る', posts_path, class: 'btn btn-primary btn-lg' %>
          <%# ***** 「link_to '投稿一覧を見る', posts_path, class: 'btn btn-primary btn-lg'」：画面へ値を出力する式 ***** %>
          <%= link_to 'グループを探す', groups_path, class: 'btn btn-info btn-lg' %>
          <%# ***** 「link_to 'グループを探す', groups_path, class: 'btn btn-info btn-lg'」：画面へ値を出力する式 ***** %>
          <%= link_to 'ユーザーを検索', users_path, class: 'btn btn-success btn-lg' %>
          <%# ***** 「link_to 'ユーザーを検索', users_path, class: 'btn btn-success btn-lg'」：画面へ値を出力する式 ***** %>
          <%= link_to '新規投稿を作成', new_post_path, class: 'btn btn-warning btn-lg' %>
          <%# ***** 「link_to '新規投稿を作成', new_post_path, class: 'btn btn-warning btn-lg'」：画面へ値を出力する式 ***** %>
        </div>
        <%# ***** 「</div>」：divタグ（汎用コンテナ要素）の終了 ***** %>
      <% else %>
      <%# ***** 「else」：上記条件に当てはまらない場合の分岐 ***** %>
        <%# ***** 未ログインユーザー向けボタン ***** %>
        <p>まずはログインして、知識ベースを使い始めましょう：</p>
        <%# ***** 「<p>【内容】</p>」：段落要素 ***** %>
        <div class="btn-group mt-3" role="group">
        <%# ***** 「<div>」：汎用コンテナ要素 ***** %>
        <%# ***** 「class ="【クラス名】"」：要素へスタイルを適用するクラス属性 ***** %>
        <%# ***** 「role ="【ロール】"」：要素の役割を示す属性 ***** %>
          <%= link_to '新規登録', new_user_registration_path, class: 'btn btn-primary btn-lg' %>
          <%# ***** 「link_to '新規登録', new_user_registration_path, class: 'btn btn-primary btn-lg'」：画面へ値を出力する式 ***** %>
          <%= link_to 'ログイン', new_user_session_path, class: 'btn btn-secondary btn-lg' %>
          <%# ***** 「link_to 'ログイン', new_user_session_path, class: 'btn btn-secondary btn-lg'」：画面へ値を出力する式 ***** %>
          <%= link_to 'ゲストログイン', guest_sign_in_path, method: :post, class: 'btn btn-info btn-lg' %>
          <%# ***** 「link_to 'ゲストログイン', guest_sign_in_path, method: :post, class: 'btn btn-info btn-lg'」：画面へ値を出力する式 ***** %>
          <%= link_to '投稿一覧を見る', posts_path, class: 'btn btn-light btn-lg' %>
          <%# ***** 「link_to '投稿一覧を見る', posts_path, class: 'btn btn-light btn-lg'」：画面へ値を出力する式 ***** %>
        </div>
        <%# ***** 「</div>」：divタグ（汎用コンテナ要素）の終了 ***** %>
      <% end %>
      <%# ***** 「end」：ブロック処理を終了するキーワード ***** %>
    </div>
    <%# ***** 「</div>」：divタグ（汎用コンテナ要素）の終了 ***** %>
  </div>
  <%# ***** 「</div>」：divタグ（汎用コンテナ要素）の終了 ***** %>

